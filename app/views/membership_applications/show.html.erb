<% mask_contact = membership_application_mask_contact_pii? %>
<div class="membership-application-show"
     <% if mask_contact %>
       data-controller="sensitive-reveal"
     <% end %>>
<% if mask_contact %>
  <div class="alert alert-secondary d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mb-3">
    <p class="mb-0 small">Applicant email, mailing address, phone, and referring member contact fields are blurred until you show them.</p>
    <button type="button" class="btn btn-sm btn-primary text-nowrap flex-shrink-0"
            data-action="click->sensitive-reveal#toggle">
      <span data-sensitive-reveal-target="label">Show contact details</span>
    </button>
  </div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    Application #<%= @application.id %>
    <span class="badge bg-<%= @application.status_badge_color %>"><%= @application.status_display %></span>
  </h1>
  <div class="d-flex gap-2">
    <% if @application.submitted? %>
      <%= link_to mark_under_review_membership_application_path(@application),
          data: { turbo_method: :post },
          class: "btn btn-outline-warning" do %>
        <i class="bi bi-eye me-1"></i> Mark Under Review
      <% end %>
    <% end %>
    <%= link_to membership_applications_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i> Back
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="row">
      <div class="col-md-6">
        <dl>
          <dt>Email</dt>
          <dd>
            <%= membership_application_masked_contact_capture do %>
              <%= @application.email %>
            <% end %>
          </dd>

          <dt>Status</dt>
          <dd><span class="badge bg-<%= @application.status_badge_color %>"><%= @application.status_display %></span></dd>

          <dt>Submitted</dt>
          <dd><%= @application.submitted_at&.strftime('%B %d, %Y at %l:%M %p') || 'Not yet submitted' %></dd>

          <dt>Linked member</dt>
          <dd class="d-flex flex-wrap align-items-center gap-2">
            <% if @application.user %>
              <%= link_to @application.user.display_name, user_path(@application.user), class: "text-decoration-none" %>
              <%= button_to 'Unlink', unlink_user_membership_application_path(@application),
                            method: :post,
                            class: 'btn btn-sm btn-outline-warning',
                            form: { data: { turbo_confirm: 'Remove the member link from this application?' } } %>
            <% else %>
              <span class="text-muted">Not linked</span>
              <% if @users_for_application_link.any? %>
                <button type="button" class="btn btn-sm btn-primary"
                        data-bs-toggle="modal" data-bs-target="#maLinkMemberModal">
                  Link member
                </button>
              <% end %>
            <% end %>
          </dd>
        </dl>
      </div>
      <div class="col-md-6">
        <dl>
          <% if @application.reviewed_by.present? %>
            <dt>Reviewed by</dt>
            <dd><%= link_to @application.reviewed_by.display_name, user_path(@application.reviewed_by) %></dd>
          <% end %>

          <% if @application.reviewed_at.present? %>
            <dt>Reviewed on</dt>
            <dd><%= @application.reviewed_at.strftime('%B %d, %Y at %l:%M %p') %></dd>
          <% end %>

          <% if @application.admin_notes.present? %>
            <dt>Admin Notes</dt>
            <dd><%= simple_format(@application.admin_notes) %></dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>
</div>

<% unless @application.draft? %>
  <%= render 'ai_feedback_card', application: @application, current_ai_feedback_vote: @current_ai_feedback_vote %>
<% end %>

<% if @application.user.nil? && @users_for_application_link.any? %>
  <%= render 'link_member_modal',
             users: @users_for_application_link,
             form_url: link_user_membership_application_path(@application),
             application_email: @application.email,
             mask_contact: mask_contact %>
<% end %>

<% @pages_with_answers.each do |entry| %>
  <% page = entry[:page] %>
  <% questions = entry[:questions] %>
  <div class="card shadow-sm border-0 mb-3">
    <div class="card-header bg-body-secondary">
      <h5 class="mb-0"><%= page.title %></h5>
      <% if page.description.present? %>
        <small class="text-body-secondary"><%= page.description %></small>
      <% end %>
    </div>
    <div class="card-body">
      <% questions.each do |qa| %>
        <div class="mb-3">
          <dt class="text-muted small"><%= qa[:question].label %></dt>
          <dd class="mb-2">
            <% if qa[:answer]&.value.present? %>
              <% if membership_application_sensitive_answer_label?(qa[:question].label) %>
                <%= membership_application_masked_contact_capture do %>
                  <%= simple_format(qa[:answer].value) %>
                <% end %>
              <% else %>
                <%= simple_format(qa[:answer].value) %>
              <% end %>
            <% else %>
              <span class="text-muted fst-italic">No answer</span>
            <% end %>
          </dd>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% unless @application.approved? || @application.rejected? %>
  <div id="review-section" class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-body-secondary">
      <h5 class="mb-0">Review Application</h5>
    </div>
    <div class="card-body">
      <div class="mb-3">
        <label for="admin_notes" class="form-label">Admin Notes <span class="text-muted small">(optional)</span></label>
        <textarea id="admin_notes" class="form-control" rows="3"
                  placeholder="Reason for approval or rejection..."><%= @application.admin_notes %></textarea>
      </div>
      <div class="d-flex gap-2">
        <%= form_with url: approve_membership_application_path(@application), method: :post, local: true do %>
          <input type="hidden" name="admin_notes" id="approve_admin_notes" value="">
          <button type="submit" class="btn btn-success review-btn"
                  data-turbo-confirm="Approve this application?">
            <i class="bi bi-check-circle me-1"></i> Approve
          </button>
        <% end %>
        <%= form_with url: reject_membership_application_path(@application), method: :post, local: true do %>
          <input type="hidden" name="admin_notes" id="reject_admin_notes" value="">
          <button type="submit" class="btn btn-danger review-btn"
                  data-turbo-confirm="Reject this application?">
            <i class="bi bi-x-circle me-1"></i> Reject
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <script>
    (function() {
      function initReviewForm() {
        var notes = document.getElementById('admin_notes');
        if (!notes) return;
        document.querySelectorAll('.review-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var form = btn.closest('form');
            var hidden = form.querySelector('input[name="admin_notes"]');
            if (hidden) hidden.value = notes.value;
          });
        });
      }
      document.addEventListener('DOMContentLoaded', initReviewForm);
      document.addEventListener('turbo:load', initReviewForm);
    })();
  </script>
<% end %>

</div><%# .membership-application-show %>
