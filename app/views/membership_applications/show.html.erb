<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    Application #<%= @application.id %>
    <span class="badge bg-<%= @application.status_badge_color %>"><%= @application.status_display %></span>
  </h1>
  <div class="d-flex gap-2">
    <% if @application.submitted? %>
      <%= link_to mark_under_review_membership_application_path(@application),
          data: { turbo_method: :post },
          class: "btn btn-outline-warning" do %>
        <i class="bi bi-eye me-1"></i> Mark Under Review
      <% end %>
    <% end %>
    <% unless @application.approved? || @application.rejected? %>
      <%= link_to approve_membership_application_path(@application),
          data: { turbo_method: :post, turbo_confirm: 'Approve this application?' },
          class: "btn btn-outline-success" do %>
        <i class="bi bi-check-circle me-1"></i> Approve
      <% end %>
      <%= link_to reject_membership_application_path(@application),
          data: { turbo_method: :post, turbo_confirm: 'Reject this application?' },
          class: "btn btn-outline-danger" do %>
        <i class="bi bi-x-circle me-1"></i> Reject
      <% end %>
    <% end %>
    <%= link_to membership_applications_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i> Back
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="row">
      <div class="col-md-6">
        <dl>
          <dt>Email</dt>
          <dd><%= @application.email %></dd>

          <dt>Status</dt>
          <dd><span class="badge bg-<%= @application.status_badge_color %>"><%= @application.status_display %></span></dd>

          <dt>Submitted</dt>
          <dd><%= @application.submitted_at&.strftime('%B %d, %Y at %l:%M %p') || 'Not yet submitted' %></dd>
        </dl>
      </div>
      <div class="col-md-6">
        <dl>
          <% if @application.reviewed_by.present? %>
            <dt>Reviewed by</dt>
            <dd><%= link_to @application.reviewed_by.display_name, user_path(@application.reviewed_by) %></dd>
          <% end %>

          <% if @application.reviewed_at.present? %>
            <dt>Reviewed on</dt>
            <dd><%= @application.reviewed_at.strftime('%B %d, %Y at %l:%M %p') %></dd>
          <% end %>

          <% if @application.admin_notes.present? %>
            <dt>Admin Notes</dt>
            <dd><%= simple_format(@application.admin_notes) %></dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>
</div>

<% @pages_with_answers.each do |entry| %>
  <% page = entry[:page] %>
  <% questions = entry[:questions] %>
  <div class="card shadow-sm border-0 mb-3">
    <div class="card-header bg-light">
      <h5 class="mb-0"><%= page.title %></h5>
      <% if page.description.present? %>
        <small class="text-muted"><%= page.description %></small>
      <% end %>
    </div>
    <div class="card-body">
      <% questions.each do |qa| %>
        <div class="mb-3">
          <dt class="text-muted small"><%= qa[:question].label %></dt>
          <dd class="mb-2">
            <% if qa[:answer]&.value.present? %>
              <%= simple_format(qa[:answer].value) %>
            <% else %>
              <span class="text-muted fst-italic">No answer</span>
            <% end %>
          </dd>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% unless @application.approved? || @application.rejected? %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-light">
      <h5 class="mb-0">Admin Notes</h5>
    </div>
    <div class="card-body">
      <%= form_with url: approve_membership_application_path(@application), method: :post, local: true do %>
        <div class="mb-3">
          <textarea name="admin_notes" class="form-control" rows="3"
                    placeholder="Optional notes about this application..."><%= @application.admin_notes %></textarea>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-success">
            <i class="bi bi-check-circle me-1"></i> Approve with Notes
          </button>
        </div>
      <% end %>
      <%= form_with url: reject_membership_application_path(@application), method: :post, local: true, class: "mt-2" do %>
        <input type="hidden" name="admin_notes" value="">
        <button type="submit" class="btn btn-outline-danger btn-sm"
                data-turbo-confirm="Reject this application?">
          <i class="bi bi-x-circle me-1"></i> Reject with Notes Above
        </button>
      <% end %>
    </div>
  </div>
<% end %>
