<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Edit Queued Message</h1>
    <p class="text-muted mb-0">Modify the message before approving it for delivery.</p>
  </div>
  <div>
    <%= link_to "Cancel", queued_mail_path(@queued_mail), class: "btn btn-secondary" %>
  </div>
</div>

<%= render 'shared/smtp_warning' %>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <%= form_with(model: @queued_mail, class: "needs-validation") do |f| %>
      <div class="mb-3">
        <%= f.label :to, "Recipient Email", class: "form-label" %>
        <%= f.text_field :to, class: "form-control #{'is-invalid' if @queued_mail.errors.key?(:to)}", required: true %>
        <% if @queued_mail.errors.key?(:to) %>
          <div class="invalid-feedback"><%= @queued_mail.errors[:to].join(', ') %></div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :subject, class: "form-label" %>
        <%= f.text_field :subject, class: "form-control #{'is-invalid' if @queued_mail.errors.key?(:subject)}", required: true %>
        <% if @queued_mail.errors.key?(:subject) %>
          <div class="invalid-feedback"><%= @queued_mail.errors[:subject].join(', ') %></div>
        <% end %>
      </div>

      <div class="mb-3" data-controller="rich-editor" data-rich-editor-variables-value="[]">
        <%= f.label :body_html, "HTML Body", class: "form-label" %>
        <div class="mb-2">
          <small class="text-muted">Use the toolbar to format, or click "Source Code" (&lt;&gt;) to edit raw HTML.</small>
        </div>
        <%= f.text_area :body_html, class: "form-control #{'is-invalid' if @queued_mail.errors.key?(:body_html)}", rows: 16, required: true, data: { rich_editor_target: "editor" } %>
        <% if @queued_mail.errors.key?(:body_html) %>
          <div class="invalid-feedback"><%= @queued_mail.errors[:body_html].join(', ') %></div>
        <% end %>
        <div class="form-text">HTML content of the email. The mailer layout wrapping is applied automatically when sent.</div>
      </div>

      <div class="mb-3">
        <%= f.label :body_text, "Plain Text Body", class: "form-label" %>
        <%= f.text_area :body_text, class: "form-control font-monospace", rows: 10 %>
        <div class="form-text">Optional plain text alternative for email clients that don't support HTML.</div>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Save Changes", class: "btn btn-primary" %>
        <%= link_to "Cancel", queued_mail_path(@queued_mail), class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<% if @queued_mail.email_template %>
  <div class="alert alert-info">
    <i class="bi bi-info-circle me-2"></i>
    This message was generated from the
    <%= link_to @queued_mail.email_template.name, email_template_path(@queued_mail.email_template) %>
    template. You can
    <%= link_to "regenerate it", regenerate_queued_mail_path(@queued_mail), method: :post,
        data: { turbo_confirm: "This will overwrite your edits with a fresh render from the template. Continue?" } %>
    to reset to the current template content.
  </div>
<% end %>
