<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Queued Message</h1>
    <p class="text-muted mb-0">
      <% if @queued_mail.delivery_failed? %>
        <span class="badge text-bg-danger">Send Failed</span>
      <% elsif @queued_mail.delivery_pending? %>
        <span class="badge text-bg-info">Sending...</span>
      <% elsif @queued_mail.sent? %>
        <span class="badge text-bg-success">Sent</span>
      <% elsif @queued_mail.pending? %>
        <span class="badge text-bg-warning">Pending Review</span>
      <% elsif @queued_mail.rejected? %>
        <span class="badge text-bg-secondary">Rejected</span>
      <% end %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <% if @queued_mail.delivery_failed? %>
      <%= button_to "Retry Sending", retry_queued_mail_path(@queued_mail), method: :post,
          class: "btn btn-warning",
          data: { turbo_confirm: "Retry sending this email to #{@queued_mail.to}?" } %>
    <% end %>
    <% if @queued_mail.pending? %>
      <%= link_to "Edit", edit_queued_mail_path(@queued_mail), class: "btn btn-outline-primary" %>
      <% if @queued_mail.can_regenerate? %>
        <%= button_to "Regenerate from Template", regenerate_queued_mail_path(@queued_mail), method: :post,
            class: "btn btn-outline-info",
            data: { turbo_confirm: "This will overwrite the current message with a fresh render from the template. Continue?" } %>
      <% end %>
      <% if smtp_configured? %>
        <%= button_to "Approve & Send", approve_queued_mail_path(@queued_mail), method: :post,
            class: "btn btn-success",
            data: { turbo_confirm: "This will send this email to #{@queued_mail.to}. Continue?" } %>
      <% else %>
        <button class="btn btn-success" disabled title="SMTP not configured">Approve & Send</button>
      <% end %>
      <%= button_to "Reject", reject_queued_mail_path(@queued_mail), method: :post,
          class: "btn btn-danger",
          data: { turbo_confirm: "Reject this email? It will not be sent." } %>
    <% end %>
    <%= link_to "Back to Queue", queued_mails_path, class: "btn btn-secondary" %>
  </div>
</div>

<%= render 'shared/smtp_warning' %>

<div class="row">
  <div class="col-lg-4 mb-4">
    <div class="card shadow-sm border-0">
      <div class="card-header">
        <h5 class="mb-0">Details</h5>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4 text-secondary">To</dt>
          <dd class="col-sm-8"><code><%= @queued_mail.to %></code></dd>

          <dt class="col-sm-4 text-secondary">Subject</dt>
          <dd class="col-sm-8"><%= @queued_mail.subject %></dd>

          <dt class="col-sm-4 text-secondary">Reason</dt>
          <dd class="col-sm-8"><%= @queued_mail.reason %></dd>

          <% if @queued_mail.recipient %>
            <dt class="col-sm-4 text-secondary">Recipient</dt>
            <dd class="col-sm-8"><%= link_to @queued_mail.recipient.display_name, user_path(@queued_mail.recipient) %></dd>
          <% end %>

          <dt class="col-sm-4 text-secondary">Template</dt>
          <dd class="col-sm-8">
            <% if @queued_mail.email_template %>
              <%= link_to @queued_mail.email_template.name, email_template_path(@queued_mail.email_template) %>
            <% else %>
              <span class="text-muted fst-italic">View-based (no database template)</span>
            <% end %>
          </dd>

          <dt class="col-sm-4 text-secondary">Action</dt>
          <dd class="col-sm-8"><code><%= @queued_mail.mailer_action %></code></dd>

          <dt class="col-sm-4 text-secondary">Queued</dt>
          <dd class="col-sm-8"><%= @queued_mail.created_at.strftime('%b %d, %Y %l:%M %p') %></dd>

          <% if @queued_mail.reviewed_by %>
            <dt class="col-sm-4 text-secondary">Reviewed by</dt>
            <dd class="col-sm-8"><%= link_to @queued_mail.reviewed_by.display_name, user_path(@queued_mail.reviewed_by) %></dd>

            <dt class="col-sm-4 text-secondary">Reviewed at</dt>
            <dd class="col-sm-8"><%= @queued_mail.reviewed_at&.strftime('%b %d, %Y %l:%M %p') %></dd>
          <% end %>

          <% if @queued_mail.sent_at %>
            <dt class="col-sm-4 text-secondary">Sent at</dt>
            <dd class="col-sm-8"><%= @queued_mail.sent_at.strftime('%b %d, %Y %l:%M %p') %></dd>
          <% end %>

          <% if @queued_mail.send_attempts > 0 %>
            <dt class="col-sm-4 text-secondary">Attempts</dt>
            <dd class="col-sm-8"><%= @queued_mail.send_attempts %></dd>
          <% end %>

          <% if @queued_mail.last_error.present? %>
            <dt class="col-sm-4 text-danger">Last Error</dt>
            <dd class="col-sm-8">
              <code class="text-danger"><%= @queued_mail.last_error %></code>
              <% if @queued_mail.last_error_at %>
                <div class="text-muted small"><%= time_ago_in_words(@queued_mail.last_error_at) %> ago</div>
              <% end %>
            </dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-8 mb-4">
    <div class="card shadow-sm border-0">
      <div class="card-header">
        <h5 class="mb-0">Message Preview</h5>
      </div>
      <div class="card-body p-0">
        <iframe id="mail_preview" srcdoc="<%= ERB::Util.html_escape(@queued_mail.body_html) %>"
                style="width: 100%; min-height: 400px; border: none;"
                sandbox="allow-same-origin"></iframe>
      </div>
    </div>

    <% if @queued_mail.body_text.present? %>
      <div class="card shadow-sm border-0 mt-3">
        <div class="card-header">
          <h5 class="mb-0">Plain Text Version</h5>
        </div>
        <div class="card-body">
          <pre class="mb-0 text-body bg-body" style="white-space: pre-wrap;"><%= @queued_mail.body_text %></pre>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
  (function() {
    function resizeIframe() {
      var iframe = document.getElementById('mail_preview');
      if (!iframe) return;
      iframe.addEventListener('load', function() {
        try {
          var height = iframe.contentDocument.documentElement.scrollHeight;
          iframe.style.height = Math.max(height + 20, 400) + 'px';
        } catch(e) {}
      });
    }
    document.addEventListener('DOMContentLoaded', resizeIframe);
    document.addEventListener('turbo:load', resizeIframe);
  })();
</script>
