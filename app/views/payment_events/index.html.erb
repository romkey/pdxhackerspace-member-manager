<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Payment Events</h1>
    <p class="text-muted mb-0">
      <strong><%= @total_count %></strong> events<%= " (filtered)" if @filter.present? %>
    </p>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <div class="btn-group btn-group-sm mb-3" role="group">
      <%= link_to "All", payment_events_path, class: "btn #{@filter.blank? ? 'btn-primary' : 'btn-outline-primary'}" %>
      <%= link_to "Payments", payment_events_path(event_type: 'payment'), class: "btn #{@filter == 'payment' ? 'btn-primary' : 'btn-outline-primary'}" %>
      <%= link_to "Subscriptions", payment_events_path(event_type: 'subscription_started'), class: "btn #{@filter == 'subscription_started' ? 'btn-primary' : 'btn-outline-primary'}" %>
      <%= link_to "Cancellations", payment_events_path(event_type: 'subscription_cancelled'), class: "btn #{@filter == 'subscription_cancelled' ? 'btn-primary' : 'btn-outline-primary'}" %>
      <%= link_to "Paused", payment_events_path(event_type: 'subscription_paused'), class: "btn #{@filter == 'subscription_paused' ? 'btn-primary' : 'btn-outline-primary'}" %>
      <%= link_to "Resumed", payment_events_path(event_type: 'subscription_resumed'), class: "btn #{@filter == 'subscription_resumed' ? 'btn-primary' : 'btn-outline-primary'}" %>
    </div>

    <% if @payment_events.any? %>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="bg-body-tertiary">
            <tr>
              <th scope="col">Member</th>
              <th scope="col">Event</th>
              <th scope="col">Source</th>
              <th scope="col">Details</th>
              <th scope="col">Amount</th>
              <th scope="col">Time</th>
            </tr>
          </thead>
          <tbody>
            <% @payment_events.each do |event| %>
              <tr>
                <td>
                  <% if event.user %>
                    <%= link_to event.user.display_name, user_path(event.user), class: "text-decoration-none" %>
                  <% else %>
                    <span class="text-muted fst-italic">Unlinked</span>
                  <% end %>
                </td>
                <td><span class="badge <%= payment_event_badge_class(event.event_type) %>"><%= event.event_type.humanize %></span></td>
                <td><span class="badge text-bg-secondary"><%= event.source.titleize %></span></td>
                <td>
                  <% linked = event.linked_payment %>
                  <% if linked %>
                    <%= link_to event.details || event.identifier, payment_show_path(linked), class: "text-decoration-none" %>
                  <% else %>
                    <span class="text-muted"><%= event.details || event.identifier %></span>
                  <% end %>
                </td>
                <td><%= event.amount_with_currency || "—" %></td>
                <td class="text-nowrap"><%= event.occurred_at ? l(event.occurred_at, format: :long) : "n/a" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-3">
          <%== @pagy.series_nav(:bootstrap) %>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted mb-0">
        <% if @filter.present? %>
          No <%= @filter.humanize.downcase %> events found.
        <% else %>
          No payment events have been recorded yet.
        <% end %>
      </p>
    <% end %>
  </div>
</div>
