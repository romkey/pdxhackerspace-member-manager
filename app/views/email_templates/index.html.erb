<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Email Templates</h1>
    <p class="text-muted mb-0">Manage the email messages sent to members.</p>
  </div>
  <div class="d-flex gap-2">
    <%= button_to "Seed Defaults", seed_email_templates_path, method: :post, class: "btn btn-outline-secondary", data: { turbo_confirm: "This will create any missing default templates. Existing templates will not be modified. Continue?" } %>
    <%= link_to "Back to Settings", settings_path, class: "btn btn-outline-secondary" %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <h2 class="h6 mb-3">Available Template Variables</h2>
    <div class="row">
      <% EmailTemplate::AVAILABLE_VARIABLES.each do |var, desc| %>
        <div class="col-md-6 col-lg-4 mb-2">
          <code class="text-primary"><%= var %></code>
          <span class="text-muted small ms-1">— <%= desc %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Filters -->
<div class="d-flex flex-wrap gap-2 mb-3">
  <% filter_chips = [
       { label: "All", filter: nil, count: @filter_counts[:all] },
       { label: "Needs review", filter: "needs_review", count: @filter_counts[:needs_review], variant: "warning" },
       { label: "Reviewed", filter: "reviewed", count: @filter_counts[:reviewed] },
       { label: "Enabled", filter: "enabled", count: @filter_counts[:enabled] },
       { label: "Disabled", filter: "disabled", count: @filter_counts[:disabled] },
       { label: "Send immediately", filter: "send_immediately", count: @filter_counts[:send_immediately], variant: "warning" },
       { label: "Immediate send blocked", filter: "immediate_send_blocked", count: @filter_counts[:immediate_send_blocked] }
     ] %>
  <% filter_chips.each do |chip| %>
    <% active = chip[:filter].nil? ? @filter.blank? : @filter == chip[:filter] %>
    <% classes = ["filter-chip", "text-decoration-none", chip[:variant], ("active" if active), ("muted" if chip[:count].zero?)].compact.join(" ") %>
    <% if chip[:count].zero? %>
      <span class="<%= classes %>" aria-disabled="true">
        <%= chip[:label] %> <span class="count"><%= chip[:count] %></span>
      </span>
    <% else %>
      <%= link_to email_templates_path(filter: chip[:filter]), class: classes do %>
        <%= chip[:label] %> <span class="count"><%= chip[:count] %></span>
      <% end %>
    <% end %>
  <% end %>
</div>

<% if @email_templates.any? %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Template</th>
            <th>Subject</th>
            <th>Delivery</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @email_templates.each do |template| %>
            <tr class="<%= 'table-secondary' unless template.enabled? %>">
              <td>
                <div class="fw-semibold">
                  <%= link_to template.name, email_template_path(template), class: "text-decoration-none" %>
                </div>
                <% if template.description.present? %>
                  <div class="text-muted small"><%= template.description %></div>
                <% end %>
                <div class="text-muted small">Key: <code><%= template.key %></code></div>
              </td>
              <td>
                <span class="text-truncate d-inline-block" style="max-width: 300px;">
                  <%= template.subject %>
                </span>
              </td>
              <td>
                <% if template.send_immediately? %>
                  <span class="badge text-bg-warning-subtle">Send immediately</span>
                <% else %>
                  <span class="text-muted small">Queued</span>
                <% end %>
                <% if template.block_send_immediately? %>
                  <span class="badge text-bg-secondary-subtle">Immediate send blocked</span>
                <% end %>
              </td>
              <td>
                <% if template.enabled? %>
                  <span class="badge text-bg-success-subtle">Enabled</span>
                <% else %>
                  <span class="badge text-bg-secondary-subtle">Disabled</span>
                <% end %>
                <% if template.needs_review? %>
                  <span class="badge text-bg-warning-subtle"><i class="bi bi-exclamation-circle me-1"></i>Needs review</span>
                <% end %>
              </td>
              <td class="text-end">
                <div class="btn-group btn-group-sm">
                  <%= link_to "View", email_template_path(template), class: "btn btn-outline-secondary" %>
                  <%= link_to "Preview", preview_email_template_path(template), class: "btn btn-outline-secondary", target: "_blank" %>
                  <%= link_to "Edit", edit_email_template_path(template), class: "btn btn-outline-secondary" %>
                  <%= button_to template.enabled? ? "Disable" : "Enable", 
                      toggle_email_template_path(template), 
                      method: :post, 
                      class: "btn btn-outline-secondary" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="card shadow-sm border-0">
    <div class="card-body text-center py-5">
      <% if @filter.present? %>
        <p class="text-muted mb-3">No email templates match this filter.</p>
        <%= link_to "Show all templates", email_templates_path, class: "btn btn-outline-primary" %>
      <% else %>
        <p class="text-muted mb-3">No email templates found.</p>
        <%= button_to "Create Default Templates", seed_email_templates_path, method: :post, class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
<% end %>
