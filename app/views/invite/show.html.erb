<div class="row justify-content-center mt-5">
  <div class="col-lg-6 col-md-8">

    <% if @error == :not_found %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-question-circle display-3 text-muted d-block mb-3"></i>
          <h2 class="h4 mb-2">Invitation Not Found</h2>
          <p class="text-muted">This invitation link is not valid. Please check the link in your email and try again.</p>
        </div>
      </div>
      <% return %>
    <% end %>

    <% if @error == :expired %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-clock-history display-3 text-warning d-block mb-3"></i>
          <h2 class="h4 mb-2">Invitation Expired</h2>
          <p class="text-muted">This invitation has expired. Please contact an administrator to receive a new invitation.</p>
        </div>
      </div>
      <% return %>
    <% end %>

    <% if @error == :cancelled %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-x-circle display-3 text-danger d-block mb-3"></i>
          <h2 class="h4 mb-2">Invitation Cancelled</h2>
          <p class="text-muted">This invitation has been cancelled. Please contact an administrator if you believe this is a mistake.</p>
        </div>
      </div>
      <% return %>
    <% end %>

    <% if @error == :already_accepted %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-check-circle display-3 text-success d-block mb-3"></i>
          <h2 class="h4 mb-2">Already Accepted</h2>
          <p class="text-muted">This invitation has already been used to create an account. You can log in to access your account.</p>
          <%= link_to "Go to Login", login_path, class: "btn btn-primary mt-2" %>
        </div>
      </div>
      <% return %>
    <% end %>

    <div class="text-center mb-4">
      <h1 class="h3">Welcome!</h1>
      <p class="text-muted">
        You've been invited to join
        <strong><%= ENV.fetch('ORGANIZATION_NAME', 'Member Manager') %></strong>
        as a <strong><%= @invitation.type_label %></strong>.
      </p>
      <p class="text-muted small"><%= @invitation.type_description %></p>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body">
        <h2 class="h5 mb-3">Create Your Account</h2>

        <% if defined?(@user) && @user&.errors&.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: @user, url: accept_invite_path(@invitation.token), method: :post, local: true, class: "vstack gap-3" do |f| %>
          <div>
            <label class="form-label">Email Address</label>
            <input type="email" class="form-control" value="<%= @invitation.email %>" disabled>
            <div class="form-text">This is the email address your invitation was sent to.</div>
          </div>

          <div>
            <%= f.label :full_name, "Full Name", class: "form-label" %> <span class="text-danger">*</span>
            <%= f.text_field :full_name, class: "form-control", required: true, placeholder: "Your full name", autofocus: true, id: "invite_full_name" %>
          </div>

          <div>
            <%= f.label :username, "Username", class: "form-label" %>
            <%= f.text_field :username, class: "form-control", placeholder: "Auto-generated from your name", id: "invite_username" %>
            <div class="form-text">Auto-generated from your name. Edit if needed.</div>
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-primary btn-lg">
              <i class="bi bi-person-check me-1"></i>Create My Account
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <p class="text-center text-muted small mt-3">
      This invitation expires <%= time_ago_in_words(@invitation.expires_at) %> from now.
    </p>
  </div>
</div>

<%= render 'shared/username_autogenerate', name_field_id: 'invite_full_name', username_field_id: 'invite_username' %>
