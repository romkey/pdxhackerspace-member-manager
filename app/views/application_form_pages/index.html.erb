<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Application Form</h1>
  <%= link_to "Add Page", new_application_form_page_path, class: "btn btn-primary" %>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-header">
    <strong>How applicants apply</strong>
  </div>
  <div class="card-body">
    <%= form_with url: update_application_flow_application_form_pages_path, method: :patch, local: true do %>
      <div class="form-check mb-2">
        <%= radio_button_tag :use_builtin_membership_application, '1',
            @membership_setting.use_builtin_membership_application?,
            class: 'form-check-input', id: 'flow_builtin' %>
        <label class="form-check-label" for="flow_builtin">
          Built-in flow at <code>/apply</code> and <code>/apply/new</code> (email verification and the wizard below).
        </label>
      </div>
      <div class="form-check mb-3">
        <%= radio_button_tag :use_builtin_membership_application, '0',
            !@membership_setting.use_builtin_membership_application?,
            class: 'form-check-input', id: 'flow_external' %>
        <label class="form-check-label" for="flow_external">
          External: show the Apply for membership text (for example a Google Form link) instead of the built-in wizard.
        </label>
      </div>
      <% frag = TextFragment.find_by(key: 'apply_for_membership') %>
      <% if frag %>
        <p class="text-muted small mb-3">
          <%= link_to 'Edit apply text', edit_text_fragment_path(frag), class: 'text-decoration-none' %>:
          shown on the public <%= link_to 'apply page', apply_path, class: 'text-decoration-none' %> when the external option is selected (built-in redirects <code>/apply</code> to the wizard).
        </p>
      <% end %>
      <%= submit_tag 'Save application flow', class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>

<% if @pages.any? %>
  <% @pages.each do |page| %>
    <div class="card shadow-sm border-0 mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <span class="badge bg-secondary me-2">Page <%= page.position %></span>
          <strong><%= page.title %></strong>
          <% if page.description.present? %>
            <span class="text-muted small ms-2"><%= truncate(page.description, length: 80) %></span>
          <% end %>
        </div>
        <div class="d-flex gap-1">
          <%= link_to new_application_form_page_application_form_question_path(page),
              class: "btn btn-sm btn-outline-success" do %>
            <i class="bi bi-plus-lg me-1"></i>Add Question
          <% end %>
          <%= link_to "Edit", edit_application_form_page_path(page), class: "btn btn-sm btn-outline-primary" %>
          <%= link_to "Delete", application_form_page_path(page),
              data: { turbo_method: :delete, turbo_confirm: "Delete page '#{page.title}' and all its questions?" },
              class: "btn btn-sm btn-outline-danger" %>
        </div>
      </div>
      <% if page.questions.any? %>
        <div class="list-group list-group-flush">
          <% page.questions.ordered.each do |q| %>
            <div class="list-group-item d-flex justify-content-between align-items-start">
              <div>
                <div>
                  <%= q.label %>
                  <% if q.required? %>
                    <span class="text-danger">*</span>
                  <% end %>
                </div>
                <small class="text-muted">
                  <%= q.field_type %>
                  <% if q.radio? && q.options.any? %>
                    &mdash; Options: <%= q.options.join(', ') %>
                  <% end %>
                </small>
              </div>
              <div class="d-flex gap-1 flex-shrink-0 ms-3">
                <%= link_to "Edit",
                    edit_application_form_page_application_form_question_path(page, q),
                    class: "btn btn-sm btn-outline-primary" %>
                <%= link_to "Delete",
                    application_form_page_application_form_question_path(page, q),
                    data: { turbo_method: :delete, turbo_confirm: "Remove this question?" },
                    class: "btn btn-sm btn-outline-danger" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="card-body text-muted text-center py-3">
          No questions yet. <%= link_to "Add one", new_application_form_page_application_form_question_path(page) %>.
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-file-earmark-text fs-1 d-block mb-2"></i>
    <p>No pages configured yet.</p>
    <%= link_to "Add the first page", new_application_form_page_path, class: "btn btn-primary" %>
  </div>
<% end %>

<div class="mt-3">
  <%= link_to "← Back to Settings", settings_path, class: "text-muted" %>
</div>
