<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1"><%= @interest.name %></h1>
    <p class="text-muted mb-0"><%= @members.count %> <%= 'member'.pluralize(@members.count) %> selected this interest</p>
  </div>
  <%= link_to "Back to Interests", interests_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm border-0">
  <% if @members.any? %>
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead class="bg-body-tertiary">
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Username</th>
            <th scope="col">Email</th>
            <th scope="col" style="width: 80px;"></th>
          </tr>
        </thead>
        <tbody>
          <% @members.each do |member| %>
            <tr>
              <td><%= member.display_name %></td>
              <td class="text-muted"><%= member.username.present? ? "@#{member.username}" : "—" %></td>
              <td class="text-muted"><%= member.email.presence || "—" %></td>
              <td>
                <%= link_to "View", user_path(member), class: "btn btn-outline-secondary btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body text-center py-5">
      <p class="text-muted mb-0">No members have selected this interest yet.</p>
    </div>
  <% end %>
</div>
