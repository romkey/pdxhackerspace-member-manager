<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Invitations</h1>
    <p class="text-muted mb-0">All membership invitations sent by admins.</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_invitation_path, class: "btn btn-primary" do %>
      <i class="bi bi-envelope-plus me-1"></i>Send New Invitation
    <% end %>
    <%= link_to "Back to Settings", settings_path, class: "btn btn-outline-secondary" %>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <% if @invitations.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Email</th>
              <th>Type</th>
              <th>Status</th>
              <th>Invited By</th>
              <th>Sent</th>
              <th>Expires</th>
              <th>Member</th>
            </tr>
          </thead>
          <tbody>
            <% @invitations.each do |invitation| %>
              <tr>
                <td><%= invitation.email %></td>
                <td><span class="badge text-bg-secondary"><%= invitation.type_label %></span></td>
                <td>
                  <% if invitation.accepted? %>
                    <span class="badge text-bg-success"><i class="bi bi-check-circle me-1"></i>Accepted</span>
                  <% elsif invitation.expired? %>
                    <span class="badge text-bg-danger"><i class="bi bi-clock-history me-1"></i>Expired</span>
                  <% else %>
                    <span class="badge text-bg-warning"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                  <% end %>
                </td>
                <td><%= invitation.invited_by.display_name %></td>
                <td><%= time_ago_in_words(invitation.created_at) %> ago</td>
                <td>
                  <% if invitation.accepted? %>
                    <span class="text-muted">—</span>
                  <% elsif invitation.expired? %>
                    <span class="text-danger small"><%= time_ago_in_words(invitation.expires_at) %> ago</span>
                  <% else %>
                    <span class="small">in <%= time_ago_in_words(invitation.expires_at) %></span>
                  <% end %>
                </td>
                <td>
                  <% if invitation.user.present? %>
                    <%= link_to invitation.user.display_name, user_path(invitation.user), class: "text-decoration-none" %>
                  <% else %>
                    <span class="text-muted fst-italic">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-envelope display-4 d-block mb-3"></i>
        <p class="mb-2">No invitations have been sent yet.</p>
        <%= link_to "Send the first invitation", new_invitation_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
