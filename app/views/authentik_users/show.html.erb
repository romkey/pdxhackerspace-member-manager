<div class="mb-4 d-flex justify-content-between align-items-center">
  <div class="d-flex gap-2 align-items-center">
    <% if @previous_authentik_user %>
      <%= link_to authentik_user_path(@previous_authentik_user), class: "btn btn-outline-secondary", title: "Previous: #{@previous_authentik_user.display_name}" do %>
        <i class="bi bi-chevron-left"></i> Previous
      <% end %>
    <% else %>
      <span class="btn btn-outline-secondary disabled" title="First user">
        <i class="bi bi-chevron-left"></i> Previous
      </span>
    <% end %>
    
    <% if @next_authentik_user %>
      <%= link_to authentik_user_path(@next_authentik_user), class: "btn btn-outline-secondary", title: "Next: #{@next_authentik_user.display_name}" do %>
        Next <i class="bi bi-chevron-right"></i>
      <% end %>
    <% else %>
      <span class="btn btn-outline-secondary disabled" title="Last user">
        Next <i class="bi bi-chevron-right"></i>
      </span>
    <% end %>
  </div>
  
  <div>
    <%= link_to "&larr; Back to Authentik users".html_safe, authentik_users_path, class: "text-decoration-none" %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <h1 class="h4 mb-0"><%= @authentik_user.display_name %></h1>
      <div class="d-flex gap-2">
        <% if @authentik_user.is_active? %>
          <span class="badge text-bg-success">Active</span>
        <% else %>
          <span class="badge text-bg-secondary">Inactive</span>
        <% end %>
        <% if @authentik_user.is_superuser? %>
          <span class="badge text-bg-info">Superuser</span>
        <% end %>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6">
        <dl class="row mb-0">
          <dt class="col-sm-4 text-secondary">Authentik ID</dt>
          <dd class="col-sm-8"><code><%= @authentik_user.authentik_id %></code></dd>

          <dt class="col-sm-4 text-secondary">Email</dt>
          <dd class="col-sm-8">
            <% if @authentik_user.email.present? %>
              <%= mail_to @authentik_user.email %>
            <% else %>
              <span class="text-muted fst-italic">Not provided</span>
            <% end %>
          </dd>

          <dt class="col-sm-4 text-secondary">Full Name</dt>
          <dd class="col-sm-8"><%= @authentik_user.full_name.presence || "—" %></dd>

          <dt class="col-sm-4 text-secondary">Username</dt>
          <dd class="col-sm-8"><%= @authentik_user.username.presence || "—" %></dd>

          <dt class="col-sm-4 text-secondary">Linked Member</dt>
          <dd class="col-sm-8">
            <% if @authentik_user.user.present? %>
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <%= link_to @authentik_user.user.display_name, user_path(@authentik_user.user), class: "text-decoration-none" %>
                <%= button_to "Disassociate", unlink_user_authentik_user_path(@authentik_user),
                    method: :post, class: "btn btn-sm btn-outline-secondary",
                    data: { turbo: false, turbo_confirm: "Disassociate this Authentik user from #{@authentik_user.user.display_name}?" } %>
              </div>
            <% else %>
              <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#linkUserModal">
                Link Member
              </button>
            <% end %>
          </dd>

          <dt class="col-sm-4 text-secondary">Last Synced</dt>
          <dd class="col-sm-8">
            <% if @authentik_user.last_synced_at %>
              <%= l(@authentik_user.last_synced_at, format: :long) %>
              <span class="text-muted">(<%= time_ago_in_words(@authentik_user.last_synced_at) %> ago)</span>
            <% else %>
              <span class="text-muted fst-italic">Never</span>
            <% end %>
          </dd>
        </dl>
      </div>
    </div>
  </div>
</div>

<% if @authentik_user.user && @authentik_user.has_discrepancies? %>
  <div class="card shadow-sm border-0 mb-4 border-warning">
    <div class="card-header bg-warning text-dark">
      <h2 class="h6 mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Discrepancies Detected</h2>
    </div>
    <div class="card-body">
      <p class="mb-3">The following fields differ between Authentik and MemberManager:</p>
      <table class="table table-sm mb-3">
        <thead>
          <tr>
            <th>Field</th>
            <th>Authentik Value</th>
            <th>MemberManager Value</th>
          </tr>
        </thead>
        <tbody>
          <% @authentik_user.discrepancies.each do |discrepancy| %>
            <tr>
              <td><strong><%= discrepancy[:field].titleize %></strong></td>
              <td><%= discrepancy[:authentik].presence || "<em class='text-muted'>empty</em>".html_safe %></td>
              <td><%= discrepancy[:user].presence || "<em class='text-muted'>empty</em>".html_safe %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div class="d-flex gap-2">
        <%= button_to "Accept Authentik Values", accept_changes_authentik_user_path(@authentik_user), 
            method: :post, 
            class: "btn btn-warning",
            data: { turbo: false, confirm: "This will update MemberManager with Authentik's values. Continue?" } %>
        <%= button_to "Push MemberManager Values to Authentik", push_to_authentik_authentik_user_path(@authentik_user), 
            method: :post, 
            class: "btn btn-outline-secondary",
            data: { turbo: false } %>
      </div>
    </div>
  </div>
<% end %>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <h2 class="h6 mb-3">Raw Attributes</h2>
    <pre class="bg-body-secondary rounded p-3 mb-0"><code class="text-body"><%= JSON.pretty_generate(@authentik_user.raw_attributes) %></code></pre>
  </div>
</div>

<% if @authentik_user.user.nil? %>
  <%= render 'shared/link_user_modal',
    modal_title: 'Link Member to Authentik User',
    form_url: link_user_authentik_user_path(@authentik_user),
    description: "Select a user to link to this Authentik user. The user's <code>authentik_id</code> will be updated.".html_safe,
    users: @all_users,
    show_email: true %>
<% end %>
