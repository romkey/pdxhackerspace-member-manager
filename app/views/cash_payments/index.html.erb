<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Cash Payments</h1>
    <p class="text-muted mb-0">Manually recorded cash payments tied to personal membership plans.</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to "Record Payment", new_cash_payment_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @cash_payments.any? %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead class="bg-body-tertiary">
          <tr>
            <th scope="col">Member</th>
            <th scope="col">Plan</th>
            <th scope="col">Amount</th>
            <th scope="col">Date</th>
            <th scope="col">Notes</th>
            <th scope="col">Recorded By</th>
            <th scope="col" class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @cash_payments.each do |payment| %>
            <tr>
              <td>
                <%= link_to payment.user.display_name, user_path(payment.user), class: "fw-semibold text-decoration-none" %>
              </td>
              <td>
                <span class="badge text-bg-info"><%= payment.membership_plan.name %></span>
              </td>
              <td><strong><%= number_to_currency(payment.amount) %></strong></td>
              <td><%= payment.paid_on.strftime('%b %d, %Y') %></td>
              <td>
                <% if payment.notes.present? %>
                  <span class="text-muted small"><%= truncate(payment.notes, length: 60) %></span>
                <% else %>
                  <span class="text-muted fst-italic">—</span>
                <% end %>
              </td>
              <td>
                <% if payment.recorded_by.present? %>
                  <span class="text-muted small"><%= payment.recorded_by.display_name %></span>
                <% else %>
                  <span class="text-muted fst-italic">—</span>
                <% end %>
              </td>
              <td class="text-end">
                <%= link_to "View", cash_payment_path(payment), class: "btn btn-outline-primary btn-sm" %>
                <%= link_to "Edit", edit_cash_payment_path(payment), class: "btn btn-outline-secondary btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <% if @pagy.pages > 1 %>
    <div class="mt-3">
      <%== @pagy.series_nav(:bootstrap) %>
    </div>
  <% end %>
<% else %>
  <div class="card shadow-sm border-0">
    <div class="card-body text-center py-5">
      <i class="bi bi-cash-coin display-4 text-muted mb-3 d-block"></i>
      <p class="text-muted mb-3">No cash payments have been recorded yet.</p>
      <%= link_to "Record First Payment", new_cash_payment_path, class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
