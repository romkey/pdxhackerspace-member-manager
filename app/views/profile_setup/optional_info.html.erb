<div class="py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="d-flex justify-content-center mb-4">
        <div class="d-flex align-items-center gap-2">
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">Basic Info</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-primary">2</span>
          <span class="fw-semibold small">About You</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">3</span>
          <span class="text-muted small">Links</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">4</span>
          <span class="text-muted small">Interests</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">5</span>
          <span class="text-muted small">Visibility</span>
        </div>
      </div>

      <!-- Member summary -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body py-2">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-check-circle-fill text-success fs-4"></i>
            <div>
              <span class="fw-semibold"><%= @user.display_name %></span>
              <span class="text-muted ms-2"><%= @user.email %></span>
              <% if @user.username.present? %>
                <span class="text-muted ms-2">@<%= @user.username %></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Pronouns & Bio -->
      <div class="card shadow-sm border-0">
        <div class="card-header bg-body-tertiary">
          <h4 class="card-title mb-0"><i class="bi bi-chat-square-text me-2"></i>About You</h4>
        </div>
        <div class="card-body">
          <div class="alert alert-light border mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Everything on this page is <strong>completely optional</strong>. If you plan to keep your profile private or just don't have anything to add right now, feel free to skip ahead.
          </div>

          <%= form_with url: profile_setup_save_optional_path, scope: :user, method: :post, class: "vstack gap-3", data: { turbo: false } do |f| %>

            <div>
              <%= f.label :pronouns, class: "form-label" %>
              <%= f.text_field :pronouns, value: @user.pronouns, class: "form-control",
                  placeholder: "e.g., they/them, she/her, he/him" %>
              <div class="form-text">Displayed on your profile. Totally optional.</div>
            </div>

            <div data-controller="rich-editor" data-rich-editor-variables-value="[]">
              <%= f.label :bio, "About Me", class: "form-label" %>
              <div class="mb-2">
                <small class="text-muted">Tell others about yourself, your interests, and what you're working on.</small>
              </div>
              <%= f.text_area :bio, value: @user.bio, class: "form-control", rows: 6, data: { rich_editor_target: "editor" } %>
            </div>

            <div class="d-flex justify-content-between">
              <%= link_to "Back", profile_setup_path, class: "btn btn-outline-secondary btn-lg" %>
              <div class="d-flex gap-2">
                <%= link_to "Skip", profile_setup_links_path, class: "btn btn-outline-secondary btn-lg" %>
                <%= f.submit "Save & Continue", class: "btn btn-primary btn-lg" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>
