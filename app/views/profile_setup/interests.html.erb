<div class="py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="d-flex justify-content-center mb-4">
        <div class="d-flex align-items-center gap-2">
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">Basic Info</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">About You</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">Links</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-primary">4</span>
          <span class="fw-semibold small">Interests</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">5</span>
          <span class="text-muted small">Visibility</span>
        </div>
      </div>

      <!-- Member summary -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body py-2">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-check-circle-fill text-success fs-4"></i>
            <div>
              <span class="fw-semibold"><%= @user.display_name %></span>
              <span class="text-muted ms-2"><%= @user.email %></span>
              <% if @user.username.present? %>
                <span class="text-muted ms-2">@<%= @user.username %></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Interests -->
      <div class="card shadow-sm border-0">
        <div class="card-header bg-body-tertiary">
          <h4 class="card-title mb-0"><i class="bi bi-tags me-2"></i>Interests</h4>
        </div>
        <div class="card-body">
          <div class="alert alert-light border mb-4">
            <i class="bi bi-info-circle me-1"></i>
            This step is <strong>completely optional</strong>. Interests are visible to other members on your profile. Click an interest to select or deselect it — you can always change your interests later.
          </div>

          <% if @suggested.any? %>
            <p class="text-muted small mb-3">Click any interest to add it to your profile:</p>

            <div class="d-flex flex-wrap gap-2 mb-4">
              <% @suggested.each do |interest| %>
                <% selected = @user_interest_ids.include?(interest.id) %>
                <% if selected %>
                  <%= button_to profile_setup_remove_interest_path(interest),
                      method: :delete,
                      class: "btn btn-primary btn-sm rounded-pill",
                      form: { data: { turbo: false } } do %>
                    <i class="bi bi-check me-1"></i><%= interest.name %>
                    <i class="bi bi-x ms-1"></i>
                  <% end %>
                <% else %>
                  <%= button_to profile_setup_add_interest_path(interest),
                      method: :post,
                      class: "btn btn-outline-secondary btn-sm rounded-pill",
                      form: { data: { turbo: false } } do %>
                    <%= interest.name %>
                  <% end %>
                <% end %>
              <% end %>
            </div>

            <% interests_not_shown = @user_interests.reject { |i| @suggested.map(&:id).include?(i.id) } %>
            <% if interests_not_shown.any? %>
              <p class="text-muted small mb-2">Other interests you've selected:</p>
              <div class="d-flex flex-wrap gap-2 mb-4">
                <% interests_not_shown.each do |interest| %>
                  <%= button_to profile_setup_remove_interest_path(interest),
                      method: :delete,
                      class: "btn btn-primary btn-sm rounded-pill",
                      form: { data: { turbo: false } } do %>
                    <i class="bi bi-check me-1"></i><%= interest.name %>
                    <% if interest.needs_review? %>
                      <span class="badge text-bg-warning ms-1" title="Pending review">&#8987;</span>
                    <% end %>
                    <i class="bi bi-x ms-1"></i>
                  <% end %>
                <% end %>
              </div>
            <% end %>

          <% else %>
            <p class="text-muted fst-italic mb-4">No interests have been added yet. An admin can add interests under Settings.</p>
          <% end %>

          <!-- Suggest a new interest -->
          <div class="border-top pt-4 mt-2">
            <p class="text-muted small mb-2">Don't see your interest? Suggest one and it'll be added to your profile pending review:</p>
            <%= form_with url: profile_setup_suggest_interest_path, method: :post, local: true, class: "row g-2 align-items-end" do %>
              <div class="col-md-8">
                <input type="text" name="interest_name" class="form-control form-control-sm"
                       placeholder="e.g., Textile Electronics, Hydroponics…"
                       maxlength="80" autocomplete="off">
              </div>
              <div class="col-md-4">
                <button type="submit" class="btn btn-outline-primary btn-sm w-100">Suggest</button>
              </div>
            <% end %>
          </div>

          <div class="d-flex justify-content-between mt-4">
            <%= link_to "Back", profile_setup_links_path, class: "btn btn-outline-secondary btn-lg" %>
            <div class="d-flex gap-2">
              <%= link_to "Skip", profile_setup_visibility_path, class: "btn btn-outline-secondary btn-lg" %>
              <%= link_to "Continue", profile_setup_visibility_path, class: "btn btn-primary btn-lg" %>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
