<div class="py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="d-flex justify-content-center mb-4">
        <div class="d-flex align-items-center gap-2">
          <span class="badge rounded-pill text-bg-primary">1</span>
          <span class="fw-semibold small">Basic Info</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">2</span>
          <span class="text-muted small">About You</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">3</span>
          <span class="text-muted small">Visibility</span>
        </div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-header bg-body-tertiary">
          <h4 class="card-title mb-0"><i class="bi bi-person me-2"></i>Basic Info</h4>
        </div>
        <div class="card-body">
          <p class="text-muted mb-3">Let's start with the essentials.</p>

          <%= form_with url: profile_setup_save_basic_path, scope: :user, method: :post, class: "vstack gap-3", data: { turbo: false } do |f| %>

            <div>
              <%= f.label :full_name, "Full Name", class: "form-label" %>
              <%= f.text_field :full_name, value: @user.full_name, class: "form-control form-control-lg", id: "setup_full_name",
                  autocorrect: "off", autocapitalize: "off", spellcheck: "false", autofocus: true, required: true %>
            </div>

            <div>
              <%= f.label :email, "Email Address", class: "form-label" %>
              <%= f.email_field :email, value: @user.email, class: "form-control form-control-lg", id: "setup_email",
                  autocorrect: "off", autocapitalize: "off", spellcheck: "false", required: true %>
            </div>

            <div>
              <%= f.label :username, "Username", class: "form-label" %>
              <%= f.text_field :username, value: @user.username, class: "form-control form-control-lg", id: "setup_username",
                  autocorrect: "off", autocapitalize: "off", spellcheck: "false" %>
              <div class="form-text">Auto-generated from your name. You can change it.</div>
            </div>

            <div class="d-flex justify-content-end">
              <%= f.submit "Save & Continue", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>

<%= render 'shared/username_autogenerate', name_field_id: 'setup_full_name', username_field_id: 'setup_username' %>
