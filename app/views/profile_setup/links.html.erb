<div class="py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="d-flex justify-content-center mb-4">
        <div class="d-flex align-items-center gap-2">
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">Basic Info</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">About You</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-primary">3</span>
          <span class="fw-semibold small">Links</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">4</span>
          <span class="text-muted small">Interests</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">5</span>
          <span class="text-muted small">Visibility</span>
        </div>
      </div>

      <!-- Member summary -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body py-2">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-check-circle-fill text-success fs-4"></i>
            <div>
              <span class="fw-semibold"><%= @user.display_name %></span>
              <span class="text-muted ms-2"><%= @user.email %></span>
              <% if @user.username.present? %>
                <span class="text-muted ms-2">@<%= @user.username %></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Profile Links -->
      <div class="card shadow-sm border-0">
        <div class="card-header bg-body-tertiary">
          <h4 class="card-title mb-0"><i class="bi bi-link-45deg me-2"></i>Profile Links</h4>
        </div>
        <div class="card-body">
          <div class="alert alert-light border mb-4">
            <i class="bi bi-info-circle me-1"></i>
            This step is <strong>completely optional</strong> — you can skip it now and add links any time from your profile. Add links to your website, social media, GitHub, portfolio, or anything else you'd like to share.
          </div>

          <% if @user_links.any? %>
            <div class="list-group mb-4">
              <% @user_links.each do |link| %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                  <div class="d-flex align-items-center gap-3">
                    <i class="bi <%= link.icon_class %> fs-5"></i>
                    <div>
                      <strong><%= link.title %></strong>
                      <br>
                      <%= link_to truncate(link.url, length: 50), sanitize_url(link.url), target: '_blank', rel: 'noopener', class: 'text-muted small text-decoration-none' %>
                    </div>
                  </div>
                  <%= button_to profile_setup_remove_link_path(link_id: link.id), method: :delete,
                      class: "btn btn-sm btn-outline-danger",
                      data: { turbo_confirm: "Remove this link?" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>

          <h6 class="text-muted mb-3">Add a link</h6>
          <%= form_with model: UserLink.new, url: profile_setup_add_link_path, method: :post, local: true, class: "row g-2 mb-4" do |lf| %>
            <div class="col-md-4">
              <%= lf.text_field :title, class: "form-control", placeholder: "Title (e.g., GitHub, Website)" %>
            </div>
            <div class="col-md-6">
              <%= lf.url_field :url, class: "form-control", placeholder: "https://..." %>
            </div>
            <div class="col-md-2">
              <%= lf.submit "Add", class: "btn btn-primary w-100" %>
            </div>
          <% end %>

          <div class="d-flex justify-content-between">
            <%= link_to "Back", profile_setup_optional_path, class: "btn btn-outline-secondary btn-lg" %>
            <div class="d-flex gap-2">
              <%= link_to "Skip", profile_setup_interests_path, class: "btn btn-outline-secondary btn-lg" %>
              <%= link_to "Continue", profile_setup_interests_path, class: "btn btn-primary btn-lg" %>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
