<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Printers</h1>
  <div class="d-flex gap-2">
    <%= button_to "Check health now", check_health_now_printers_path, method: :post, class: "btn btn-outline-secondary" %>
    <%= link_to "Add Printer", new_printer_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @printers.any? %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Server</th>
            <th>CUPS Printer</th>
            <th>Receipts</th>
            <th>Health</th>
            <th>Description</th>
            <th>Default</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @printers.each do |printer| %>
            <tr>
              <td><%= printer.name %></td>
              <td>
                <% if printer.cups_printer_server.present? %>
                  <code><%= printer.cups_printer_server %></code>
                <% else %>
                  <span class="text-muted">Local</span>
                <% end %>
              </td>
              <td><code><%= printer.cups_printer_name %></code></td>
              <td class="text-muted text-nowrap"><%= printer.receipt_paper_summary %></td>
              <td>
                <% if printer.urgent_health_issue? %>
                  <span class="badge text-bg-danger-subtle"><%= printer.health_status_label %></span>
                <% elsif printer.health_status == 'healthy' %>
                  <span class="status-dot status-success me-1"></span>
                  <span class="text-muted"><%= printer.health_status_label %></span>
                <% else %>
                  <span class="status-dot status-muted me-1"></span>
                  <span class="text-muted"><%= printer.health_status_label %></span>
                <% end %>
                <% if printer.last_health_check_at.present? %>
                  <div class="text-muted small"><%= l(printer.last_health_check_at, format: :short) %></div>
                <% end %>
                <% if printer.last_health_error.present? && printer.urgent_health_issue? %>
                  <div class="text-danger small text-break"><%= truncate(printer.last_health_error, length: 120) %></div>
                <% end %>
              </td>
              <td class="text-muted"><%= printer.description %></td>
              <td>
                <% if printer.default_printer? %>
                  <span class="badge bg-success">Default</span>
                <% end %>
              </td>
              <td class="text-end">
                <%= link_to "Test Print", test_print_printer_path(printer),
                    data: { turbo_method: :post, turbo_confirm: "Send a test page to '#{printer.name}'?" },
                    class: "btn btn-sm btn-outline-info me-1" %>
                <%= link_to "Edit", edit_printer_path(printer), class: "btn btn-sm btn-outline-primary me-1" %>
                <%= link_to "Delete", printer_path(printer),
                    data: { turbo_method: :delete, turbo_confirm: "Remove printer '#{printer.name}'?" },
                    class: "btn btn-sm btn-outline-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-printer fs-1 d-block mb-2"></i>
    <p>No printers configured yet.</p>
    <%= link_to "Add the first printer", new_printer_path, class: "btn btn-primary" %>
  </div>
<% end %>

<% if @cups_printers.any? %>
  <div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-light">
      <h5 class="card-title mb-0">Available CUPS Printers</h5>
    </div>
    <div class="table-responsive">
      <table class="table table-sm mb-0">
        <thead>
          <tr>
            <th>CUPS Name</th>
            <th>Status</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <% @cups_printers.each do |cp| %>
            <tr>
              <td><code><%= cp[:name] %></code></td>
              <td><%= cp[:status] %></td>
              <td class="text-muted"><%= cp[:description] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% elsif @local_cups_printers_configured %>
  <div class="alert alert-warning mt-4">
    <i class="bi bi-exclamation-triangle me-1"></i>
    Local/default CUPS is not reachable or no local printers are detected. Server-backed printers are checked individually above.
  </div>
<% end %>

<div class="mt-3">
  <%= link_to "← Back to Settings", settings_path, class: "text-muted" %>
</div>
