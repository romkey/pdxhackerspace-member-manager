<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">PayPal Payments</h1>
    <p class="text-muted mb-0">
      <strong><%= @payment_count %></strong> records —
      Total <strong>$<%= number_to_currency(@total_amount || 0, unit: "") %> USD</strong>
    </p>
  </div>
  <div class="d-flex gap-2">
    <% if @show_unmatched %>
      <%= link_to "View Unique Subjects", unmatched_subjects_paypal_payments_path, class: "btn btn-outline-info" %>
    <% end %>
    <%= link_to "Export JSON", export_paypal_payments_path, class: "btn btn-outline-primary", data: { turbo: false } %>
    <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#importModal">Import JSON</button>
    <%= button_to "Sync now", sync_paypal_payments_path, method: :post, class: "btn btn-primary", data: { turbo: false } %>
  </div>
</div>

<% if @filter_active || @show_unmatched %>
  <div class="alert alert-info py-2 mb-3 d-flex justify-content-between align-items-center">
    <small>
      <i class="bi bi-funnel me-1"></i> Filtering:
      <% filter_parts = [] %>
      <% filter_parts << (@show_unmatched ? 'Unmatched Subjects' : nil) %>
      <% filter_parts << case params[:linked]
          when 'yes' then 'Linked'
          when 'no' then 'Unlinked'
          when 'dont_link' then "Don't Link"
          end %>
      <%= filter_parts.compact.join(' / ') %> payments
      (<%= @payment_count %> of <%= PaypalPayment.count %>)
    </small>
    <%= link_to "Clear all filters", paypal_payments_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>
<% end %>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <p class="small text-muted mb-3"><i class="bi bi-hand-index me-1"></i> Click any badge to filter the list</p>
    
    <% unmatched_param = @show_unmatched ? { show_unmatched: 'true' } : {} %>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to paypal_payments_path(unmatched_param), class: "badge text-bg-secondary text-decoration-none #{'border border-dark border-2' if !@filter_active && !@show_unmatched}" do %>
        All: <strong><%= @total_count %></strong>
      <% end %>
      <%= link_to paypal_payments_path(unmatched_param.merge(linked: 'yes')), class: "badge text-bg-success text-decoration-none #{'border border-dark border-2' if params[:linked] == 'yes'}" do %>
        Linked: <strong><%= @linked_count %></strong>
      <% end %>
      <%= link_to paypal_payments_path(unmatched_param.merge(linked: 'no')), class: "badge text-bg-warning text-decoration-none #{'border border-dark border-2' if params[:linked] == 'no'}" do %>
        Unlinked: <strong><%= @unlinked_count %></strong>
      <% end %>
      <%= link_to paypal_payments_path(unmatched_param.merge(linked: 'dont_link')), class: "badge text-bg-secondary text-decoration-none #{'border border-dark border-2' if params[:linked] == 'dont_link'}" do %>
        Don't Link: <strong><%= @dont_link_count %></strong>
      <% end %>

      <span class="border-start ms-2 ps-2"></span>

      <%= link_to paypal_payments_path, class: "badge text-bg-primary text-decoration-none #{'border border-dark border-2' if !@show_unmatched && !@filter_active}" do %>
        Matched: <strong><%= PaypalPayment.matching_plan.count %></strong>
      <% end %>
      <% if @unmatched_plan_count > 0 %>
        <%= link_to paypal_payments_path(show_unmatched: 'true'), class: "badge text-bg-danger text-decoration-none #{'border border-dark border-2' if @show_unmatched}" do %>
          Unmatched Subjects: <strong><%= @unmatched_plan_count %></strong>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="importModalLabel">Import PayPal Payments from JSON</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with url: import_paypal_payments_path, method: :post, multipart: true, local: true do |f| %>
        <div class="modal-body">
          <p class="text-muted">Select a JSON backup file to import. This will update existing payments and create new ones based on <code>paypal_id</code>.</p>
          <div class="mb-3">
            <%= f.file_field :file, accept: 'application/json', class: "form-control", required: true %>
          </div>
          <div class="alert alert-warning mb-0">
            <strong>Warning:</strong> This operation will modify the database. Existing payments with matching <code>paypal_id</code> will be updated.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit "Import", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%= form_with url: paypal_payments_path, method: :get, local: true,
              data: { controller: "live-filter", live_filter_server_value: true, turbo_frame: "paypal_payments_results" } do |form| %>
  <% request.query_parameters.except('q', 'page').each do |key, value| %>
    <%= hidden_field_tag key, value %>
  <% end %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <div class="d-flex gap-2">
        <%= form.text_field :q, value: params[:q], class: "form-control",
                            placeholder: "Search by transaction ID, payer name, email, or status…",
                            autocomplete: "off", autocorrect: "off", autocapitalize: "off", spellcheck: "false",
                            data: { live_filter_target: "input", action: "input->live-filter#filter" } %>
        <button type="button" class="btn btn-outline-secondary <%= 'd-none' unless params[:q].present? %>"
                data-live-filter-target="clearButton" data-action="click->live-filter#clear">Clear</button>
      </div>
    </div>
  </div>
<% end %>

<%= turbo_frame_tag "paypal_payments_results" do %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
      <thead class="bg-body-tertiary">
        <tr>
          <th scope="col">Transaction</th>
          <th scope="col">Status</th>
          <th scope="col">Amount</th>
          <th scope="col">Payer</th>
          <th scope="col">Linked Member</th>
          <th scope="col">Time</th>
        </tr>
      </thead>
      <tbody id="paypal_payments_table_body">
        <% @payments.each do |payment| %>
          <tr class="paypal-payment-row"
              data-live-filter-target="item"
              data-search-text="<%= [
                payment.paypal_id,
                payment.payer_name,
                payment.payer_email,
                payment.status.presence || "unknown",
                payment.amount_with_currency,
                payment.user&.display_name,
                payment.user_id.present? ? "linked" : "unlinked"
              ].compact.join(' ').downcase %>">
            <td class="fw-semibold"><%= link_to payment.paypal_id, paypal_payment_path(payment) %></td>
            <td><span class="badge text-bg-secondary"><%= payment.status.presence || "Unknown" %></span></td>
            <td><%= payment.amount_with_currency || "—" %></td>
            <td>
              <% if payment.payer_name.present? %>
                <div><strong><%= payment.payer_name %></strong></div>
              <% end %>
              <% if payment.payer_email.present? %>
                <div class="text-muted small"><%= mail_to payment.payer_email %></div>
              <% end %>
            </td>
            <td>
              <% if payment.user.present? %>
                <%= link_to payment.user.display_name, user_path(payment.user), class: "text-decoration-none" %>
              <% else %>
                <span class="text-muted fst-italic">Not linked</span>
              <% end %>
            </td>
            <td><%= payment.transaction_time ? l(payment.transaction_time, format: :long) : "n/a" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  </div>
  <% if @pagy.pages > 1 %>
    <div class="mt-3">
      <%== @pagy.series_nav(:bootstrap) %>
      <div class="text-center text-muted small mt-2">
        Showing <%= @pagy.from %>-<%= @pagy.to %> of <%= @pagy.count %>
      </div>
    </div>
  <% end %>
<% end %>

