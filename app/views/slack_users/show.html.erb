<% if @nav_params.present? %>
  <div class="alert alert-info py-2 mb-3 d-flex justify-content-between align-items-center">
    <small>
      <i class="bi bi-funnel me-1"></i> Browsing filtered list
      <% if @nav_params[:linked].present? %>
        — <%= case @nav_params[:linked]
              when 'yes' then 'Linked'
              when 'no' then 'Unlinked'
              when 'dont_link' then "Don't Link"
              end %>
      <% end %>
      <% if @nav_params[:is_admin].present? %>
        — <%= @nav_params[:is_admin] == 'yes' ? 'Admins' : 'Non-admins' %>
      <% end %>
      <% if @nav_params[:is_owner].present? %>
        — <%= @nav_params[:is_owner] == 'yes' ? 'Owners' : 'Non-owners' %>
      <% end %>
      <% if @nav_params[:is_bot].present? %>
        — <%= @nav_params[:is_bot] == 'yes' ? 'Bots' : 'Humans' %>
      <% end %>
      <% if @nav_params[:status].present? %>
        — <%= @nav_params[:status].humanize %>
      <% end %>
    </small>
    <%= link_to "Clear filter", slack_user_path(@slack_user), class: "btn btn-outline-secondary btn-sm" %>
  </div>
<% end %>

<div class="mb-4 d-flex justify-content-between align-items-center">
  <div class="d-flex gap-2 align-items-center">
    <% if @previous_slack_user %>
      <%= link_to slack_user_path(@previous_slack_user, @nav_params), class: "btn btn-outline-secondary", title: "Previous: #{@previous_slack_user.display_name}" do %>
        <i class="bi bi-chevron-left"></i> Previous
      <% end %>
    <% else %>
      <span class="btn btn-outline-secondary disabled" title="First user">
        <i class="bi bi-chevron-left"></i> Previous
      </span>
    <% end %>
    
    <% if @next_slack_user %>
      <%= link_to slack_user_path(@next_slack_user, @nav_params), class: "btn btn-outline-secondary", title: "Next: #{@next_slack_user.display_name}" do %>
        Next <i class="bi bi-chevron-right"></i>
      <% end %>
    <% else %>
      <span class="btn btn-outline-secondary disabled" title="Last user">
        Next <i class="bi bi-chevron-right"></i>
      </span>
    <% end %>
  </div>
  
  <div>
    <%= link_to "&larr; Back to Slack users".html_safe, slack_users_path(@nav_params), class: "text-decoration-none" %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <h1 class="h4 mb-3"><%= @slack_user.display_name %></h1>
    <div class="row">
      <div class="col-md-8">
        <dl class="row mb-0">
          <dt class="col-sm-3 text-secondary">Slack ID</dt>
          <dd class="col-sm-9"><%= @slack_user.slack_id %></dd>

          <dt class="col-sm-3 text-secondary">Team ID</dt>
          <dd class="col-sm-9"><%= @slack_user.team_id.presence || "—" %></dd>

          <dt class="col-sm-3 text-secondary">Email</dt>
          <dd class="col-sm-9">
            <% if @slack_user.email.present? %>
              <%= mail_to @slack_user.email %>
            <% else %>
              <span class="text-muted fst-italic">Not provided</span>
            <% end %>
          </dd>

          <dt class="col-sm-3 text-secondary">Real name</dt>
          <dd class="col-sm-9"><%= @slack_user.real_name.presence || "—" %></dd>

          <dt class="col-sm-3 text-secondary">Pronouns</dt>
          <dd class="col-sm-9"><%= @slack_user.pronouns.presence || "—" %></dd>

          <dt class="col-sm-3 text-secondary">Username</dt>
          <dd class="col-sm-9"><%= @slack_user.username.presence || "—" %></dd>

          <dt class="col-sm-3 text-secondary">Display name</dt>
          <dd class="col-sm-9"><%= @slack_user.display_name.presence || "—" %></dd>

          <dt class="col-sm-3 text-secondary">Title</dt>
          <dd class="col-sm-9"><%= @slack_user.title.presence || "—" %></dd>

          <dt class="col-sm-3 text-secondary">Phone</dt>
          <dd class="col-sm-9"><%= @slack_user.phone.presence || "—" %></dd>

          <dt class="col-sm-3 text-secondary">Timezone</dt>
          <dd class="col-sm-9"><%= @slack_user.tz.presence || "—" %></dd>

          <dt class="col-sm-3 text-secondary">Flags</dt>
          <dd class="col-sm-9">
            <% if @slack_user.is_admin? %><span class="badge text-bg-primary">Admin</span><% end %>
            <% if @slack_user.is_owner? %><span class="badge text-bg-warning">Owner</span><% end %>
            <% if @slack_user.is_bot? %><span class="badge text-bg-info">Bot</span><% end %>
            <% if @slack_user.deleted? %><span class="badge text-bg-danger">Deactivated</span><% else %><span class="badge text-bg-success">Active</span><% end %>
            <% if @slack_user.dont_link? %><span class="badge text-bg-secondary">Don't Link</span><% end %>
          </dd>

          <dt class="col-sm-3 text-secondary">Member</dt>
          <dd class="col-sm-9">
            <% if @slack_user.user.present? %>
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <%= link_to @slack_user.user.display_name, user_path(@slack_user.user), class: "text-decoration-none" %>
                <%= button_to "Disassociate", unlink_user_slack_user_path(@slack_user),
                    method: :post, class: "btn btn-sm btn-outline-secondary",
                    data: { turbo: false, turbo_confirm: "Disassociate this Slack user from #{@slack_user.user.display_name}?" } %>
              </div>
            <% elsif @slack_user.dont_link? %>
              <span class="badge text-bg-secondary me-2">Don't Link</span>
              <%= button_to "Clear Don't Link", toggle_dont_link_slack_user_path(@slack_user), 
                  method: :post, class: "btn btn-sm btn-outline-secondary", data: { turbo: false } %>
            <% else %>
              <div class="d-flex gap-2 align-items-center">
                <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#linkUserModal">
                  Link Member
                </button>
                <%= button_to "Don't Link", toggle_dont_link_slack_user_path(@slack_user), 
                    method: :post, class: "btn btn-sm btn-outline-secondary", data: { turbo: false },
                    title: "Mark this Slack user as not needing to be linked to a member" %>
                <%= button_to "Create Member", create_member_slack_user_path(@slack_user),
                    method: :post, class: "btn btn-sm btn-outline-success", data: { turbo: false,
                    turbo_confirm: "Create a new member from '#{@slack_user.display_name}'?" },
                    title: "Create a new member from this Slack user's information" %>
              </div>
            <% end %>
          </dd>

          <dt class="col-sm-3 text-secondary">Last synced</dt>
          <dd class="col-sm-9"><%= @slack_user.last_synced_at ? l(@slack_user.last_synced_at, format: :long) : "Never" %></dd>
        </dl>
      </div>
      <div class="col-md-4">
        <% image_url = @slack_user.raw_attributes.dig("profile", "image_192") %>
        <% if image_url.present? %>
          <div class="text-center">
            <img src="<%= image_url %>" alt="<%= @slack_user.display_name %>" class="img-fluid rounded" style="max-width: 192px; max-height: 192px;">
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <h2 class="h6 mb-3">Attributes</h2>
    <pre class="bg-body-secondary rounded p-3 mb-0"><code class="text-body"><%= JSON.pretty_generate(@slack_user.raw_attributes) %></code></pre>
  </div>
</div>

<% if @slack_user.user.nil? %>
  <%= render 'shared/link_user_modal',
    modal_title: 'Link Member to Slack User',
    form_url: link_user_slack_user_path(@slack_user),
    description: "Select a user to link to this Slack user. The user's Slack information will be updated.",
    users: @all_users %>
<% end %>

