<%= form_with model: ai_provider, local: true do |f| %>
  <% if ai_provider.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(ai_provider.errors.count, 'error') %> prevented this provider from being saved:</h6>
      <ul class="mb-0">
        <% ai_provider.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :url, "Provider URL", class: "form-label" %>
    <%= f.text_field :url, class: "form-control", required: true, placeholder: "https://api.example.com" %>
  </div>

  <div class="mb-3">
    <%= f.label :api_key, "API key", class: "form-label" %>
    <%= f.password_field :api_key,
                         value: nil,
                         class: "form-control",
                         autocomplete: "new-password",
                         placeholder: (ai_provider.api_key.present? ? "KEY****" : "Optional") %>
    <div class="form-text">Leave blank to keep the existing API key.</div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", ai_providers_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
