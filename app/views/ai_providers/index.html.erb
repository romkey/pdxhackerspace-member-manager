<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">AI Providers</h1>
  <%= link_to "Add Provider", new_ai_provider_path, class: "btn btn-primary" %>
</div>

<% if @ai_providers.any? %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>URL</th>
            <th>API key</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @ai_providers.each do |provider| %>
            <tr>
              <td><%= provider.name %></td>
              <td class="text-break"><%= provider.url %></td>
              <td><%= provider.api_key.present? ? 'Configured' : '—' %></td>
              <td class="text-end">
                <%= link_to "Edit", edit_ai_provider_path(provider), class: "btn btn-sm btn-outline-primary me-1" %>
                <%= link_to "Delete", ai_provider_path(provider), data: { turbo_method: :delete, turbo_confirm: "Delete provider '#{provider.name}'?" }, class: "btn btn-sm btn-outline-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-cpu fs-1 d-block mb-2"></i>
    <p>No AI providers configured yet.</p>
    <%= link_to "Add the first provider", new_ai_provider_path, class: "btn btn-primary" %>
  </div>
<% end %>

<div class="mt-3">
  <%= link_to "← Back to Settings", settings_path, class: "text-muted" %>
</div>
