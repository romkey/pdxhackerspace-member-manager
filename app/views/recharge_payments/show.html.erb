<div class="mb-4">
  <%= link_to "&larr; Back to Recharge payments".html_safe, recharge_payments_path, class: "text-decoration-none" %>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <h1 class="h4 mb-3">Charge <%= @payment.recharge_id %></h1>

    <dl class="row mb-0">
      <dt class="col-sm-3 text-secondary">Status</dt>
      <dd class="col-sm-9"><span class="badge text-bg-secondary"><%= @payment.status.presence || "Unknown" %></span></dd>

      <dt class="col-sm-3 text-secondary">Amount</dt>
      <dd class="col-sm-9"><%= @payment.amount_with_currency || "—" %></dd>

      <dt class="col-sm-3 text-secondary">Charge type</dt>
      <dd class="col-sm-9"><%= @payment.charge_type.presence || "—" %></dd>

      <dt class="col-sm-3 text-secondary">Processed</dt>
      <dd class="col-sm-9"><%= @payment.processed_at ? l(@payment.processed_at, format: :long) : "Unknown" %></dd>

      <dt class="col-sm-3 text-secondary">Customer</dt>
      <dd class="col-sm-9">
        <% if @payment.customer_name.present? %>
          <div><%= @payment.customer_name %></div>
        <% end %>
        <% if @payment.customer_email.present? %>
          <div><%= mail_to @payment.customer_email %></div>
        <% end %>
        <% if @payment.customer_name.blank? && @payment.customer_email.blank? %>
          <span class="text-muted fst-italic">Not provided</span>
        <% end %>
      </dd>

      <dt class="col-sm-3 text-secondary">Member</dt>
      <dd class="col-sm-9">
        <% if @user_by_customer_id.present? %>
          <div class="d-flex gap-2 align-items-center flex-wrap">
            <%= link_to @user_by_customer_id.display_name, user_path(@user_by_customer_id), class: "text-decoration-none" %>
            <%= button_to "Unlink", unlink_recharge_payment_path(@payment),
                method: :post, class: "btn btn-sm btn-outline-danger", data: { turbo: false,
                turbo_confirm: "Unlink this payment from #{@user_by_customer_id.display_name}?" },
                title: "Remove the link between this payment and the member" %>
          </div>
        <% elsif @payment.dont_link? %>
          <span class="badge text-bg-secondary me-2">Don't Link</span>
          <%= button_to "Clear Don't Link", toggle_dont_link_recharge_payment_path(@payment),
              method: :post, class: "btn btn-sm btn-outline-secondary", data: { turbo: false } %>
        <% elsif @customer_id.present? %>
          <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="text-muted fst-italic">No user found with matching customer ID</span>
            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#linkUserModal">
              Link Member
            </button>
            <%= button_to "Create Member", create_member_recharge_payment_path(@payment),
                method: :post, class: "btn btn-sm btn-outline-success", data: { turbo: false },
                title: "Create a new member from this payment's information" %>
            <%= button_to "Don't Link", toggle_dont_link_recharge_payment_path(@payment),
                method: :post, class: "btn btn-sm btn-outline-secondary", data: { turbo: false },
                title: "Mark this payment as not needing to be linked" %>
          </div>
        <% else %>
          <span class="text-muted fst-italic">No customer ID available</span>
        <% end %>
      </dd>

      <dt class="col-sm-3 text-secondary">Last synced</dt>
      <dd class="col-sm-9"><%= @payment.last_synced_at ? l(@payment.last_synced_at, format: :long) : "Unknown" %></dd>

      <dt class="col-sm-3 text-secondary">Raw data</dt>
      <dd class="col-sm-9">
        <pre class="bg-body-secondary rounded p-3 mb-0"><code class="text-body"><%= JSON.pretty_generate(@payment.raw_attributes) %></code></pre>
      </dd>
    </dl>
  </div>
</div>

<% if @user_by_customer_id.nil? && @customer_id.present? %>
  <%= render 'shared/link_user_modal',
    modal_title: 'Link Member to Recharge Payment',
    form_url: link_user_recharge_payment_path(@payment),
    description: safe_join([
      'Select a user to link to this Recharge payment. The user\'s ',
      tag.code('recharge_customer_id'),
      ' will be set to match this payment\'s customer ID (',
      tag.strong(h(@customer_id.to_s)),
      ').'
    ]),
    users: @all_users %>
<% end %>

