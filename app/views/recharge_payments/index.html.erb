<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h-page-title mb-0">Recharge payments</h1>
    <p class="text-13 text-secondary mb-0 mt-1">
      <span class="text-body"><%= @payment_count %></span> records ·
      Total <span class="text-body">$<%= number_to_currency(@total_amount || 0, unit: "") %> USD</span>
    </p>
  </div>
  <div class="d-flex gap-2">
    <%= button_to "Sync now", sync_recharge_payments_path, method: :post, class: "btn btn-primary btn-sm", data: { turbo: false } %>
    <div class="dropdown">
      <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="dropdown" aria-expanded="false">...</button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li><%= link_to "Export JSON", export_recharge_payments_path, class: "dropdown-item", data: { turbo: false } %></li>
        <li><button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#importModal">Import JSON</button></li>
        <li><%= link_to "Test", test_recharge_payments_path, class: "dropdown-item" %></li>
      </ul>
    </div>
  </div>
</div>

<% if @filter_active %>
  <div class="alert alert-info py-2 mb-3 d-flex justify-content-between align-items-center">
    <small>
      <i class="bi bi-funnel me-1"></i> Filtering:
      <%= case params[:linked]
          when 'yes' then 'Linked'
          when 'no' then 'Unlinked'
          when 'dont_link' then "Don't Link"
          end %> payments
      (<%= @payment_count %> of <%= @total_count %>)
    </small>
    <%= link_to "Clear filter", recharge_payments_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>
<% end %>

<div class="row g-2 mb-3">
  <div class="col-sm-6 col-lg-3">
      <%= link_to recharge_payments_path, class: "kpi-tile clickable d-block text-decoration-none h-100 #{'active' unless @filter_active}" do %>
        <div class="kpi-label">All</div>
        <div class="kpi-value"><%= @total_count %></div>
      <% end %>
  </div>
  <div class="col-sm-6 col-lg-3">
      <%= link_to recharge_payments_path(linked: 'yes'), class: "kpi-tile clickable d-block text-decoration-none h-100 #{'active' if params[:linked] == 'yes'}" do %>
        <div class="kpi-label">Linked</div>
        <div class="kpi-value"><%= @linked_count %></div>
      <% end %>
  </div>
  <div class="col-sm-6 col-lg-3">
      <%= link_to recharge_payments_path(linked: 'no'), class: "kpi-tile clickable warning d-block text-decoration-none h-100 #{'active' if params[:linked] == 'no'}" do %>
        <div class="kpi-label">Unlinked</div>
        <div class="kpi-value"><%= @unlinked_count %></div>
      <% end %>
  </div>
  <div class="col-sm-6 col-lg-3">
      <%= link_to recharge_payments_path(linked: 'dont_link'), class: "kpi-tile clickable d-block text-decoration-none h-100 #{'active' if params[:linked] == 'dont_link'}" do %>
        <div class="kpi-label">Don't link</div>
        <div class="kpi-value"><%= @dont_link_count %></div>
      <% end %>
  </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="importModalLabel">Import Recharge Payments from JSON</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with url: import_recharge_payments_path, method: :post, multipart: true, local: true do |f| %>
        <div class="modal-body">
          <p class="text-muted">Select a JSON backup file to import. This will update existing payments and create new ones based on <code>recharge_id</code>.</p>
          <div class="mb-3">
            <%= f.file_field :file, accept: 'application/json', class: "form-control", required: true %>
          </div>
          <div class="alert alert-warning mb-0">
            <strong>Warning:</strong> This operation will modify the database. Existing payments with matching <code>recharge_id</code> will be updated.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit "Import", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div data-controller="live-filter">
<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="d-flex gap-2">
      <input type="text" class="form-control form-control-sm" placeholder="Search by charge ID, customer name, email, or status…" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
             data-live-filter-target="input" data-action="input->live-filter#filter">
      <button type="button" class="btn btn-outline-secondary d-none"
              data-live-filter-target="clearButton" data-action="click->live-filter#clear">Clear</button>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="table-responsive">
    <table class="table table-compact mb-0 align-middle">
      <thead>
        <tr>
          <th scope="col">Charge</th>
          <th scope="col">Status</th>
          <th scope="col">Amount</th>
          <th scope="col">Customer</th>
          <th scope="col">Linked Member</th>
          <th scope="col">Processed</th>
        </tr>
      </thead>
      <tbody id="recharge_payments_table_body">
        <% @payments.each do |payment| %>
          <% unlinked = payment.user.blank? && !payment.dont_link? %>
          <tr class="recharge-payment-row" style="<%= 'background: rgba(255, 193, 7, 0.04);' if unlinked %>"
              data-live-filter-target="item"
              data-search-text="<%= [
                payment.recharge_id,
                payment.customer_name,
                payment.customer_email,
                payment.status.presence || "unknown",
                payment.amount_with_currency,
                payment.user&.display_name,
                payment.user_id.present? ? "linked" : "unlinked"
              ].compact.join(' ').downcase %>">
            <td class="font-monospace text-12"><%= link_to payment.recharge_id, recharge_payment_path(payment), class: "text-info text-decoration-none" %></td>
            <td>
              <% if payment.status.to_s.casecmp("success").zero? %>
                <span class="status-dot status-success" title="Success"></span>
              <% else %>
                <span class="status-dot status-danger me-1" title="<%= payment.status.presence || 'Unknown' %>"></span>
                <span class="badge text-bg-danger-subtle small"><%= payment.status.presence || "Unknown" %></span>
              <% end %>
            </td>
            <td class="num">
              <% if payment.amount.present? %>
                <% amount = payment.amount.to_d %>
                <% whole = amount.truncate %>
                <% cents = ((amount - whole) * 100).round %>
                <span class="money <%= 'fw-medium' unless amount == 40.to_d %>"><span class="currency">$</span><%= whole %><span class="cents">.<%= format('%02d', cents) %></span></span>
              <% else %>
                <span class="text-secondary">—</span>
              <% end %>
            </td>
            <td>
              <% if payment.customer_name.present? %>
                <div><%= payment.customer_name %></div>
              <% end %>
              <% if payment.customer_email.present? %>
                <div class="text-muted small"><%= payment.customer_email %></div>
              <% end %>
            </td>
            <td>
              <% if payment.user.present? %>
                <%= link_to payment.user.display_name, user_path(payment.user), class: "text-decoration-none" %>
              <% elsif unlinked %>
                <%= link_to "Link member...", recharge_payment_path(payment), class: "btn btn-sm btn-warning" %>
              <% else %>
                <span class="text-muted fst-italic">Not linked</span>
              <% end %>
            </td>
            <td>
              <% if payment.processed_at %>
                <span class="text-secondary text-12" title="<%= l(payment.processed_at, format: :long) %>"><%= time_ago_in_words(payment.processed_at) %> ago</span>
              <% else %>
                <span class="text-secondary text-12">n/a</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
</div><%# /data-controller="live-filter" %>
<% if @pagy.pages > 1 %>
  <div class="mt-3 d-flex justify-content-between align-items-center">
    <div class="text-secondary text-12">Showing <%= @pagy.from %>-<%= @pagy.to %> of <%= @pagy.count %></div>
    <%== @pagy.series_nav(:bootstrap) %>
  </div>
<% end %>

