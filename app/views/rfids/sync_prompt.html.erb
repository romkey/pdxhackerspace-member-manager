<div class="mb-4">
  <%= link_to "&larr; Back to #{@user.display_name}".html_safe, user_path(@user), class: "text-decoration-none" %>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-4 p-md-5">
    <h1 class="h4 mb-3">Sync access controllers</h1>

    <div class="alert alert-warning mb-4">
      <strong>The key fob is saved but not active on doors yet.</strong>
      Until each access controller has synced, this fob will not grant entry. Run a sync now, or schedule one from
      <%= link_to 'Access Controllers', access_controllers_path, class: 'alert-link' %> when you are ready.
    </div>

    <p class="text-muted mb-4">
      Code added: <code class="user-select-all"><%= @rfid.rfid %></code>
      for <strong><%= @user.display_name %></strong>.
    </p>

    <% if @enabled_controllers_count.positive? %>
      <p class="mb-3">
        <%= pluralize(@enabled_controllers_count, 'enabled access controller') %> will be queued to sync.
        Sync runs in the background; check the Access Controllers page for status.
      </p>
      <div class="d-flex flex-wrap gap-2 align-items-center">
        <%= button_to sync_all_access_controllers_path,
                      method: :post,
                      params: { redirect_user_id: @user.id },
                      class: 'btn btn-primary',
                      data: { turbo: false } do %>
          <i class="bi bi-arrow-repeat me-1"></i> Sync all access controllers now
        <% end %>
        <%= link_to "Skip — I'll sync later", user_path(@user), class: "btn btn-outline-secondary" %>
        <%= link_to 'Return to onboarding (building access)', onboard_access_path(@user), class: 'btn btn-link' %>
      </div>
    <% else %>
      <p class="text-muted mb-3">
        There are no enabled access controllers. Add or enable one under Settings before fobs can work on doors.
      </p>
      <%= link_to 'Open Access Controllers', access_controllers_path, class: 'btn btn-primary' %>
      <%= link_to 'Back to member', user_path(@user), class: 'btn btn-outline-secondary ms-2' %>
      <%= link_to 'Onboarding: building access', onboard_access_path(@user), class: 'btn btn-link' %>
    <% end %>
  </div>
</div>
