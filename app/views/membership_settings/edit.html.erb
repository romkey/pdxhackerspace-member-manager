<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Edit Membership Settings</h1>
    <p class="text-muted mb-0">Configure system-wide membership grace periods.</p>
  </div>
  <div>
    <%= link_to "Cancel", membership_settings_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-body">
        <%= form_with model: @membership_setting, url: membership_settings_path, method: :patch, local: true do |f| %>
          <% if @membership_setting.errors.any? %>
            <div class="alert alert-danger">
              <h5 class="alert-heading">Please fix the following errors:</h5>
              <ul class="mb-0">
                <% @membership_setting.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :payment_grace_period_days, "Payment Grace Period (days)", class: "form-label" %>
            <%= f.number_field :payment_grace_period_days, class: "form-control", min: 0, style: "max-width: 150px;" %>
            <div class="form-text">Days after payment due date before membership is marked as lapsed.</div>
          </div>

          <div class="mb-4">
            <%= f.label :reactivation_grace_period_months, "Reactivation Grace Period (months)", class: "form-label" %>
            <%= f.number_field :reactivation_grace_period_months, class: "form-control", min: 0, style: "max-width: 150px;" %>
            <div class="form-text">Months a lapsed member can reactivate without needing to reapply.</div>
          </div>

          <div class="mb-4">
            <%= f.label :invitation_expiry_hours, "Invitation Expiry (hours)", class: "form-label" %>
            <div class="d-flex align-items-center gap-2">
              <%= f.number_field :invitation_expiry_hours, class: "form-control", min: 1, style: "max-width: 150px;", id: "invitation_expiry_hours" %>
              <div class="d-flex flex-wrap gap-1">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('invitation_expiry_hours').value=24">1 day</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('invitation_expiry_hours').value=48">2 days</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('invitation_expiry_hours').value=72">3 days</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('invitation_expiry_hours').value=168">1 week</button>
              </div>
            </div>
            <div class="form-text">How long invitation links remain valid. Use the shortcuts or enter a custom number of hours.</div>
          </div>

          <div class="mb-4">
            <%= f.label :login_link_expiry_hours, "Member Login Link Expiry (hours)", class: "form-label" %>
            <div class="d-flex align-items-center gap-2">
              <%= f.number_field :login_link_expiry_hours, class: "form-control", min: 1, style: "max-width: 150px;", id: "login_link_expiry_hours" %>
              <div class="d-flex flex-wrap gap-1">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('login_link_expiry_hours').value=1">1 hour</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('login_link_expiry_hours').value=3">3 hours</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('login_link_expiry_hours').value=24">1 day</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('login_link_expiry_hours').value=168">1 week</button>
              </div>
            </div>
            <div class="form-text">How long member login links remain valid. Links can only be used once.</div>
          </div>

          <div class="mb-4">
            <%= f.label :admin_login_link_expiry_minutes, "Admin Login Link Expiry (minutes)", class: "form-label" %>
            <div class="d-flex align-items-center gap-2">
              <%= f.number_field :admin_login_link_expiry_minutes, class: "form-control", min: 1, style: "max-width: 150px;", id: "admin_login_link_expiry_minutes" %>
              <div class="d-flex flex-wrap gap-1">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('admin_login_link_expiry_minutes').value=5">5 min</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('admin_login_link_expiry_minutes').value=15">15 min</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('admin_login_link_expiry_minutes').value=30">30 min</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('admin_login_link_expiry_minutes').value=60">1 hour</button>
              </div>
            </div>
            <div class="form-text">How long admin login links remain valid. Shorter for security. Links can only be used once.</div>
          </div>

          <div class="d-flex gap-2">
            <%= f.submit "Save Settings", class: "btn btn-primary" %>
            <%= link_to "Cancel", membership_settings_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h5 class="card-title mb-0">About Grace Periods</h5>
      </div>
      <div class="card-body">
        <p class="small text-muted mb-2">
          <strong>Payment Grace Period:</strong> When a member's payment is overdue, they have this many days 
          before their membership status changes to lapsed.
        </p>
        <p class="small text-muted mb-2">
          <strong>Reactivation Grace Period:</strong> After a membership lapses, members have this many months 
          to resume their membership without going through the full application process again.
        </p>
        <p class="small text-muted mb-2">
          <strong>Invitation Expiry:</strong> When an admin sends an invitation, the link is valid for this 
          many hours. After expiry, the recipient must be invited again.
        </p>
        <p class="small text-muted mb-2">
          <strong>Member Login Link Expiry:</strong> Members can request a login link from the sign-in page.
          Links can only be used once and expire after this many hours.
        </p>
        <p class="small text-muted mb-0">
          <strong>Admin Login Link Expiry:</strong> Admin login links expire faster for security.
          Links can only be used once and expire after this many minutes.
        </p>
      </div>
    </div>
  </div>
</div>
