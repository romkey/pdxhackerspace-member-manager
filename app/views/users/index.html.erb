<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Members</h1>
    <p class="text-muted mb-0">
      <strong><%= @user_count %></strong> members<%= " (including #{@legacy_count} legacy)" if @include_legacy && @legacy_count.positive? %> —
      <%= link_to stacking_filter_path(:active, 'true'), class: "text-decoration-none" do %>
        <strong><%= @active_count %></strong> active
      <% end %>,
      <%= link_to stacking_filter_path(:active, 'false'), class: "text-decoration-none" do %>
        <strong><%= @inactive_count %></strong> inactive
      <% end %>
      <% if @filter_active || @include_legacy %>
        <span class="text-muted fst-italic">(filtered counts)</span>
      <% end %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <% if MemberSource.enabled?('authentik') %>
      <%= button_to "Sync from Authentik", sync_users_path, method: :post, class: "btn btn-primary", data: { turbo: false } %>
    <% else %>
      <button class="btn btn-secondary" disabled title="Authentik source is disabled">Sync from Authentik</button>
    <% end %>
    <% if MemberSource.enabled?('member_manager') %>
      <%= button_to "Sync to Authentik", sync_all_to_authentik_users_path, method: :post, class: "btn btn-outline-primary", data: { turbo: false, turbo_confirm: "This will sync all members, groups, and the active members group to Authentik. Continue?" } %>
    <% else %>
      <button class="btn btn-secondary" disabled title="Member Manager source is disabled">Sync to Authentik</button>
    <% end %>
  </div>
</div>

<% if @filter_active || @include_legacy %>
  <%
    filter_labels = []
    filter_labels << "Including legacy" if @include_legacy
    filter_labels << "Membership: #{params[:membership_status].humanize}" if params[:membership_status].present?
    filter_labels << "Payment: #{params[:payment_type].humanize}" if params[:payment_type].present?
    filter_labels << "Dues: #{params[:dues_status].humanize}" if params[:dues_status].present?
    if params[:membership_plan_id].present?
      plan_name = params[:membership_plan_id] == 'none' ? 'No Plan' : MembershipPlan.find_by(id: params[:membership_plan_id])&.name || 'Unknown'
      filter_labels << "Plan: #{plan_name}"
    end
    filter_labels << (params[:active] == 'true' ? 'Active only' : 'Inactive only') if params[:active].present?
    filter_labels << 'Emergency active override' if params[:emergency_active_override] == '1'
    filter_labels << "Missing: #{params[:missing] == 'rfid' ? 'No RFID' : 'No Email'}" if params[:missing].present?
    if params[:account_type].present?
      filter_labels << (params[:account_type] == 'service' ? 'Service Accounts' : 'Members Only')
    end
  %>
  <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
    <div>
      <i class="bi bi-funnel me-2"></i>
      Showing <strong><%= @filtered_count || @users.count %></strong> of <%= @user_count %> members
      <% if filter_labels.any? %>
        — <%= filter_labels.map { |l| "<strong>#{ERB::Util.html_escape(l)}</strong>" }.join(" + ").html_safe %>
      <% end %>
    </div>
    <%= link_to "Clear all filters", users_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>
<% end %>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <p class="small text-muted mb-0"><i class="bi bi-hand-index me-1"></i> Click badges to stack filters — click again to remove</p>
      <% if @legacy_count.positive? %>
        <div class="form-check mb-0">
          <input class="form-check-input" type="checkbox" id="include_legacy_checkbox"
                 <%= 'checked' if @include_legacy %>
                 onchange="window.location.href='<%= stacking_filter_path(:include_legacy, @include_legacy ? nil : '1') %>'">
          <label class="form-check-label small" for="include_legacy_checkbox">
            <i class="bi bi-archive me-1"></i>Include legacy (<%= @legacy_count %>)
          </label>
        </div>
      <% end %>
    </div>
    
    <h2 class="h6 mb-3">Membership Status</h2>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <%= link_to stacking_filter_path(:membership_status, 'unknown'), class: "badge text-bg-secondary text-decoration-none #{'border border-dark border-2' if params[:membership_status] == 'unknown'}" do %>
        Unknown: <strong><%= @membership_status_unknown %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:membership_status, 'sponsored'), class: "badge text-bg-primary text-decoration-none #{'border border-dark border-2' if params[:membership_status] == 'sponsored'}" do %>
        Sponsored: <strong><%= @membership_status_sponsored %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:membership_status, 'paying'), class: "badge text-bg-success text-decoration-none #{'border border-dark border-2' if params[:membership_status] == 'paying'}" do %>
        Paying: <strong><%= @membership_status_paying %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:membership_status, 'applicant'), class: "badge text-bg-secondary text-decoration-none #{'border border-dark border-2' if params[:membership_status] == 'applicant'}" do %>
        Applicant: <strong><%= @membership_status_applicant %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:membership_status, 'banned'), class: "badge text-bg-danger text-decoration-none #{'border border-dark border-2' if params[:membership_status] == 'banned'}" do %>
        Banned: <strong><%= @membership_status_banned %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:membership_status, 'deceased'), class: "badge text-bg-dark text-decoration-none #{'border border-dark border-2' if params[:membership_status] == 'deceased'}" do %>
        Deceased: <strong><%= @membership_status_deceased %></strong>
      <% end %>
    </div>
    
    <h2 class="h6 mb-3">Payment Type</h2>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <%= link_to stacking_filter_path(:payment_type, 'unknown'), class: "badge text-bg-secondary text-decoration-none #{'border border-dark border-2' if params[:payment_type] == 'unknown'}" do %>
        Unknown: <strong><%= @payment_type_unknown %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:payment_type, 'sponsored'), class: "badge text-bg-primary text-decoration-none #{'border border-dark border-2' if params[:payment_type] == 'sponsored'}" do %>
        Sponsored: <strong><%= @payment_type_sponsored %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:payment_type, 'paypal'), class: "badge text-bg-info text-decoration-none #{'border border-dark border-2' if params[:payment_type] == 'paypal'}" do %>
        PayPal: <strong><%= @payment_type_paypal %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:payment_type, 'recharge'), class: "badge text-bg-info text-decoration-none #{'border border-dark border-2' if params[:payment_type] == 'recharge'}" do %>
        Recharge: <strong><%= @payment_type_recharge %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:payment_type, 'cash'), class: "badge text-bg-info text-decoration-none #{'border border-dark border-2' if params[:payment_type] == 'cash'}" do %>
        Cash: <strong><%= @payment_type_cash %></strong>
      <% end %>
    </div>
    
    <h2 class="h6 mb-3">Payment Plan</h2>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <% @plan_counts.each do |plan, count| %>
        <% next if count.zero? %>
        <%= link_to stacking_filter_path(:membership_plan_id, plan.id.to_s), class: "badge text-bg-info text-decoration-none #{'border border-dark border-2' if params[:membership_plan_id] == plan.id.to_s}" do %>
          <%= plan.name %>: <strong><%= count %></strong>
        <% end %>
      <% end %>
      <% if @no_plan_count.positive? %>
        <%= link_to stacking_filter_path(:membership_plan_id, 'none'), class: "badge text-bg-secondary text-decoration-none #{'border border-dark border-2' if params[:membership_plan_id] == 'none'}" do %>
          No Plan: <strong><%= @no_plan_count %></strong>
        <% end %>
      <% end %>
    </div>

    <h2 class="h6 mb-3">Dues Status</h2>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <%= link_to stacking_filter_path(:dues_status, 'current'), class: "badge text-bg-success text-decoration-none #{'border border-dark border-2' if params[:dues_status] == 'current'}" do %>
        Current: <strong><%= @dues_status_current %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:dues_status, 'lapsed'), class: "badge text-bg-warning text-decoration-none #{'border border-dark border-2' if params[:dues_status] == 'lapsed'}" do %>
        Lapsed: <strong><%= @dues_status_lapsed %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:dues_status, 'inactive'), class: "badge text-bg-secondary text-decoration-none #{'border border-dark border-2' if params[:dues_status] == 'inactive'}" do %>
        Inactive: <strong><%= @dues_status_inactive %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:dues_status, 'unknown'), class: "badge text-bg-secondary text-decoration-none #{'border border-dark border-2' if params[:dues_status] == 'unknown'}" do %>
        Unknown: <strong><%= @dues_status_unknown %></strong>
      <% end %>
    </div>
    
    <h2 class="h6 mb-3">Account Type</h2>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <%= link_to stacking_filter_path(:account_type, 'member'), class: "badge text-bg-primary text-decoration-none #{'border border-dark border-2' if params[:account_type] == 'member'}" do %>
        Members: <strong><%= @member_account_count %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:account_type, 'service'), class: "badge text-bg-info text-decoration-none #{'border border-dark border-2' if params[:account_type] == 'service'}" do %>
        <i class="bi bi-gear-fill me-1"></i>Service Accounts: <strong><%= @service_account_count %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:emergency_active_override, '1'), class: "badge text-bg-warning text-decoration-none #{'border border-dark border-2' if params[:emergency_active_override] == '1'}" do %>
        <i class="bi bi-lightning-charge me-1"></i>Emergency override: <strong><%= @emergency_active_override_count %></strong>
      <% end %>
    </div>

    <h2 class="h6 mb-3">Missing Data</h2>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to stacking_filter_path(:missing, 'rfid'), class: "badge text-bg-warning text-decoration-none #{'border border-dark border-2' if params[:missing] == 'rfid'}" do %>
        No RFID: <strong><%= @no_rfid_count %></strong>
      <% end %>
      <%= link_to stacking_filter_path(:missing, 'email'), class: "badge text-bg-warning text-decoration-none #{'border border-dark border-2' if params[:missing] == 'email'}" do %>
        No Email: <strong><%= @no_email_count %></strong>
      <% end %>
    </div>
  </div>
</div>

<div data-controller="live-filter">
<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="d-flex gap-2">
      <input type="text" class="form-control" placeholder="Search by name, email, or Authentik ID…" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" value="<%= params[:q] %>"
             data-live-filter-target="input" data-action="input->live-filter#filter">
      <button type="button" class="btn btn-outline-secondary <%= 'd-none' unless params[:q].present? %>"
              data-live-filter-target="clearButton" data-action="click->live-filter#clear">Clear</button>
    </div>
  </div>
</div>

<% if @recent_members.any? && !@filter_active && !@include_legacy %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-body-tertiary">
      <h6 class="mb-0"><i class="bi bi-person-plus me-1"></i>New Members This Week (<%= @recent_members.size %>)</h6>
    </div>
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead class="bg-body-tertiary">
          <tr>
            <th scope="col" style="width: 48px;"></th>
            <th scope="col">Username</th>
            <th scope="col">Name</th>
            <th scope="col">Email</th>
            <th scope="col">Status</th>
            <th scope="col">Joined</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_members.each do |user| %>
            <tr>
              <td>
                <%= link_to user_path(user, @list_params) do %>
                  <%= render 'shared/user_avatar', user: user %>
                <% end %>
              </td>
              <td class="small text-monospace text-secondary fw-semibold"><%= link_to user.username, user_path(user, @list_params), class: "text-decoration-none text-secondary" %></td>
              <td class="fw-semibold"><%= link_to user.display_name, user_path(user, @list_params), class: "text-decoration-none" %></td>
              <td>
                <% if user.email.present? %>
                  <%= mail_to user.email %>
                <% else %>
                  <span class="text-muted fst-italic">Not provided</span>
                <% end %>
              </td>
              <td>
                <span class="badge text-bg-<%= membership_status_badge_class(user.membership_status) %>"><%= user.membership_status&.humanize %></span>
              </td>
              <td class="text-muted small"><%= time_ago_in_words(user.created_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<div class="card shadow-sm border-0">
  <div class="table-responsive">
    <table class="table mb-0 align-middle">
      <thead class="bg-body-tertiary">
        <tr>
          <th scope="col" style="width: 48px;"></th>
          <th scope="col"><%= sortable_column('username', 'Username', @sort_column, @sort_direction) %></th>
          <th scope="col"><%= sortable_column('full_name', 'Name', @sort_column, @sort_direction) %></th>
          <th scope="col"><%= sortable_column('email', 'Email', @sort_column, @sort_direction) %></th>
          <th scope="col"><%= sortable_column('membership_status', 'Status', @sort_column, @sort_direction) %></th>
          <th scope="col"><%= sortable_column('payment_type', 'Payment Type', @sort_column, @sort_direction) %></th>
          <th scope="col"><%= sortable_column('last_synced_at', 'Last synced', @sort_column, @sort_direction) %></th>
        </tr>
      </thead>
      <tbody id="users_table_body">
        <% @users.each do |user| %>
          <tr class="user-row"
              data-live-filter-target="item"
              data-search-text="<%= [user.username, user.display_name, user.email, user.authentik_id].compact.join(' ').downcase %>">
            <td>
              <%= link_to user_path(user, @list_params) do %>
                <%= render 'shared/user_avatar', user: user %>
              <% end %>
            </td>
            <td class="small text-monospace text-secondary fw-semibold"><%= link_to user.username, user_path(user, @list_params), class: "text-decoration-none text-secondary" %></td>
            <td class="fw-semibold">
              <%= link_to user.display_name, user_path(user, @list_params), class: "text-decoration-none" %>
              <% if user.is_sponsored? %>
                <span class="badge text-bg-primary ms-1"><i class="bi bi-heart-fill me-1"></i>Sponsored</span>
              <% end %>
              <% if user.service_account? %>
                <span class="badge text-bg-info ms-1"><i class="bi bi-gear-fill me-1"></i>Service</span>
              <% end %>
              <% if user.legacy? %>
                <span class="badge text-bg-secondary ms-1"><i class="bi bi-archive me-1"></i>Legacy</span>
              <% end %>
            </td>
            <td>
              <% if user.email.present? %>
                <%= mail_to user.email %>
              <% else %>
                <span class="text-muted fst-italic">Not provided</span>
              <% end %>
            </td>
            <td>
              <% if user.service_account? %>
                <span class="text-muted">–</span>
              <% else %>
                <span class="badge text-bg-<%= membership_status_badge_class(user.membership_status) %>">
                  <%= user.membership_status.humanize %>
                </span>
                <% if user.active? %>
                  <span class="badge text-bg-success ms-1">Active</span>
                <% end %>
              <% end %>
            </td>
            <td>
              <% if user.service_account? %>
                <span class="text-muted">–</span>
              <% else %>
                <span class="badge text-bg-info"><%= user.payment_type.humanize %></span>
              <% end %>
            </td>
            <td><%= user.last_synced_at ? l(user.last_synced_at, format: :long) : "n/a" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
</div><%# /data-controller="live-filter" %>

