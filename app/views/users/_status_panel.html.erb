<%# Status Panel - shows membership status information %>
<%# Params: user, show_dues (boolean) %>
<div class="card border-0 bg-body-tertiary">
  <div class="card-body text-center">
    <%# Service Account Badge %>
    <% if user.service_account? %>
      <div class="mb-3">
        <span class="badge text-bg-info fs-6"><i class="bi bi-gear-fill me-1"></i>Service Account</span>
      </div>
    <% end %>

    <%# Sponsored Badge - visible to everyone %>
    <% if user.is_sponsored? %>
      <div class="mb-3">
        <span class="badge text-bg-primary fs-6"><i class="bi bi-heart-fill me-1"></i>Sponsored</span>
      </div>
    <% end %>

    <%# Legacy Badge - admin only %>
    <% if user.legacy? && current_user_admin? %>
      <div class="mb-3">
        <span class="badge text-bg-secondary fs-6"><i class="bi bi-archive me-1"></i>Legacy Member</span>
      </div>
    <% end %>

    <%# Active/Inactive Status %>
    <div class="mb-3">
      <% if user.active? %>
        <div class="display-6 text-success mb-2">
          <i class="bi bi-check-circle-fill"></i>
        </div>
        <h4 class="text-success mb-0">Active</h4>
      <% else %>
        <div class="display-6 text-secondary mb-2">
          <i class="bi bi-x-circle-fill"></i>
        </div>
        <h4 class="text-secondary mb-0">Inactive</h4>
      <% end %>
    </div>

    <% if user.membership_start_date.present? || user.membership_ended_date.present? %>
      <div class="mb-3 text-muted">
        <i class="bi bi-calendar-check me-1"></i>
        <% if user.membership_start_date.present? && user.membership_ended_date.present? %>
          <% if user.membership_start_date.strftime('%B %Y') == user.membership_ended_date.strftime('%B %Y') %>
            Member since <%= user.membership_start_date.strftime('%B %Y') %>
          <% else %>
            Member <%= user.membership_start_date.strftime('%B %Y') %> - <%= user.membership_ended_date.strftime('%B %Y') %>
          <% end %>
        <% elsif user.membership_start_date.present? %>
          Member since <%= user.membership_start_date.strftime('%B %Y') %>
        <% elsif user.membership_ended_date.present? %>
          Membership ended <%= user.membership_ended_date.strftime('%B %Y') %>
        <% end %>
      </div>
    <% end %>

    <hr>

    <%# Membership Details - hidden for service accounts %>
    <div class="text-start">
      <% unless user.service_account? %>
        <% sponsored_no_payment = user.is_sponsored? && user.payment_type.in?(%w[unknown sponsored inactive]) && user.membership_plan.blank? && user.supplementary_plans.empty? %>

        <% unless sponsored_no_payment %>
          <div class="mb-3">
            <small class="text-muted d-block">Payment Type</small>
            <span class="badge text-bg-info fs-6"><%= user.payment_type.humanize %></span>
          </div>
        <% end %>

        <% if user.membership_plan.present? || user.supplementary_plans.any? %>
          <div class="mb-3">
            <small class="text-muted d-block">Membership Plans</small>
            <% if user.membership_plan.present? %>
              <div class="mb-1">
                <strong><%= link_to user.membership_plan.name, membership_plan_path(user.membership_plan), class: "text-decoration-none" %></strong>
                <span class="badge text-bg-primary ms-1">Primary</span>
                <br>
                <span class="text-muted">$<%= format('%.2f', user.membership_plan.cost) %>/<%= user.membership_plan.billing_frequency %></span>
              </div>
            <% end %>
            <% user.supplementary_plans.order(:name).each do |plan| %>
              <div class="mb-1">
                <strong><%= link_to plan.name, membership_plan_path(plan), class: "text-decoration-none" %></strong>
                <span class="badge text-bg-info ms-1">Supplementary</span>
                <br>
                <span class="text-muted">$<%= format('%.2f', plan.cost) %>/<%= plan.billing_frequency %></span>
              </div>
            <% end %>
          </div>
        <% end %>

        <% next_payment = user.next_payment_date %>
        <% if next_payment.present? && user.membership_status.in?(%w[paying cancelled unknown applicant]) %>
          <div class="mb-3">
            <small class="text-muted d-block">Next Payment</small>
            <% if next_payment > Date.current %>
              <span class="text-success">
                <i class="bi bi-calendar-event me-1"></i>
                Renews on <%= next_payment.strftime('%B %d, %Y') %>
              </span>
            <% else %>
              <span class="text-warning">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Was due <%= next_payment.strftime('%B %d, %Y') %>
              </span>
            <% end %>
          </div>
        <% elsif user.dues_due_at.present? && user.membership_status.in?(%w[guest sponsored]) %>
          <div class="mb-3">
            <small class="text-muted d-block">Limited <%= user.membership_status.humanize %> Access</small>
            <% if user.dues_due_at > Time.current %>
              <span class="text-success">
                <i class="bi bi-calendar-event me-1"></i>
                Good through <%= user.dues_due_at.strftime('%B %d, %Y') %>
                <span class="d-block small text-muted mt-1">
                  (<%= distance_of_time_in_words_to_now(user.dues_due_at) %> from now)
                </span>
              </span>
            <% else %>
              <span class="text-warning">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Ended <%= user.dues_due_at.strftime('%B %d, %Y') %>
              </span>
            <% end %>
          </div>
        <% end %>

        <% if local_assigns[:show_dues] %>
          <div class="mb-3">
            <small class="text-muted d-block">Dues Status</small>
            <% dues_badge_class = case user.dues_status
               when "current" then "success"
               when "lapsed" then "warning"
               when "inactive" then "secondary"
               when "unknown" then "secondary"
               else "secondary"
               end %>
            <span class="badge text-bg-<%= dues_badge_class %> fs-6"><%= user.dues_status.humanize %></span>
          </div>
        <% end %>

        <%# Reactivation options for lapsed members %>
        <% if user.within_reactivation_grace_period? %>
          <%# Can reactivate - show payment options and expiration %>
          <% plans_with_links = MembershipPlan.with_payment_link.ordered %>
          <% if plans_with_links.any? %>
            <div class="mt-3 pt-3 border-top">
              <div class="alert alert-warning py-2 mb-2">
                <i class="bi bi-exclamation-triangle me-1"></i>
                <strong>Membership Lapsed</strong>
              </div>
              <p class="small text-muted mb-2">
                Your last payment was <%= time_ago_in_words(user.most_recent_payment_date) %> ago.
                You can reactivate your membership by selecting a plan below:
              </p>
              <% expires_on = user.reactivation_expires_on %>
              <% if expires_on.present? %>
                <p class="small mb-2">
                  <i class="bi bi-clock me-1"></i>
                  <% if expires_on > Date.current %>
                    <strong class="text-warning">Reactivation available for <%= distance_of_time_in_words_to_now(expires_on) %></strong>
                    <br>
                    <span class="text-muted">(until <%= expires_on.strftime('%B %d, %Y') %>)</span>
                  <% else %>
                    <strong class="text-danger">Reactivation expires today!</strong>
                  <% end %>
                </p>
              <% end %>
              <div class="d-grid gap-2">
                <% plans_with_links.each do |plan| %>
                  <%= link_to plan.payment_link, class: "btn btn-outline-primary btn-sm", target: "_blank", rel: "noopener" do %>
                    <i class="bi bi-credit-card me-1"></i>
                    <%= plan.name %> - $<%= format('%.2f', plan.cost) %>/<%= plan.billing_frequency %>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        <% elsif user.past_reactivation_grace_period? %>
          <%# Past grace period - needs orientation %>
          <div class="mt-3 pt-3 border-top">
            <div class="alert alert-danger py-2 mb-2">
              <i class="bi bi-x-circle me-1"></i>
              <strong>Membership Expired</strong>
            </div>
            <p class="small text-muted mb-2">
              Your membership has been lapsed for too long to reactivate directly.
            </p>
            <p class="small mb-0">
              <i class="bi bi-info-circle me-1"></i>
              To rejoin, you'll need to go through orientation again. 
              Please <strong>contact the space</strong> to schedule a new orientation session.
            </p>
          </div>
        <% end %>

        <div class="mb-3">
          <small class="text-muted d-block">Membership Status</small>
          <span class="badge text-bg-<%= membership_status_badge_class(user.membership_status) %> fs-6"><%= user.membership_status.humanize %></span>
        </div>

        <% manage_membership_content = TextFragment.content_for('manage_your_membership') %>
        <% if manage_membership_content.present? && current_user&.id == user.id %>
          <div>
            <button type="button" class="btn btn-outline-primary btn-sm w-100"
                    data-bs-toggle="modal" data-bs-target="#manageMembershipModal">
              <i class="bi bi-gear me-1"></i> Manage Your Membership
            </button>
          </div>

          <div class="modal fade" id="manageMembershipModal" tabindex="-1" aria-labelledby="manageMembershipModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title" id="manageMembershipModalLabel">Manage Your Membership</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                  <%= sanitize(manage_membership_content) %>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

      <%# Documents available to this user %>
      <% user_documents = user.available_documents %>
      <% if user_documents.any? %>
        <hr class="my-3">
        <div>
          <h6 class="text-muted mb-2">
            <i class="bi bi-file-earmark-text me-1"></i> Documents
          </h6>
          <ul class="list-unstyled mb-0">
            <% user_documents.each do |doc| %>
              <li class="mb-1">
                <%= link_to download_document_path(doc), class: "text-decoration-none" do %>
                  <i class="bi bi-download me-1"></i> <%= doc.title %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Training topic links for topics the user is trained in %>
      <% topics_with_links = user.training_topics_with_links %>
      <% if topics_with_links.any? %>
        <hr class="my-3">
        <div>
          <h6 class="text-muted mb-2">
            <i class="bi bi-link-45deg me-1"></i> Training Resources
          </h6>
          <% topics_with_links.each do |topic| %>
            <div class="mb-3">
              <span class="d-block mb-1"><%= topic.name %></span>
              <ul class="list-unstyled mb-0 ms-2">
                <% topic.links.order(:title).each do |link| %>
                  <li class="mb-1">
                    <%= link_to link.url, class: "text-decoration-none", target: "_blank", rel: "noopener" do %>
                      <i class="bi bi-box-arrow-up-right me-1"></i> <%= link.title %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
