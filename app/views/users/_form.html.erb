<%= form_with model: @user,
              local: true,
              class: "vstack gap-3",
              data: {
                user_authentik_id: @user.authentik_id,
                user_username: @user.username
              } do |f| %>
  <% if current_user_admin? %>
    <div class="form-check mb-2">
      <%= f.check_box :service_account, class: "form-check-input", id: "user_service_account" %>
      <%= f.label :service_account, "Service Account", class: "form-check-label" %>
      <div class="form-text">Service accounts are used for access control and applications. They don't have payment plans or membership info.</div>
    </div>
    <% if @user.persisted? %>
      <div class="form-check mb-2">
        <%= f.check_box :legacy, class: "form-check-input", id: "user_legacy" %>
        <%= f.label :legacy, "Legacy Member", class: "form-check-label" %>
        <div class="form-text">Legacy members are former members with little information. They are hidden from the default member list.</div>
      </div>
    <% end %>
  <% end %>

  <div>
    <%= f.label :username, class: "form-label" %>
    <%= f.text_field :username, class: "form-control", autocorrect: "off", autocapitalize: "off", spellcheck: "false" %>
    <div class="form-text">Will be synced back to Authentik in the future.</div>
  </div>

  <div>
    <%= f.label :full_name, class: "form-label" %>
    <%= f.text_field :full_name, class: "form-control", autocorrect: "off", autocapitalize: "off", spellcheck: "false" %>
  </div>

  <div>
    <%= f.label :email, class: "form-label" %>
    <%= f.email_field :email, class: "form-control", autocorrect: "off", autocapitalize: "off", spellcheck: "false" %>
  </div>

  <div>
    <%= f.label :pronouns, class: "form-label" %>
    <%= f.text_field :pronouns, class: "form-control", placeholder: "e.g., they/them, she/her, he/him" %>
  </div>

  <div>
    <%= f.label :profile_visibility, "Profile Visibility", class: "form-label" %>
    <%= f.select :profile_visibility,
        options_for_select([
          ["Public (visible to anyone)", "public"],
          ["Other Members (visible to logged-in members)", "members"],
          ["Private (only visible to admins)", "private"]
        ], @user.profile_visibility),
        {},
        { class: "form-select" } %>
    <div class="form-text">Controls who can see your profile information.</div>
  </div>

  <% if @user.persisted? %>
    <div data-controller="rich-editor" data-rich-editor-variables-value="[]">
      <%= f.label :bio, "About Me", class: "form-label" %>
      <div class="mb-2">
        <small class="text-muted">Tell others about yourself, your interests, and what you're working on.</small>
      </div>
      <%= f.text_area :bio, class: "form-control", rows: 5, data: { rich_editor_target: "editor" } %>
    </div>
  <% end %>

  <% current_greeting_option = @user.greeting_option %>
  <div>
    <label class="form-label">Greeting Name</label>
    <small class="text-muted d-block mb-2">Name displayed on entry signs when you arrive at the space</small>

    <div class="vstack gap-2 mb-3">
      <div class="form-check">
        <input type="radio" name="user[greeting_option]" value="full_name" id="user_greet_full_name"
               class="form-check-input" <%= 'checked' if current_greeting_option == 'full_name' %>>
        <label class="form-check-label" for="user_greet_full_name">
          Use my full name<% if @user.full_name.present? %> — <strong><%= @user.full_name %></strong><% end %>
        </label>
      </div>
      <div class="form-check">
        <input type="radio" name="user[greeting_option]" value="username" id="user_greet_username"
               class="form-check-input" <%= 'checked' if current_greeting_option == 'username' %>>
        <label class="form-check-label" for="user_greet_username">
          Use my username<% if @user.username.present? %> — <strong><%= @user.username %></strong><% end %>
        </label>
      </div>
      <div class="form-check">
        <input type="radio" name="user[greeting_option]" value="custom" id="user_greet_custom"
               class="form-check-input" <%= 'checked' if current_greeting_option == 'custom' %>>
        <label class="form-check-label" for="user_greet_custom">Use a custom name</label>
      </div>
      <div class="form-check">
        <input type="radio" name="user[greeting_option]" value="do_not_greet" id="user_greet_none"
               class="form-check-input" <%= 'checked' if current_greeting_option == 'do_not_greet' %>>
        <label class="form-check-label" for="user_greet_none">Don't greet me</label>
      </div>
    </div>

    <input type="text" id="user_greeting_name" name="user[greeting_name]"
           class="form-control"
           placeholder="Enter a custom greeting name"
           value="<%= @user.greeting_name %>">
  </div>

  <% if current_user_admin? %>
    <div>
      <%= f.label :membership_status, "Membership Status", class: "form-label" %>
      <%= f.select :membership_status, 
          options_for_select([
            ["Paying", "paying"],
            ["Guest", "guest"],
            ["Banned", "banned"],
            ["Deceased", "deceased"],
            ["Sponsored", "sponsored"],
            ["Applicant", "applicant"],
            ["Cancelled", "cancelled"],
            ["Unknown", "unknown"]
          ], @user.membership_status),
          {},
          { class: "form-select", id: "user_membership_status" } %>
      <div class="form-text">For Guest or Sponsored, you can set when access ends below (optional).</div>
    </div>

    <div class="guest-sponsored-access-duration border rounded p-3 bg-body-secondary" id="guest-sponsored-access-fields">
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :dues_due_at, "Access ends at (optional)", class: "form-label" %>
          <%= f.datetime_field :dues_due_at, class: "form-control", include_seconds: false %>
          <div class="form-text">Leave blank for unlimited guest or sponsored access.</div>
        </div>
        <div class="col-md-6">
          <%= f.label :sponsored_guest_duration_months, "Or duration from now (months)", class: "form-label" %>
          <%= f.number_field :sponsored_guest_duration_months, class: "form-control", min: 0, step: 1,
              value: nil, placeholder: "e.g. 3" %>
          <div class="form-text">If set, overrides “Access ends at” on save. Use 0 to clear an end date.</div>
        </div>
      </div>
    </div>

    <% if @user.service_account? %>
      <div class="form-check">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, "Active", class: "form-check-label" %>
      </div>
    <% else %>
      <div>
        <label class="form-label">Active Status</label>
        <div>
          <% if @user.active? %>
            <span class="badge text-bg-success">Active</span>
          <% else %>
            <span class="badge text-bg-secondary">Inactive</span>
          <% end %>
          <span class="form-text ms-2">Determined automatically by membership and dues status.</span>
        </div>
      </div>
    <% end %>

    <div>
      <%= f.label :payment_type, class: "form-label" %>
      <%= f.select :payment_type, 
          options_for_select([
            ["Unknown", "unknown"],
            ["Sponsored", "sponsored"],
            ["PayPal", "paypal"],
            ["Recharge", "recharge"],
            ["Ko-Fi", "kofi"],
            ["Cash", "cash"],
            ["Inactive", "inactive"]
          ], @user.payment_type),
          {},
          { class: "form-select" } %>
    </div>

    <div>
      <%= f.label :membership_plan_id, "Membership Plan", class: "form-label" %>
      <%= f.select :membership_plan_id,
          options_from_collection_for_select(MembershipPlan.ordered, :id, :display_name, @user.membership_plan_id),
          { prompt: "No plan" },
          { class: "form-select" } %>
      <div class="form-text">Optional: Assign a membership plan to this user.</div>
    </div>

    <div>
      <%= f.label :aliases, "Aliases (alternate names)", class: "form-label" %>
      <%= f.text_field :aliases_text, value: @user.aliases&.join(", "), class: "form-control",
          placeholder: "e.g., Bob Smith, Robert J. Smith" %>
      <div class="form-text">Comma-separated list of alternate names used for matching payments and syncs.</div>
    </div>

    <div>
      <%= f.label :notes, class: "form-label" %>
      <%= f.text_area :notes, class: "form-control", rows: 4 %>
    </div>

    <% if @user.persisted? %>
      <div class="form-check">
        <%= f.check_box :is_admin, class: "form-check-input", id: "user_is_admin" %>
        <%= f.label :is_admin, "Administrator", class: "form-check-label" %>
      </div>
    <% end %>

    <script>
    (function() {
      const sel = document.getElementById('user_membership_status');
      const box = document.getElementById('guest-sponsored-access-fields');
      if (!sel || !box) return;
      function sync() {
        const v = sel.value;
        box.style.display = (v === 'guest' || v === 'sponsored') ? 'block' : 'none';
      }
      sel.addEventListener('change', sync);
      sync();
    })();
    </script>

  <% end %>

  <div class="d-flex gap-2">
    <%= f.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Cancel", @user.persisted? ? user_path(@user) : users_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<% if @user.persisted? %>
  <div class="card shadow-sm border-0 mt-4" id="links">
    <div class="card-header bg-body-tertiary">
      <h5 class="card-title mb-0">Profile Links</h5>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">Add links to your website, social media, GitHub, and other profiles.</p>

      <% if @user.user_links.any? %>
        <div class="list-group mb-4">
          <% @user.user_links.ordered.each do |link| %>
            <div class="list-group-item d-flex justify-content-between align-items-center">
              <div class="d-flex align-items-center gap-3">
                <i class="bi <%= link.icon_class %> fs-5"></i>
                <div>
                  <strong><%= link.title %></strong>
                  <br>
                  <%= link_to truncate(link.url, length: 50), sanitize_url(link.url), target: '_blank', rel: 'noopener', class: 'text-muted small text-decoration-none' %>
                </div>
              </div>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#edit-link-<%= link.id %>">
                  Edit
                </button>
                <%= button_to user_user_link_path(@user, link), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Remove this link?" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </div>
            </div>
            <div class="collapse" id="edit-link-<%= link.id %>">
              <div class="card card-body border-0 bg-body-tertiary">
                <%= form_with model: link, url: user_user_link_path(@user, link), method: :patch, local: true, class: "row g-2" do |lf| %>
                  <div class="col-md-4">
                    <%= lf.text_field :title, class: "form-control form-control-sm", placeholder: "Title" %>
                  </div>
                  <div class="col-md-6">
                    <%= lf.url_field :url, class: "form-control form-control-sm", placeholder: "https://..." %>
                  </div>
                  <div class="col-md-2">
                    <%= lf.submit "Update", class: "btn btn-sm btn-primary w-100" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <h6 class="text-muted">Add New Link</h6>
      <%= form_with model: UserLink.new, url: user_user_links_path(@user), local: true, class: "row g-2" do |lf| %>
        <div class="col-md-4">
          <%= lf.text_field :title, class: "form-control", placeholder: "Title (e.g., GitHub, Website)" %>
        </div>
        <div class="col-md-6">
          <%= lf.url_field :url, class: "form-control", placeholder: "https://..." %>
        </div>
        <div class="col-md-2">
          <%= lf.submit "Add Link", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var greetingField   = document.getElementById('user_greeting_name');
    var fullNameField   = document.getElementById('user_full_name');
    var usernameField   = document.getElementById('user_username');
    var radios          = document.querySelectorAll('input[name="user[greeting_option]"]');

    if (!greetingField || !radios.length) return;

    // Preserve whatever the user types when "custom" is active
    var savedCustomValue = (greetingField.value || '').trim();

    function selectedOption() {
      for (var i = 0; i < radios.length; i++) {
        if (radios[i].checked) return radios[i].value;
      }
      return null;
    }

    function applyOption(option) {
      switch (option) {
        case 'full_name':
          greetingField.value    = (fullNameField ? fullNameField.value : '') || '';
          greetingField.readOnly = true;
          greetingField.classList.add('text-muted');
          break;
        case 'username':
          greetingField.value    = (usernameField ? usernameField.value : '') || '';
          greetingField.readOnly = true;
          greetingField.classList.add('text-muted');
          break;
        case 'custom':
          greetingField.value    = savedCustomValue;
          greetingField.readOnly = false;
          greetingField.classList.remove('text-muted');
          greetingField.focus();
          break;
        case 'do_not_greet':
          greetingField.value    = '';
          greetingField.readOnly = true;
          greetingField.classList.add('text-muted');
          break;
      }
    }

    // When a radio changes, update the field
    radios.forEach(function(radio) {
      radio.addEventListener('change', function() {
        applyOption(this.value);
      });
    });

    // Keep savedCustomValue in sync while user types
    greetingField.addEventListener('input', function() {
      if (selectedOption() === 'custom') {
        savedCustomValue = greetingField.value;
      }
    });

    // Live-update the field when full_name / username source fields change
    if (fullNameField) {
      fullNameField.addEventListener('input', function() {
        if (selectedOption() === 'full_name') greetingField.value = fullNameField.value;
      });
    }
    if (usernameField) {
      usernameField.addEventListener('input', function() {
        if (selectedOption() === 'username') greetingField.value = usernameField.value;
      });
    }

    // Initialise state on page load
    applyOption(selectedOption());
  });
})();
</script>


