<%
  image_url = if @user.avatar.present?
    @user.avatar
  elsif @user.email.present?
    gravatar_url(@user.email, size: 192)
  elsif @user.slack_user&.raw_attributes&.dig("profile", "image_192").present?
    @user.slack_user.raw_attributes.dig("profile", "image_192")
  end
%>

<% if true_user_admin? || @can_preview_views %>
  <div class="d-flex align-items-center justify-content-between mb-3 small text-secondary flex-wrap gap-2">
    <span>
      <% if true_user_admin? %>
        <%= link_to "‹ Members", users_path(@nav_params || {}), class: "text-info-emphasis text-decoration-none" %>
        / <%= @user.username %>
      <% else %>
        Profile preview
      <% end %>
    </span>

    <div class="d-flex gap-2 align-items-center flex-wrap">
      <% if true_user_admin? && @view_level == :admin && !impersonating? %>
        <% if @previous_user %>
          <%= link_to "‹ Prev", user_path(@previous_user, @nav_params), class: "btn btn-sm btn-outline-secondary", title: "Previous: #{@previous_user.display_name}" %>
        <% else %>
          <span class="btn btn-sm btn-outline-secondary disabled" title="First member">‹ Prev</span>
        <% end %>

        <% if @next_user %>
          <%= link_to "Next ›", user_path(@next_user, @nav_params), class: "btn btn-sm btn-outline-secondary", title: "Next: #{@next_user.display_name}" %>
        <% else %>
          <span class="btn btn-sm btn-outline-secondary disabled" title="Last member">Next ›</span>
        <% end %>

        <span class="mx-1 text-secondary opacity-50">|</span>
      <% end %>

      <% if @can_preview_views %>
        <span class="text-12">View as:</span>
        <%= form_with url: user_path(@user), method: :get, local: true, class: "d-inline-flex align-items-center" do %>
          <%= select_tag :view_as,
              options_for_select(@available_views, @view_level),
              class: "form-select form-select-sm view-as-picker",
              onchange: "this.form.submit();" %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @view_level != @natural_view_level %>
  <div class="preview-banner">
    <span class="text-12">
      Previewing as <strong><%= member_preview_label(@view_level) %></strong> -
      you're seeing the <%= member_preview_label(@view_level) %> view.
    </span>
    <%= link_to "Return to admin view ›", user_path(@user), class: "text-12 text-info-emphasis" %>
  </div>
<% end %>

<% if @view_level == :admin && @user.emergency_active_override? %>
  <div class="override-banner mb-3">
    <div class="d-flex align-items-center gap-2 small">
      <i class="bi bi-lightning-charge text-warning" aria-hidden="true"></i>
      <span>
        <strong>Active override applied</strong> -
        membership shows as Active despite <%= @user.dues_status.to_s.humanize.downcase %> dues.
        <span class="text-secondary">See Journal for audit details.</span>
      </span>
    </div>
    <%= button_to "Clear override", clear_emergency_active_override_user_path(@user), method: :post,
        class: "btn btn-sm btn-outline-warning",
        form: { data: { turbo: false } } %>
  </div>
<% end %>

<% if @view_level == :admin %>
  <% status_label, status_class = member_admin_status_pill(@user) %>
  <div class="d-flex align-items-start justify-content-between mb-3 gap-3 flex-wrap">
    <div class="d-flex align-items-center gap-3">
      <% if image_url.present? %>
        <img src="<%= image_url %>" alt="<%= @user.display_name %>" class="rounded-circle" style="width: 56px; height: 56px; object-fit: cover;">
      <% else %>
        <div class="avatar-initial avatar-initial-md"><%= @user.display_name.to_s.first.to_s.upcase %></div>
      <% end %>

      <div>
        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
          <h1 class="h-page-title mb-0"><%= @user.display_name %></h1>
          <span class="status-pill <%= status_class %>">
            <span class="dot">●</span> <%= status_label %>
          </span>
          <% if @user.dues_status == 'lapsed' %>
            <span class="badge text-bg-warning-subtle small fw-normal">Lapsed dues</span>
          <% end %>
          <% if @user.is_sponsored? %>
            <span class="badge text-bg-info-subtle small fw-normal">Sponsored</span>
          <% end %>
        </div>

        <div class="text-12 text-secondary">
          <% if @user.pronouns.present? || @user.bio.present? %>
            <span><%= truncate([@user.pronouns, strip_tags(@user.bio)].compact_blank.join(" - "), length: 40) %></span> ·
          <% end %>
          <span>@<%= @user.username %></span>
          <% if @user.email.present? %>
            · <span><%= @user.email %></span>
          <% end %>
        </div>

        <div class="text-12 text-tertiary mt-1"><%= member_admin_tenure(@user) %></div>
      </div>
    </div>

    <div class="d-flex gap-2 align-items-center">
      <%= link_to "Edit", edit_user_path(@user), class: "btn btn-primary btn-sm" %>
      <% unless impersonating? || @user == true_user %>
        <%= button_to "Impersonate", impersonate_user_path(@user), method: :post,
            class: "btn btn-outline-secondary btn-sm",
            form: { data: { turbo: false } },
            data: { confirm_message: "View the site as #{@user.display_name}? You can stop impersonating at any time." },
            onclick: "return confirm(this.dataset.confirmMessage);" %>
      <% end %>

      <div class="dropdown">
        <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="dropdown" title="More actions" style="line-height: 1;">⋯</button>
        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
          <li><h6 class="dropdown-header">Status changes</h6></li>
          <% if @user.service_account? %>
            <% if @user.active? %>
              <li><%= button_to "Deactivate", deactivate_user_path(@user), method: :post, class: "dropdown-item", form: { data: { turbo: false } } %></li>
            <% else %>
              <li><%= button_to "Activate", activate_user_path(@user), method: :post, class: "dropdown-item", form: { data: { turbo: false } } %></li>
            <% end %>
          <% elsif @user.emergency_active_override? %>
            <li><%= button_to "Clear active override", clear_emergency_active_override_user_path(@user), method: :post, class: "dropdown-item", form: { data: { turbo: false } } %></li>
          <% elsif !@user.active? && !@user.membership_status.in?(%w[banned deceased]) %>
            <li><button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#applyOverrideModal">Apply active override...</button></li>
          <% end %>
          <% unless @user.service_account? %>
            <% if @user.is_sponsored? %>
              <li><%= button_to "Remove Sponsorship", unmark_sponsored_user_path(@user), method: :post, class: "dropdown-item", form: { data: { turbo: false } } %></li>
            <% else %>
              <li><%= button_to "Sponsor...", mark_sponsored_user_path(@user), method: :post, class: "dropdown-item", form: { data: { turbo: false } } %></li>
            <% end %>
            <li><button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#deceasedModal">Mark as deceased...</button></li>
          <% end %>
          <li><hr class="dropdown-divider"></li>
          <li><h6 class="dropdown-header">Sync</h6></li>
          <% if @user.authentik_id.present? && MemberSource.enabled?('member_manager') %>
            <li><%= button_to "Push to Authentik", sync_to_authentik_user_path(@user), method: :post, class: "dropdown-item", form: { data: { turbo: false } } %></li>
          <% else %>
            <li><span class="dropdown-item disabled">Push to Authentik</span></li>
          <% end %>
          <% if @user.authentik_id.present? && MemberSource.enabled?('authentik') %>
            <li><%= button_to "Pull from Authentik", sync_from_authentik_user_path(@user), method: :post, class: "dropdown-item", form: { data: { turbo: false } } %></li>
          <% else %>
            <li><span class="dropdown-item disabled">Pull from Authentik</span></li>
          <% end %>
          <li><hr class="dropdown-divider"></li>
          <% unless @user.service_account? %>
            <li><button type="button" class="dropdown-item text-danger" data-bs-toggle="modal" data-bs-target="#banModal">Ban...</button></li>
          <% end %>
          <li><button type="button" class="dropdown-item text-danger" data-bs-toggle="modal" data-bs-target="#deleteMemberModal">Delete member...</button></li>
        </ul>
      </div>
    </div>
  </div>

  <%= render "users/admin_member_action_modals", user: @user %>
<% end %>

<% unless @view_level.in?(%i[self admin]) %>
  <% if @view_level == :members %>
    <div class="mb-4">
      <h1 class="h5 mb-0">Member Profile</h1>
    </div>
  <% end %>

  <%# Profile photo URL %>
  <%
    image_url = if @user.avatar.present?
      @user.avatar
    elsif @user.email.present?
      gravatar_url(@user.email, size: 192)
    elsif @user.slack_user&.raw_attributes&.dig("profile", "image_192").present?
      @user.slack_user.raw_attributes.dig("profile", "image_192")
    end
  %>

  <%# Name and Photo Header - shown for admin, member, and public views. Self view uses the compact member hero below. %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <div class="d-flex align-items-center gap-4">
        <% if image_url.present? %>
          <img src="<%= image_url %>" alt="<%= @user.display_name %>" class="rounded-circle" style="width: 96px; height: 96px; object-fit: cover;">
        <% else %>
          <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" style="width: 96px; height: 96px;">
            <i class="bi bi-person-fill text-white" style="font-size: 48px;"></i>
          </div>
        <% end %>
        <div>
          <h1 class="h3 mb-1"><%= @user.display_name %></h1>
          <% if @user.pronouns.present? %>
            <span class="text-muted"><%= @user.pronouns %></span>
          <% end %>
          <% if @user.membership_start_date.present? || @user.membership_ended_date.present? %>
            <div class="text-muted small mt-1">
              <i class="bi bi-calendar-check me-1"></i>
              <% if @user.membership_start_date.present? && @user.membership_ended_date.present? %>
                Member <%= @user.membership_start_date.strftime('%B %Y') %> - <%= @user.membership_ended_date.strftime('%B %Y') %>
              <% elsif @user.membership_start_date.present? %>
                Member since <%= @user.membership_start_date.strftime('%B %Y') %>
              <% elsif @user.membership_ended_date.present? %>
                Membership ended <%= @user.membership_ended_date.strftime('%B %Y') %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% if @view_level == :admin %>
  <%# ===== ADMIN VIEW WITH TABS ===== %>
  <ul class="nav nav-tabs mb-3 small" role="tablist">
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :profile, view_as: params[:view_as]), 
          class: "nav-link #{'active' if @active_tab == :profile}", 
          role: "tab" do %>
        Profile
      <% end %>
    </li>
    <% unless @user.service_account? %>
      <li class="nav-item" role="presentation">
        <%= link_to user_path(@user, tab: :payments, view_as: params[:view_as]), 
            class: "nav-link #{'active' if @active_tab == :payments}", 
            role: "tab" do %>
          Payments
          <% if @payments_count.to_i > 0 %>
            <span class="text-secondary small ms-1"><%= @payments_count %></span>
          <% end %>
        <% end %>
      </li>
    <% end %>
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :access, view_as: params[:view_as]), 
          class: "nav-link #{'active' if @active_tab == :access}", 
          role: "tab" do %>
        Access
        <% if @access_count.to_i > 0 %>
          <span class="text-secondary small ms-1"><%= @access_count %></span>
        <% end %>
      <% end %>
    </li>
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :profile, anchor: "training-access-section", view_as: params[:view_as]),
          class: "nav-link",
          role: "tab" do %>
        Training
        <% training_count = @user.trainings_as_trainee.count %>
        <% if training_count.positive? %>
          <span class="text-secondary small ms-1"><%= training_count %></span>
        <% end %>
      <% end %>
    </li>
    <% if @incidents_count.to_i > 0 %>
      <li class="nav-item" role="presentation">
        <%= link_to user_path(@user, tab: :incidents, view_as: params[:view_as]), 
            class: "nav-link #{'active' if @active_tab == :incidents}", 
            role: "tab" do %>
          Incidents <span class="text-warning small ms-1"><%= @incidents_count %></span>
        <% end %>
      </li>
    <% end %>
    <% if @parking_notices_count.to_i > 0 %>
      <li class="nav-item" role="presentation">
        <%= link_to user_path(@user, tab: :parking, view_as: params[:view_as]),
            class: "nav-link #{'active' if @active_tab == :parking}",
            role: "tab" do %>
          Parking <span class="text-secondary small ms-1"><%= @parking_notices_count %></span>
        <% end %>
      </li>
    <% end %>
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :journal, view_as: params[:view_as]), 
          class: "nav-link #{'active' if @active_tab == :journal}", 
          role: "tab" do %>
        Journal
        <% if @journals_count.to_i > 0 %>
          <span class="text-secondary small ms-1"><%= @journals_count %></span>
        <% end %>
      <% end %>
    </li>
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :mail, view_as: params[:view_as]), 
          class: "nav-link #{'active' if @active_tab == :mail}", 
          role: "tab" do %>
        Mail
        <% if @mail_count.to_i > 0 %>
          <span class="text-secondary small ms-1"><%= @mail_count %></span>
        <% end %>
      <% end %>
    </li>
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :messages, view_as: params[:view_as]),
          class: "nav-link #{'active' if @active_tab == :messages}",
          role: "tab" do %>
        Messages
        <% if @unread_messages_count.to_i > 0 %>
          <span class="text-warning small ms-1"><%= @unread_messages_count %></span>
        <% end %>
      <% end %>
    </li>
  </ul>

  <div class="tab-content">
    <% if @active_tab == :profile %>
      <%= render 'users/tab_profile_admin', user: @user, most_recent_access: @most_recent_access %>
    <% elsif @active_tab == :payments %>
      <%= render 'users/tab_payments', payments: @payments, pagy: @pagy_payments, user: @user, show_payment_links: true %>
    <% elsif @active_tab == :access %>
      <%= render 'users/tab_access', recent_accesses: @recent_accesses, pagy: @pagy_accesses, user: @user %>
    <% elsif @active_tab == :incidents %>
      <%= render 'users/tab_incidents', user_incidents: @user_incidents, pagy: @pagy_incidents, user: @user %>
    <% elsif @active_tab == :parking %>
      <%= render 'users/tab_parking', parking_notices: @parking_notices_list, show_actions: true %>
    <% elsif @active_tab == :journal %>
      <%= render 'users/tab_journal', journals: @journals, pagy: @pagy_journals, user: @user %>
    <% elsif @active_tab == :mail %>
      <%= render 'users/tab_mail', queued_mails: @queued_mails, pagy: @pagy_mails, user: @user %>
    <% elsif @active_tab == :messages %>
      <%= render 'users/tab_messages', messages: @messages, pagy: @pagy_messages, user: @user, show_send: true %>
    <% end %>
  </div>

<% elsif @view_level == :self %>
  <%# ===== SELF VIEW WITH TABS ===== %>
  <% member_since = @user.membership_start_date || @user.created_at %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-3">
      <%= render 'users/member_avatar_44', user: @user, editable: @active_tab == :profile %>
      <div>
        <% if @active_tab == :profile %>
          <div class="h-page-title mb-0">Your profile</div>
          <div class="text-12 text-secondary">How others see you and how we reach you</div>
        <% else %>
          <div class="h-page-title mb-0">Hi, <%= @user.display_name %></div>
          <div class="text-12 text-secondary">Member since <%= member_since.strftime('%b %Y') %></div>
        <% end %>
      </div>
    </div>
  </div>

  <ul class="nav nav-tabs mb-3 small" role="tablist">
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :dashboard, view_as: params[:view_as]),
          class: "nav-link #{'active' if @active_tab == :dashboard}",
          role: "tab" do %>
        Dashboard
      <% end %>
    </li>
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :profile, view_as: params[:view_as]), 
          class: "nav-link #{'active' if @active_tab == :profile}", 
          role: "tab" do %>
        Profile
      <% end %>
    </li>
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :payments, view_as: params[:view_as]), 
          class: "nav-link #{'active' if @active_tab == :payments}", 
          role: "tab" do %>
        Payments
        <% if @payments_count.to_i > 0 %>
          <span class="text-secondary small ms-1"><%= @payments_count %></span>
        <% end %>
      <% end %>
    </li>
    <% if @parking_notices_count.to_i > 0 %>
      <li class="nav-item" role="presentation">
        <%= link_to user_path(@user, tab: :parking, view_as: params[:view_as]),
            class: "nav-link #{'active' if @active_tab == :parking}",
            role: "tab" do %>
          Parking <span class="text-secondary small ms-1"><%= @parking_notices_count %></span>
        <% end %>
      </li>
    <% end %>
    <li class="nav-item" role="presentation">
      <%= link_to user_path(@user, tab: :messages, view_as: params[:view_as]),
          class: "nav-link #{'active' if @active_tab == :messages}",
          role: "tab" do %>
        Messages
        <% if @unread_messages_count.to_i > 0 %>
          <span class="text-warning small ms-1"><%= @unread_messages_count %></span>
        <% end %>
      <% end %>
    </li>
  </ul>

  <div class="tab-content">
    <% if @active_tab == :dashboard %>
      <%= render 'users/tab_dashboard_self', user: @user %>
    <% elsif @active_tab == :profile %>
      <%= render 'users/tab_profile_self', user: @user %>
    <% elsif @active_tab == :payments %>
      <%= render 'users/tab_payments', payments: @payments, pagy: @pagy_payments, user: @user, show_payment_links: false %>
    <% elsif @active_tab == :parking %>
      <%= render 'users/tab_parking', parking_notices: @parking_notices_list, show_actions: false %>
    <% elsif @active_tab == :messages %>
      <%= render 'users/tab_messages', messages: @messages, pagy: @pagy_messages, user: @user, show_send: false %>
    <% end %>
  </div>

<% elsif @view_level == :members %>
  <%# ===== MEMBERS VIEW - NO TABS ===== %>
  <%= render 'users/tab_profile_members', user: @user %>

<% else %>
  <%# ===== PUBLIC VIEW - NO TABS ===== %>
  <% if @user.profile_visibility != 'public' %>
    <div class="text-center py-5">
      <h1 class="display-6 fw-bold text-muted">404</h1>
      <p class="lead text-muted mb-1">Page not found</p>
      <p class="text-muted small">This profile is not visible to the public.</p>
    </div>
  <% else %>
    <%= render 'users/tab_profile_public', user: @user %>
  <% end %>
<% end %>

<%# Member Help Modal - only for profile owner %>
<% if @member_help_content.present? && current_user && current_user.id == @user.id && !impersonating? %>
  <div class="modal fade" id="memberHelpModal" tabindex="-1" aria-labelledby="memberHelpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="memberHelpModalLabel">
            <i class="bi bi-question-circle me-2"></i>Member Help
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <%= sanitize(@member_help_content, tags: %w[h1 h2 h3 h4 h5 h6 p br strong b em i u s ul ol li a div span hr], attributes: %w[href target class style]) %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Got it!</button>
        </div>
      </div>
    </div>
  </div>

  <% if @show_member_help_auto %>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var helpModal = new bootstrap.Modal(document.getElementById('memberHelpModal'));
        helpModal.show();
        
        // Mark help as seen when modal is closed
        document.getElementById('memberHelpModal').addEventListener('hidden.bs.modal', function() {
          fetch('<%= mark_help_seen_user_path(@user) %>', {
            method: 'POST',
            headers: {
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
              'Accept': 'application/json'
            }
          });
        });
      });
    </script>
  <% end %>
<% end %>
