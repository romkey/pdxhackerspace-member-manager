<%# Mail Tab %>
<%# Params: queued_mails, pagy, user %>
<div class="card shadow-sm border-0">
  <div class="card-body">
    <h2 class="h6 mb-3">Mail History</h2>
    <% if queued_mails.any? %>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="bg-body-tertiary">
            <tr>
              <th scope="col">Date</th>
              <th scope="col">Subject</th>
              <th scope="col">Reason</th>
              <th scope="col">Status</th>
              <th scope="col">Activity</th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% queued_mails.each do |qm| %>
              <tr class="<%= 'table-danger' if qm.delivery_failed? %><%= 'table-secondary' if qm.rejected? %>">
                <td class="text-muted small text-nowrap"><%= l(qm.created_at, format: :long) %></td>
                <td>
                  <span class="text-truncate d-inline-block" style="max-width: 250px;">
                    <%= qm.subject %>
                  </span>
                </td>
                <td class="text-muted small"><%= qm.reason %></td>
                <td>
                  <% if qm.delivery_failed? %>
                    <span class="badge text-bg-danger">Send Failed</span>
                  <% elsif qm.delivery_pending? %>
                    <span class="badge text-bg-info">Sending...</span>
                  <% elsif qm.sent? %>
                    <span class="badge text-bg-success">Sent</span>
                    <% if qm.sent_at %>
                      <br><span class="text-muted small"><%= time_ago_in_words(qm.sent_at) %> ago</span>
                    <% end %>
                  <% elsif qm.pending? %>
                    <span class="badge text-bg-warning">Pending</span>
                  <% elsif qm.rejected? %>
                    <span class="badge text-bg-secondary">Rejected</span>
                  <% end %>
                </td>
                <td class="small">
                  <% qm.mail_log_entries.sort_by(&:created_at).reverse.first(3).each do |entry| %>
                    <div class="text-muted">
                      <span class="badge text-bg-light border"><%= entry.event %></span>
                      <% if entry.actor %>
                        by <%= entry.actor.display_name %>
                      <% end %>
                      <span class="text-nowrap"><%= time_ago_in_words(entry.created_at) %> ago</span>
                    </div>
                  <% end %>
                  <% if qm.mail_log_entries.size > 3 %>
                    <div class="text-muted small">... and <%= qm.mail_log_entries.size - 3 %> more</div>
                  <% end %>
                </td>
                <td class="text-end">
                  <%= link_to "View", queued_mail_path(qm), class: "btn btn-sm btn-outline-primary" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if pagy.pages > 1 %>
        <div class="mt-3">
          <%== pagy.series_nav(:bootstrap) %>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted mb-0">No mail has been queued for this member.</p>
    <% end %>
  </div>
</div>
