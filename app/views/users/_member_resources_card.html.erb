<%# locals: user %>
<% documents = user.available_documents %>
<% topics_with_links = user.training_topics_with_links %>

<% if documents.any? || topics_with_links.any? %>
  <div class="sidebar-card">
    <div class="h-section-label mb-2">Resources for you</div>

    <% if documents.any? %>
      <div class="mb-3">
        <div class="text-12 text-secondary mb-1">
          <i class="bi bi-file-earmark-text me-1" aria-hidden="true"></i>Documents
        </div>
        <div class="d-flex flex-column gap-1">
          <% documents.each do |doc| %>
            <%= link_to download_document_path(doc), class: "resource-link" do %>
              &darr; <%= doc.title %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if topics_with_links.any? %>
      <div>
        <div class="text-12 text-secondary mb-2">
          <i class="bi bi-link-45deg me-1" aria-hidden="true"></i>Training resources
        </div>
        <% topics_with_links.each do |topic| %>
          <div class="mb-2">
            <div class="text-12 text-body mb-1"><%= topic.name %></div>
            <div class="d-flex flex-column gap-1 ms-2">
              <% topic.links.order(:title).each do |link| %>
                <%= link_to link.url, class: "resource-link", target: "_blank", rel: "noopener" do %>
                  &nearr; <%= link.title %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
