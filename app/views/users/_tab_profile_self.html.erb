<% edit_profile_path = edit_user_path(user) %>
<% visibility_label = { 'public' => 'Public', 'members' => 'Other members', 'private' => 'Private' }[user.profile_visibility] || user.profile_visibility.humanize %>
<% user_interests = user.interests.order(:name) %>

<div class="row g-3">
  <div class="col-lg-8">
    <div class="mb-4">
      <div class="profile-section-header">
        <span class="h-section-label">Public profile</span>
        <span class="profile-section-context">- visible to other members</span>
      </div>
      <div class="profile-field-group">
        <div class="profile-field-row">
          <span class="profile-field-label">Display name</span>
          <% if user.greeting_name.present? %>
            <span class="profile-field-value"><%= user.greeting_name %></span>
            <%= link_to "Edit", edit_profile_path, class: "profile-field-edit" %>
          <% else %>
            <span class="profile-field-value empty">Choose how members should greet you</span>
            <%= link_to "Add", edit_profile_path, class: "profile-field-edit" %>
          <% end %>
        </div>

        <div class="profile-field-row">
          <span class="profile-field-label">About</span>
          <% if user.bio.present? %>
            <span class="profile-field-value"><%= sanitize(user.bio, tags: %w[p br strong b em i u s ul ol li a h1 h2 h3 h4 h5 h6 span div], attributes: %w[href target style]) %></span>
            <%= link_to "Edit", edit_profile_path, class: "profile-field-edit" %>
          <% else %>
            <span class="profile-field-value empty">Tell others a bit about yourself</span>
            <%= link_to "Add", edit_profile_path, class: "profile-field-edit" %>
          <% end %>
        </div>

        <div class="profile-field-row">
          <span class="profile-field-label">Links</span>
          <% if user.user_links.any? %>
            <span class="profile-field-value">
              <% user.user_links.ordered.each do |link| %>
                <%= link_to sanitize_url(link.url), target: '_blank', rel: 'noopener', class: 'resource-link me-2' do %>
                  <i class="bi <%= link.icon_class %> me-1"></i><%= link.title %>
                <% end %>
              <% end %>
            </span>
            <%= link_to "Edit", edit_profile_path, class: "profile-field-edit" %>
          <% else %>
            <span class="profile-field-value empty">Website, social, portfolio...</span>
            <%= link_to "Add", edit_profile_path, class: "profile-field-edit" %>
          <% end %>
        </div>

        <div class="profile-field-row">
          <span class="profile-field-label">Interests</span>
          <% if user_interests.any? %>
            <span class="profile-field-value">
              <% user_interests.each do |interest| %>
                <span class="cert-pill me-1"><%= interest.name %></span>
              <% end %>
            </span>
            <%= link_to "Edit", edit_profile_path, class: "profile-field-edit" %>
          <% else %>
            <span class="profile-field-value empty">Help others find common ground</span>
            <%= link_to "Add", edit_profile_path, class: "profile-field-edit" %>
          <% end %>
        </div>

        <div class="profile-field-row">
          <span class="profile-field-label">Profile visibility</span>
          <span class="profile-field-value"><%= visibility_label %></span>
          <%= link_to "Edit", edit_profile_path, class: "profile-field-edit" %>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <div class="profile-section-header">
        <span class="h-section-label">Contact</span>
        <span class="profile-section-context">- how we reach you</span>
      </div>
      <div class="profile-field-group">
        <div class="profile-field-row">
          <span class="profile-field-label">Email</span>
          <% if user.email.present? %>
            <span class="profile-field-value"><%= mail_to user.email %></span>
            <%= link_to "Edit", edit_profile_path, class: "profile-field-edit" %>
          <% else %>
            <span class="profile-field-value empty">Add an email address</span>
            <%= link_to "Add", edit_profile_path, class: "profile-field-edit" %>
          <% end %>
        </div>

        <div class="profile-field-row">
          <span class="profile-field-label">Slack</span>
          <% if user.slack_user.present? || user.slack_handle.present? %>
            <span class="profile-field-value">
              <%= user.slack_handle.presence || user.slack_user&.display_name || 'Slack account' %>
              <span class="text-success small ms-1">● connected</span>
            </span>
            <span></span>
          <% elsif SlackOidcConfig.configured? %>
            <span class="profile-field-value empty">Connect Slack for member coordination</span>
            <%= link_to "Add", slack_link_start_path, class: "profile-field-edit" %>
          <% else %>
            <span class="profile-field-value empty">Slack connection is not available</span>
            <span></span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <div class="profile-section-header">
        <span class="h-section-label">Account</span>
      </div>
      <div class="profile-field-group">
        <div class="profile-field-row">
          <span class="profile-field-label">Username</span>
          <% if user.username.present? %>
            <span class="profile-field-value"><%= user.username %></span>
          <% else %>
            <span class="profile-field-value empty">Assigned by your sign-in provider</span>
          <% end %>
          <span></span>
        </div>

        <div class="profile-field-row">
          <span class="profile-field-label">Password</span>
          <span class="profile-field-value">Managed by your sign-in provider</span>
          <span></span>
        </div>

        <div class="profile-field-row">
          <span class="profile-field-label">Sessions</span>
          <span class="profile-field-value">Current session active</span>
          <span></span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <%= render 'users/member_membership_card', user: user %>
    <%= render 'users/member_training_card', user: user %>
  </div>
</div>
