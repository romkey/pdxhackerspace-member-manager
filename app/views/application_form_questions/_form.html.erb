<%= form_with model: [page, question],
    url: question.persisted? ? application_form_page_application_form_question_path(page, question) : application_form_page_application_form_questions_path(page),
    local: true do |f| %>
  <% if question.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(question.errors.count, 'error') %> prevented this question from being saved:</h6>
      <ul class="mb-0">
        <% question.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :label, 'Question Text', class: "form-label" %>
    <%= f.text_area :label, class: "form-control", rows: 2, required: true %>
  </div>

  <div class="row">
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :field_type, class: "form-label" %>
        <%= f.select :field_type,
            ApplicationFormQuestion::FIELD_TYPES.map { |t| [t.capitalize, t] },
            {}, class: "form-select", id: "question_field_type" %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :position, class: "form-label" %>
        <%= f.number_field :position, class: "form-control" %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3 pt-md-4">
        <div class="form-check">
          <%= f.check_box :required, class: "form-check-input" %>
          <%= f.label :required, class: "form-check-label" %>
        </div>
      </div>
    </div>
  </div>

  <div class="mb-3" id="options-field">
    <label class="form-label">Options (one per line, for radio fields)</label>
    <textarea name="application_form_question[options_text]" class="form-control" rows="4"
              placeholder="Yes&#10;No&#10;Maybe&#10;Other"><%= question.options.join("\n") %></textarea>
  </div>

  <div class="mb-3">
    <%= f.label :help_text, class: "form-label" %>
    <%= f.text_field :help_text, class: "form-control",
        placeholder: "Optional help text shown below the field" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", application_form_pages_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<script>
  (function() {
    function initQuestionForm() {
      var typeSelect = document.getElementById('question_field_type');
      var optionsField = document.getElementById('options-field');
      if (!typeSelect || !optionsField) return;

      function toggleOptions() {
        optionsField.style.display = typeSelect.value === 'radio' ? '' : 'none';
      }
      toggleOptions();
      typeSelect.addEventListener('change', toggleOptions);
    }
    document.addEventListener('DOMContentLoaded', initQuestionForm);
    document.addEventListener('turbo:load', initQuestionForm);
  })();
</script>
