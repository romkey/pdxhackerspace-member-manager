<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Edit <%= @ai_ollama_profile.name %></h1>
  <%= link_to "Back to AI Services", ai_ollama_profiles_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <%= form_with model: @ai_ollama_profile, url: ai_ollama_profile_path(@ai_ollama_profile), method: :patch do |f| %>
      <% if @ai_ollama_profile.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @ai_ollama_profile.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :ai_provider_id, "AI provider", class: "form-label" %>
        <%= f.select :ai_provider_id,
                     options_for_select([['Custom / Override', nil]] + @ai_provider_options, @ai_ollama_profile.ai_provider_id),
                     {},
                     class: "form-select" %>
        <div class="form-text">Choose a saved provider or leave on Custom / Override.</div>
      </div>

      <div class="mb-3">
        <%= f.label :base_url, "Service URL (legacy/custom)", class: "form-label" %>
        <%= f.text_field :base_url, class: "form-control", placeholder: "https://api.example.com" %>
        <% if @ai_ollama_profile.key != 'default' %>
          <div class="form-text">Leave blank to use override URL, selected provider URL, or Default service URL.</div>
        <% else %>
          <div class="form-text">Optional. Other services inherit this when their own URL/provider is blank.</div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :api_key, "Service API key (optional)", class: "form-label" %>
        <%= f.password_field :api_key,
                             value: nil,
                             class: "form-control",
                             autocomplete: "new-password",
                             placeholder: (@ai_ollama_profile.api_key.present? ? "KEY****" : "Optional") %>
        <div class="form-text">Leave blank to keep the existing service API key.</div>
      </div>

      <div class="mb-3">
        <%= f.label :provider_name_override, "Provider override name (optional)", class: "form-label" %>
        <%= f.text_field :provider_name_override, class: "form-control", placeholder: "My Custom Provider" %>
      </div>

      <div class="mb-3">
        <%= f.label :provider_url_override, "Provider override URL (optional)", class: "form-label" %>
        <%= f.text_field :provider_url_override, class: "form-control", placeholder: "https://override.example.com" %>
        <div class="form-text">When set, this takes precedence over selected provider and service URL.</div>
      </div>

      <div class="mb-3">
        <%= f.label :provider_api_key_override, "Provider override API key (optional)", class: "form-label" %>
        <%= f.password_field :provider_api_key_override,
                             value: nil,
                             class: "form-control",
                             autocomplete: "new-password",
                             placeholder: (@ai_ollama_profile.provider_api_key_override.present? ? "KEY****" : "Optional") %>
        <div class="form-text">Leave blank to keep the existing override key. When set, this takes precedence over selected provider and service API key.</div>
      </div>

      <div class="mb-3">
        <%= f.label :model, class: "form-label" %>
        <%= f.text_field :model, class: "form-control", placeholder: "e.g. llama3.2" %>
        <% if @ai_ollama_profile.key != 'default' %>
          <div class="form-text">Leave blank to use the Default profile's model.</div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :prompt, class: "form-label" %>
        <%= f.text_area :prompt, class: "form-control font-monospace", rows: 12 %>
      </div>

      <div class="mb-4 form-check">
        <%= hidden_field_tag "ai_ollama_profile[enabled]", "0" %>
        <%= f.check_box :enabled, class: "form-check-input" %>
        <%= f.label :enabled, "Enabled", class: "form-check-label" %>
        <div class="form-text">Disabled profiles are not checked for health and do not count as urgent or healthy on the dashboard.</div>
      </div>

      <%= f.submit "Save", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
