<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Edit <%= @ai_ollama_profile.name %></h1>
  <%= link_to "Back to Manage AI", ai_ollama_profiles_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <%= form_with model: @ai_ollama_profile, url: ai_ollama_profile_path(@ai_ollama_profile), method: :patch do |f| %>
      <% if @ai_ollama_profile.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @ai_ollama_profile.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :base_url, "Ollama base URL", class: "form-label" %>
        <%= f.text_field :base_url, class: "form-control", placeholder: "http://host:11434" %>
        <% if @ai_ollama_profile.key != 'default' %>
          <div class="form-text">Leave blank to use the Default profile’s endpoint.</div>
        <% else %>
          <div class="form-text">Optional. Other profiles inherit this when their own URL is blank.</div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :model, class: "form-label" %>
        <%= f.text_field :model, class: "form-control", placeholder: "e.g. llama3.2" %>
      </div>

      <div class="mb-3">
        <%= f.label :prompt, class: "form-label" %>
        <%= f.text_area :prompt, class: "form-control font-monospace", rows: 12 %>
      </div>

      <div class="mb-4 form-check">
        <%= hidden_field_tag "ai_ollama_profile[enabled]", "0" %>
        <%= f.check_box :enabled, class: "form-check-input" %>
        <%= f.label :enabled, "Enabled", class: "form-check-label" %>
        <div class="form-text">Disabled profiles are not checked for health and do not count as urgent or healthy on the dashboard.</div>
      </div>

      <%= f.submit "Save", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
