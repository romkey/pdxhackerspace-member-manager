<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h1 class="h3 mb-1"><%= @title %></h1>
      <p class="text-muted mb-0">Members marked as legacy who have access log records.</p>
    </div>
    <div>
      <%= link_to "&larr; Back to Reports".html_safe, reports_path(tab: 'legacy-with-access'), class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-header bg-body-tertiary">
    <h2 class="h5 mb-0">Legacy Members with Access (<%= @legacy_with_access_count %>)</h2>
  </div>
  <div class="card-body">
    <% if @legacy_with_access.any? %>
      <%= render partial: 'legacy_access_table', locals: { entries: @legacy_with_access } %>
    <% else %>
      <p class="text-muted mb-0">No legacy members have access records.</p>
    <% end %>
  </div>
</div>
