<div class="table-responsive">
  <table class="table table-hover align-middle mb-0">
    <thead class="bg-body-tertiary">
      <tr>
        <th style="width: 48px;"></th>
        <th>Member</th>
        <th>Total Access Records</th>
        <th>Most Recent Access</th>
        <th>Recent Access Details</th>
      </tr>
    </thead>
    <tbody>
      <% entries.each do |entry| %>
        <% user = entry[:user] %>
        <tr>
          <td>
            <%= link_to user_path(user) do %>
              <% if user.avatar.present? %>
                <img src="<%= user.avatar %>" alt="<%= user.display_name %>" style="width: 32px; height: 32px; border-radius: 4px;">
              <% elsif user.email.present? %>
                <img src="<%= gravatar_url(user.email, size: 32) %>" alt="<%= user.display_name %>" style="width: 32px; height: 32px; border-radius: 4px;">
              <% else %>
                <div style="width: 32px; height: 32px; border-radius: 4px; background-color: #dee2e6; display: inline-block;"></div>
              <% end %>
            <% end %>
          </td>
          <td>
            <%= link_to user.display_name, user_path(user), class: "text-decoration-none fw-semibold" %>
            <span class="badge text-bg-secondary ms-1">Legacy</span>
            <% if user.email.present? %>
              <br><small class="text-muted"><%= user.email %></small>
            <% end %>
          </td>
          <td>
            <span class="badge text-bg-info fs-6"><%= entry[:access_count] %></span>
          </td>
          <td>
            <% most_recent = entry[:most_recent_access] %>
            <i class="bi bi-door-open me-1 text-muted"></i>
            <%= most_recent.logged_at.strftime('%B %d, %Y %H:%M') %>
            <% if most_recent.respond_to?(:location) && most_recent.location.present? %>
              <br><small class="text-muted"><%= most_recent.location %></small>
            <% end %>
            <br><small class="text-muted"><%= time_ago_in_words(most_recent.logged_at) %> ago</small>
          </td>
          <td>
            <% entry[:recent_accesses].each do |access| %>
              <div class="small">
                <span class="text-muted"><%= access.logged_at.strftime('%b %d, %Y %H:%M') %></span>
                <% if access.respond_to?(:location) && access.location.present? %>
                  <span class="text-secondary ms-1">(<%= access.location %>)</span>
                <% end %>
              </div>
            <% end %>
            <% if entry[:access_count] > entry[:recent_accesses].size %>
              <div class="small text-muted fst-italic">... and <%= entry[:access_count] - entry[:recent_accesses].size %> more</div>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
