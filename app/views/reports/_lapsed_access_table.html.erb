<div class="table-responsive">
  <table class="table table-hover align-middle mb-0">
    <thead class="bg-body-tertiary">
      <tr>
        <th style="width: 48px;"></th>
        <th>Member</th>
        <th>Last Payment</th>
        <th>Accesses Since Lapse</th>
        <th>Most Recent Access</th>
        <th>Recent Access Details</th>
      </tr>
    </thead>
    <tbody>
      <% entries.each do |entry| %>
        <% user = entry[:user] %>
        <tr>
          <td>
            <%= link_to user_path(user) do %>
              <%= render 'shared/user_avatar', user: user %>
            <% end %>
          </td>
          <td>
            <%= link_to user.display_name, user_path(user), class: "text-decoration-none fw-semibold" %>
            <% if user.email.present? %>
              <br><small class="text-muted"><%= user.email %></small>
            <% end %>
          </td>
          <td>
            <span class="text-danger">
              <i class="bi bi-calendar-x me-1"></i>
              <%= entry[:last_payment_date].strftime('%B %d, %Y') %>
            </span>
            <br>
            <small class="text-muted"><%= time_ago_in_words(entry[:last_payment_date]) %> ago</small>
          </td>
          <td>
            <span class="badge text-bg-warning fs-6"><%= entry[:access_count] %></span>
          </td>
          <td>
            <% most_recent = entry[:most_recent_access] %>
            <span class="text-warning">
              <i class="bi bi-door-open me-1"></i>
              <%= most_recent.logged_at.strftime('%B %d, %Y %H:%M') %>
            </span>
            <% if most_recent.location.present? %>
              <br><small class="text-muted"><%= most_recent.location %></small>
            <% end %>
          </td>
          <td>
            <% entry[:recent_accesses].each do |access| %>
              <div class="small">
                <span class="text-muted"><%= access.logged_at.strftime('%b %d, %Y %H:%M') %></span>
                <% if access.location.present? %>
                  <span class="text-secondary ms-1">(<%= access.location %>)</span>
                <% end %>
              </div>
            <% end %>
            <% if entry[:access_count] > 5 %>
              <div class="small text-muted fst-italic">... and <%= entry[:access_count] - 5 %> more</div>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
