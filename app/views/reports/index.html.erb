<div class="mb-4">
  <h1 class="h3 mb-1">Reports</h1>
  <p class="text-muted mb-0">Users requiring attention.</p>
</div>

<% 
  active_tab = params[:tab] || 'charts'
  tabs = [
    { id: 'charts', name: 'Charts', count: nil },
    { id: 'membership-status-unknown', name: 'Membership', count: @membership_status_unknown_count },
    { id: 'payment-type-unknown', name: 'Payment', count: @payment_type_unknown_count },
    { id: 'dues-status-unknown', name: 'Dues', count: @dues_status_unknown_count },
    { id: 'dues-status-lapsed', name: 'Lapsed', count: @dues_status_lapsed_count },
    { id: 'lapsed-with-access', name: 'Lapsed + Access', count: @lapsed_with_access_count },
    { id: 'no-email', name: 'No Email', count: @no_email_count },
    { id: 'sponsored-and-paying', name: 'Sponsored & Paying', count: @sponsored_and_paying_count },
    { id: 'no-access', name: 'Few Access', count: @no_access_count }
  ]
%>

<ul class="nav nav-tabs mb-4" role="tablist">
  <% tabs.each do |tab| %>
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= 'active' if active_tab == tab[:id] %>" 
              id="<%= tab[:id] %>-tab" 
              data-bs-toggle="tab" 
              data-bs-target="#<%= tab[:id] %>-pane" 
              type="button" 
              role="tab" 
              aria-controls="<%= tab[:id] %>-pane" 
              aria-selected="<%= active_tab == tab[:id] %>">
        <%= tab[:name] %> <span class="badge text-bg-secondary ms-1"><%= tab[:count] %></span>
      </button>
    </li>
  <% end %>
</ul>

<div class="tab-content">
  <!-- Charts -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'charts' %>" 
       id="charts-pane" 
       role="tabpanel" 
       aria-labelledby="charts-tab">
    <div class="row g-4">
      <!-- Active Members Chart -->
      <div class="col-12">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-body-tertiary">
            <h2 class="h5 mb-0">Active Members per Month</h2>
          </div>
          <div class="card-body">
            <canvas id="activeMembersChart" height="80"></canvas>
          </div>
        </div>
      </div>
      
      <!-- Revenue Chart -->
      <div class="col-12">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-body-tertiary">
            <h2 class="h5 mb-0">Revenue per Month</h2>
          </div>
          <div class="card-body">
            <canvas id="revenueChart" height="80"></canvas>
          </div>
        </div>
      </div>

      <!-- New & Lapsed Members Chart -->
      <div class="col-12">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">New & Lapsed Members per Month</h2>
            <div class="d-flex align-items-center gap-2">
              <button type="button" class="btn btn-sm btn-outline-secondary" id="churnPrev" title="Back 3 months">
                <i class="bi bi-chevron-left"></i>
              </button>
              <span class="text-muted small" id="churnRange"></span>
              <button type="button" class="btn btn-sm btn-outline-secondary" id="churnNext" title="Forward 3 months">
                <i class="bi bi-chevron-right"></i>
              </button>
            </div>
          </div>
          <div class="card-body">
            <% if @churn_data.any? %>
              <canvas id="churnChart" height="80"></canvas>
            <% else %>
              <p class="text-muted mb-0">No membership start or end date data available.</p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Membership Duration Chart -->
      <div class="col-12">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Membership Duration Distribution</h2>
            <span class="text-muted small">
              <%= @duration_total %> ended memberships
              <% if @duration_total > 0 %>
                &middot; median: <%= @duration_median %> months &middot; average: <%= @duration_avg %> months
              <% end %>
            </span>
          </div>
          <div class="card-body">
            <% if @duration_total > 0 %>
              <canvas id="durationChart" height="80"></canvas>
            <% else %>
              <p class="text-muted mb-0">No ended memberships with both start and end dates.</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Membership Status Unknown -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'membership-status-unknown' %>" 
       id="membership-status-unknown-pane" 
       role="tabpanel" 
       aria-labelledby="membership-status-unknown-tab">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h2 class="h5 mb-0">Membership Status: Unknown (<%= @membership_status_unknown_count %>)</h2>
      </div>
      <div class="card-body">
        <% if @membership_status_unknown.any? %>
          <%= render partial: 'user_table', locals: { 
            users: @membership_status_unknown, 
            anchor: 'membership-status-unknown',
            show_payment_type: true,
            show_dues_status: false,
            show_last_payment: false
          } %>
          <% if @membership_status_unknown_count > 20 %>
            <div class="mt-3 text-center">
              <%= link_to "View all #{@membership_status_unknown_count} users", 
                  reports_view_all_path('membership-status-unknown'), 
                  class: "btn btn-outline-primary" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No users with unknown membership status.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Payment Type Unknown -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'payment-type-unknown' %>" 
       id="payment-type-unknown-pane" 
       role="tabpanel" 
       aria-labelledby="payment-type-unknown-tab">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h2 class="h5 mb-0">Payment Type: Unknown (<%= @payment_type_unknown_count %>)</h2>
      </div>
      <div class="card-body">
        <% if @payment_type_unknown.any? %>
          <%= render partial: 'user_table', locals: { 
            users: @payment_type_unknown, 
            anchor: 'payment-type-unknown',
            show_payment_type: true,
            show_dues_status: false,
            show_last_payment: false
          } %>
          <% if @payment_type_unknown_count > 20 %>
            <div class="mt-3 text-center">
              <%= link_to "View all #{@payment_type_unknown_count} users", 
                  reports_view_all_path('payment-type-unknown'), 
                  class: "btn btn-outline-primary" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No users with unknown payment type.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Dues Status Unknown -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'dues-status-unknown' %>" 
       id="dues-status-unknown-pane" 
       role="tabpanel" 
       aria-labelledby="dues-status-unknown-tab">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h2 class="h5 mb-0">Dues Status: Unknown (<%= @dues_status_unknown_count %>)</h2>
      </div>
      <div class="card-body">
        <% if @dues_status_unknown.any? %>
          <%= render partial: 'user_table', locals: { 
            users: @dues_status_unknown, 
            anchor: 'dues-status-unknown',
            show_payment_type: false,
            show_dues_status: true,
            show_last_payment: false
          } %>
          <% if @dues_status_unknown_count > 20 %>
            <div class="mt-3 text-center">
              <%= link_to "View all #{@dues_status_unknown_count} users", 
                  reports_view_all_path('dues-status-unknown'), 
                  class: "btn btn-outline-primary" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No users with unknown dues status.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Dues Status Lapsed -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'dues-status-lapsed' %>" 
       id="dues-status-lapsed-pane" 
       role="tabpanel" 
       aria-labelledby="dues-status-lapsed-tab">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h2 class="h5 mb-0">Dues Status: Lapsed (<%= @dues_status_lapsed_count %>)</h2>
      </div>
      <div class="card-body">
        <% if @dues_status_lapsed.any? %>
          <%= render partial: 'user_table', locals: { 
            users: @dues_status_lapsed, 
            anchor: 'dues-status-lapsed',
            show_payment_type: false,
            show_dues_status: true,
            show_last_payment: true
          } %>
          <% if @dues_status_lapsed_count > 20 %>
            <div class="mt-3 text-center">
              <%= link_to "View all #{@dues_status_lapsed_count} users", 
                  reports_view_all_path('dues-status-lapsed'), 
                  class: "btn btn-outline-primary" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No users with lapsed dues status.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Lapsed Members with Access -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'lapsed-with-access' %>" 
       id="lapsed-with-access-pane" 
       role="tabpanel" 
       aria-labelledby="lapsed-with-access-tab">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h2 class="h5 mb-0">Lapsed Members with Access After Lapse (<%= @lapsed_with_access_count %>)</h2>
      </div>
      <div class="card-body">
        <% if @lapsed_with_access.any? %>
          <p class="text-muted small mb-3">Members whose dues have lapsed but who have accessed the space after their last payment.</p>
          <%= render partial: 'lapsed_access_table', locals: { entries: @lapsed_with_access } %>
          <% if @lapsed_with_access_count > 20 %>
            <div class="mt-3 text-center">
              <%= link_to "View all #{@lapsed_with_access_count} members",
                  reports_view_all_path('lapsed-with-access'),
                  class: "btn btn-outline-primary" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No lapsed members with access records after their lapse.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Members with No Email -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'no-email' %>"
       id="no-email-pane"
       role="tabpanel"
       aria-labelledby="no-email-tab">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h2 class="h5 mb-0">Paying, Sponsored or Guest Members with No Email (<%= @no_email_count %>)</h2>
      </div>
      <div class="card-body">
        <% if @no_email.any? %>
          <p class="text-muted small mb-3">Active members (paying, sponsored, or guest) who have no email address on file.</p>
          <div class="table-responsive">
            <table class="table mb-0 align-middle">
              <thead class="bg-body-tertiary">
                <tr>
                  <th scope="col" style="width: 48px;"></th>
                  <th scope="col">Name</th>
                  <th scope="col">Membership Status</th>
                  <th scope="col">Payment Type</th>
                  <th scope="col">Dues Status</th>
                </tr>
              </thead>
              <tbody>
                <% @no_email.each do |user| %>
                  <tr>
                    <td>
                      <% if user.avatar.present? %>
                        <img src="<%= user.avatar %>" alt="<%= user.display_name %>" style="width: 32px; height: 32px; border-radius: 4px;">
                      <% else %>
                        <div style="width: 32px; height: 32px; border-radius: 4px; background-color: #dee2e6; display: inline-block;"></div>
                      <% end %>
                    </td>
                    <td class="fw-semibold">
                      <%= link_to user.display_name, user_path(user), class: "text-decoration-none" %>
                    </td>
                    <td>
                      <% badge_class = case user.membership_status
                         when "paying" then "success"
                         when "sponsored" then "primary"
                         when "guest" then "warning"
                         else "secondary"
                         end %>
                      <span class="badge text-bg-<%= badge_class %>"><%= user.membership_status.humanize %></span>
                    </td>
                    <td>
                      <span class="badge text-bg-info"><%= user.payment_type.humanize %></span>
                    </td>
                    <td>
                      <% dues_badge_class = case user.dues_status
                         when "current" then "success"
                         when "lapsed" then "warning"
                         else "secondary"
                         end %>
                      <span class="badge text-bg-<%= dues_badge_class %>"><%= user.dues_status.humanize %></span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <% if @no_email_count > 20 %>
            <div class="mt-3 text-center">
              <%= link_to "View all #{@no_email_count} members",
                  reports_view_all_path('no-email'),
                  class: "btn btn-outline-primary" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">All paying, sponsored, and guest members have email addresses.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sponsored & Paying -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'sponsored-and-paying' %>"
       id="sponsored-and-paying-pane"
       role="tabpanel"
       aria-labelledby="sponsored-and-paying-tab">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h2 class="h5 mb-0">Sponsored & Paying Members (<%= @sponsored_and_paying_count %>)</h2>
      </div>
      <div class="card-body">
        <% if @sponsored_and_paying.any? %>
          <p class="text-muted small mb-3">Members who have the sponsored flag set but whose membership status is "paying" (they have current payments).</p>
          <div class="table-responsive">
            <table class="table mb-0 align-middle">
              <thead class="bg-body-tertiary">
                <tr>
                  <th scope="col" style="width: 48px;"></th>
                  <th scope="col">Name</th>
                  <th scope="col">Email</th>
                  <th scope="col">Membership Status</th>
                  <th scope="col">Payment Type</th>
                  <th scope="col">Dues Status</th>
                  <th scope="col">Plan</th>
                </tr>
              </thead>
              <tbody>
                <% @sponsored_and_paying.each do |user| %>
                  <tr>
                    <td>
                      <% if user.avatar.present? %>
                        <img src="<%= user.avatar %>" alt="<%= user.display_name %>" style="width: 32px; height: 32px; border-radius: 4px;">
                      <% elsif user.email.present? %>
                        <img src="<%= gravatar_url(user.email, size: 32) %>" alt="<%= user.display_name %>" style="width: 32px; height: 32px; border-radius: 4px;">
                      <% else %>
                        <div style="width: 32px; height: 32px; border-radius: 4px; background-color: #dee2e6; display: inline-block;"></div>
                      <% end %>
                    </td>
                    <td class="fw-semibold">
                      <%= link_to user.display_name, user_path(user), class: "text-decoration-none" %>
                      <span class="badge text-bg-primary ms-1"><i class="bi bi-heart-fill me-1"></i>Sponsored</span>
                    </td>
                    <td>
                      <% if user.email.present? %>
                        <%= mail_to user.email %>
                      <% else %>
                        <span class="text-muted fst-italic">Not provided</span>
                      <% end %>
                    </td>
                    <td><span class="badge text-bg-success">Paying</span></td>
                    <td><span class="badge text-bg-info"><%= user.payment_type.humanize %></span></td>
                    <td>
                      <% dues_badge_class = case user.dues_status
                         when "current" then "success"
                         when "lapsed" then "warning"
                         else "secondary"
                         end %>
                      <span class="badge text-bg-<%= dues_badge_class %>"><%= user.dues_status.humanize %></span>
                    </td>
                    <td>
                      <% if user.membership_plan.present? %>
                        <%= user.membership_plan.name %>
                      <% else %>
                        <span class="text-muted fst-italic">None</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <% if @sponsored_and_paying_count > 20 %>
            <div class="mt-3 text-center">
              <%= link_to "View all #{@sponsored_and_paying_count} members",
                  reports_view_all_path('sponsored-and-paying'),
                  class: "btn btn-outline-primary" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">No members are both sponsored and paying.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Paying Members with Few Access Records -->
  <div class="tab-pane fade <%= 'show active' if active_tab == 'no-access' %>"
       id="no-access-pane"
       role="tabpanel"
       aria-labelledby="no-access-tab">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-body-tertiary">
        <h2 class="h5 mb-0">Paying Members with Few Access Records (<%= @no_access_count %>)</h2>
      </div>
      <div class="card-body">
        <% if @no_access.any? %>
          <p class="text-muted small mb-3">Members with membership status "paying" who have fewer than 3 access log entries.</p>
          <div class="table-responsive">
            <table class="table mb-0 align-middle">
              <thead class="bg-body-tertiary">
                <tr>
                  <th scope="col" style="width: 48px;"></th>
                  <th scope="col">Name</th>
                  <th scope="col">Email</th>
                  <th scope="col">Access Records</th>
                  <th scope="col">Dues Status</th>
                  <th scope="col">Payment Type</th>
                  <th scope="col">Plan</th>
                </tr>
              </thead>
              <tbody>
                <% @no_access.each do |user| %>
                  <tr>
                    <td>
                      <% if user.avatar.present? %>
                        <img src="<%= user.avatar %>" alt="<%= user.display_name %>" style="width: 32px; height: 32px; border-radius: 4px;">
                      <% elsif user.email.present? %>
                        <img src="<%= gravatar_url(user.email, size: 32) %>" alt="<%= user.display_name %>" style="width: 32px; height: 32px; border-radius: 4px;">
                      <% else %>
                        <div style="width: 32px; height: 32px; border-radius: 4px; background-color: #dee2e6; display: inline-block;"></div>
                      <% end %>
                    </td>
                    <td class="fw-semibold">
                      <%= link_to user.display_name, user_path(user), class: "text-decoration-none" %>
                    </td>
                    <td>
                      <% if user.email.present? %>
                        <%= mail_to user.email %>
                      <% else %>
                        <span class="text-muted fst-italic">Not provided</span>
                      <% end %>
                    </td>
                    <td>
                      <% count = user.access_logs.count %>
                      <% if count == 0 %>
                        <span class="badge text-bg-danger">0</span>
                      <% else %>
                        <span class="badge text-bg-warning"><%= count %></span>
                      <% end %>
                    </td>
                    <td>
                      <% dues_badge_class = case user.dues_status
                         when "current" then "success"
                         when "lapsed" then "warning"
                         else "secondary"
                         end %>
                      <span class="badge text-bg-<%= dues_badge_class %>"><%= user.dues_status.humanize %></span>
                    </td>
                    <td><span class="badge text-bg-info"><%= user.payment_type.humanize %></span></td>
                    <td>
                      <% if user.membership_plan.present? %>
                        <%= user.membership_plan.name %>
                      <% else %>
                        <span class="text-muted fst-italic">None</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <% if @no_access_count > 20 %>
            <div class="mt-3 text-center">
              <%= link_to "View all #{@no_access_count} members",
                  reports_view_all_path('no-access'),
                  class: "btn btn-outline-primary" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">All paying members have at least 3 access records.</p>
        <% end %>
      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  var _reportCharts = {};

  function destroyCharts() {
    Object.keys(_reportCharts).forEach(function(key) {
      if (_reportCharts[key]) { _reportCharts[key].destroy(); }
    });
    _reportCharts = {};
  }

  function setupReportsPage() {
    destroyCharts();

    const tabButtons = document.querySelectorAll('[data-bs-toggle="tab"]');
    tabButtons.forEach(function(button) {
      button.addEventListener('shown.bs.tab', function(event) {
        const tabId = event.target.getAttribute('data-bs-target').replace('#', '').replace('-pane', '');
        const url = new URL(window.location);
        url.searchParams.set('tab', tabId);
        window.history.pushState({}, '', url);

        if (tabId === 'charts') {
          initializeCharts();
        }
      });
    });

    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab') || 'charts';
    const tabButton = document.querySelector('[data-bs-target="#' + tabParam + '-pane"]');
    if (tabButton) {
      const tab = new bootstrap.Tab(tabButton);
      tab.show();
      if (tabParam === 'charts') {
        setTimeout(initializeCharts, 100);
      }
    } else {
      const chartsTab = document.querySelector('[data-bs-target="#charts-pane"]');
      if (chartsTab) {
        const tab = new bootstrap.Tab(chartsTab);
        tab.show();
        setTimeout(initializeCharts, 100);
      }
    }
  }

  document.addEventListener('DOMContentLoaded', setupReportsPage);
  document.addEventListener('turbo:load', setupReportsPage);

  function initializeCharts() {
    destroyCharts();

    // Active Members Chart
    const activeMembersCtx = document.getElementById('activeMembersChart');
    if (activeMembersCtx && typeof Chart !== 'undefined') {
      _reportCharts.activeMembers = new Chart(activeMembersCtx, {
        type: 'line',
        data: {
          labels: <%= raw @chart_months.to_json %>,
          datasets: [{
            label: 'Active Members',
            data: <%= raw @active_members_counts.to_json %>,
            borderColor: 'rgb(75, 192, 192)',
            backgroundColor: 'rgba(75, 192, 192, 0.2)',
            tension: 0.1,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              display: true,
              position: 'top'
            },
            tooltip: {
              mode: 'index',
              intersect: false
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                stepSize: 1
              }
            }
          }
        }
      });
    }
    
    // Revenue Chart
    const revenueCtx = document.getElementById('revenueChart');
    if (revenueCtx && typeof Chart !== 'undefined') {
      _reportCharts.revenue = new Chart(revenueCtx, {
        type: 'bar',
        data: {
          labels: <%= raw @chart_months.to_json %>,
          datasets: [
            {
              label: 'PayPal',
              data: <%= raw @paypal_revenue.to_json %>,
              backgroundColor: 'rgba(0, 123, 255, 0.8)',
              borderColor: 'rgb(0, 123, 255)',
              borderWidth: 1
            },
            {
              label: 'Recharge',
              data: <%= raw @recharge_revenue.to_json %>,
              backgroundColor: 'rgba(40, 167, 69, 0.8)',
              borderColor: 'rgb(40, 167, 69)',
              borderWidth: 1
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              display: true,
              position: 'top'
            },
            tooltip: {
              mode: 'index',
              intersect: false,
              callbacks: {
                label: function(context) {
                  return context.dataset.label + ': $' + context.parsed.y.toFixed(2);
                }
              }
            }
          },
          scales: {
            x: {
              stacked: false
            },
            y: {
              beginAtZero: true,
              ticks: {
                callback: function(value) {
                  return '$' + value.toFixed(0);
                }
              }
            }
          }
        }
      });
    }

    // New & Lapsed Members Chart
    initChurnChart();

    // Membership Duration Chart
    const durationCtx = document.getElementById('durationChart');
    if (durationCtx && typeof Chart !== 'undefined') {
      _reportCharts.duration = new Chart(durationCtx, {
        type: 'bar',
        data: {
          labels: <%= raw @duration_labels.to_json %>,
          datasets: [{
            label: 'Members',
            data: <%= raw @duration_counts.to_json %>,
            backgroundColor: [
              'rgba(220, 53, 69, 0.8)',
              'rgba(255, 153, 0, 0.8)',
              'rgba(255, 193, 7, 0.8)',
              'rgba(13, 202, 240, 0.8)',
              'rgba(25, 135, 84, 0.8)',
              'rgba(13, 110, 253, 0.8)',
              'rgba(102, 16, 242, 0.8)',
              'rgba(111, 66, 193, 0.8)'
            ],
            borderColor: [
              'rgb(220, 53, 69)',
              'rgb(255, 153, 0)',
              'rgb(255, 193, 7)',
              'rgb(13, 202, 240)',
              'rgb(25, 135, 84)',
              'rgb(13, 110, 253)',
              'rgb(102, 16, 242)',
              'rgb(111, 66, 193)'
            ],
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(context) {
                  var total = <%= @duration_total %>;
                  var pct = total > 0 ? ((context.parsed.y / total) * 100).toFixed(1) : 0;
                  return context.parsed.y + ' members (' + pct + '%)';
                }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: { stepSize: 1 },
              title: { display: true, text: 'Number of Members' }
            },
            x: {
              title: { display: true, text: 'Membership Duration' }
            }
          }
        }
      });
    }
  }

  var _churnAllData = <%= raw @churn_data.to_json %>;
  var _churnWindowSize = 12;
  var _churnOffset = Math.max(0, _churnAllData.length - _churnWindowSize);

  function initChurnChart() {
    var ctx = document.getElementById('churnChart');
    if (!ctx || typeof Chart === 'undefined' || _churnAllData.length === 0) return;

    // Default to showing the most recent 12 months
    _churnOffset = Math.max(0, _churnAllData.length - _churnWindowSize);
    renderChurnChart();

    document.getElementById('churnPrev').addEventListener('click', function() {
      _churnOffset = Math.max(0, _churnOffset - 3);
      renderChurnChart();
    });
    document.getElementById('churnNext').addEventListener('click', function() {
      _churnOffset = Math.min(_churnAllData.length - _churnWindowSize, _churnOffset + 3);
      if (_churnOffset < 0) _churnOffset = 0;
      renderChurnChart();
    });
  }

  function renderChurnChart() {
    var slice = _churnAllData.slice(_churnOffset, _churnOffset + _churnWindowSize);
    var labels = slice.map(function(d) { return d.month; });
    var newData = slice.map(function(d) { return d.new_members; });
    var lapsedData = slice.map(function(d) { return d.lapsed_members; });

    // Update range label
    var rangeEl = document.getElementById('churnRange');
    if (rangeEl && labels.length > 0) {
      rangeEl.textContent = labels[0] + ' \u2013 ' + labels[labels.length - 1];
    }

    // Update button states
    var prevBtn = document.getElementById('churnPrev');
    var nextBtn = document.getElementById('churnNext');
    if (prevBtn) prevBtn.disabled = (_churnOffset <= 0);
    if (nextBtn) nextBtn.disabled = (_churnOffset + _churnWindowSize >= _churnAllData.length);

    if (_reportCharts.churn) {
      _reportCharts.churn.data.labels = labels;
      _reportCharts.churn.data.datasets[0].data = newData;
      _reportCharts.churn.data.datasets[1].data = lapsedData;
      _reportCharts.churn.update();
      return;
    }

    var ctx = document.getElementById('churnChart');
    _reportCharts.churn = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [
          {
            label: 'New Members',
            data: newData,
            backgroundColor: 'rgba(25, 135, 84, 0.8)',
            borderColor: 'rgb(25, 135, 84)',
            borderWidth: 1
          },
          {
            label: 'Lapsed Members',
            data: lapsedData,
            backgroundColor: 'rgba(220, 53, 69, 0.8)',
            borderColor: 'rgb(220, 53, 69)',
            borderWidth: 1
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { display: true, position: 'top' },
          tooltip: { mode: 'index', intersect: false }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { stepSize: 1 },
            title: { display: true, text: 'Members' }
          },
          x: {
            title: { display: true, text: 'Month' }
          }
        }
      }
    });
  }
</script>
