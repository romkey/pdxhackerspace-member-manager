<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Parking Notices</h1>
  <div class="d-flex gap-2">
    <%= link_to new_parking_notice_path(type: 'permit'), class: "btn btn-primary btn-sm" do %>
      <i class="bi bi-plus-circle me-1"></i> New Permit
    <% end %>
    <%= link_to new_parking_notice_path(type: 'ticket'), class: "btn btn-outline-secondary btn-sm" do %>
      <i class="bi bi-plus-circle me-1"></i> New Ticket
    <% end %>
  </div>
</div>

<%# Status filter tabs %>
<ul class="nav nav-tabs mb-3">
  <li class="nav-item">
    <%= link_to parking_notices_path(type: params[:type]),
        class: "nav-link #{params[:status].blank? ? 'active' : ''}" do %>
      All <span class="badge bg-secondary"><%= @status_counts[:all] %></span>
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to parking_notices_path(status: 'active', type: params[:type]),
        class: "nav-link #{params[:status] == 'active' ? 'active' : ''}" do %>
      Active <span class="badge bg-primary"><%= @status_counts[:active] %></span>
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to parking_notices_path(status: 'expired', type: params[:type]),
        class: "nav-link #{params[:status] == 'expired' ? 'active' : ''}" do %>
      Expired <span class="badge bg-danger"><%= @status_counts[:expired] %></span>
    <% end %>
  </li>
  <li class="nav-item">
    <%= link_to parking_notices_path(status: 'cleared', type: params[:type]),
        class: "nav-link #{params[:status] == 'cleared' ? 'active' : ''}" do %>
      Cleared <span class="badge bg-secondary"><%= @status_counts[:cleared] %></span>
    <% end %>
  </li>
</ul>

<%# Type sub-filter %>
<div class="mb-3 d-flex gap-2">
  <%= link_to "All Types", parking_notices_path(status: params[:status]),
      class: "btn btn-sm #{params[:type].blank? ? 'btn-primary' : 'btn-outline-secondary'}" %>
  <%= link_to "Permits", parking_notices_path(status: params[:status], type: 'permit'),
      class: "btn btn-sm #{params[:type] == 'permit' ? 'btn-primary' : 'btn-outline-secondary'}" %>
  <%= link_to "Tickets", parking_notices_path(status: params[:status], type: 'ticket'),
      class: "btn btn-sm #{params[:type] == 'ticket' ? 'btn-primary' : 'btn-outline-secondary'}" %>
</div>

<% if @parking_notices.any? %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Type</th>
            <th>Member</th>
            <th>Location</th>
            <th>Description</th>
            <th>Expires</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @parking_notices.each do |notice| %>
            <tr>
              <td>
                <span class="badge text-bg-secondary-subtle">
                  <%= notice.notice_type_display %>
                </span>
              </td>
              <td>
                <% if notice.user.present? %>
                  <%= link_to notice.user.display_name, user_path(notice.user) %>
                <% else %>
                  <span class="text-muted">Unknown</span>
                <% end %>
              </td>
              <td><%= notice.location_display.presence || '—' %></td>
              <td><%= truncate(notice.description.to_s, length: 50) %></td>
              <td>
                <% if notice.active? && notice.expires_at <= 2.days.from_now %>
                  <span class="text-danger fw-semibold"><%= notice.expires_at.strftime('%b %d, %Y %l:%M %p') %></span>
                <% else %>
                  <%= notice.expires_at.strftime('%b %d, %Y %l:%M %p') %>
                <% end %>
              </td>
              <td>
                <span class="badge text-bg-<%= notice.status_badge_color %>-subtle"><%= notice.status_display %></span>
              </td>
              <td class="text-end">
                <%= link_to "View", parking_notice_path(notice), class: "btn btn-sm btn-outline-secondary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-3">
    <%== @pagy.series_nav(:bootstrap) %>
  </div>
<% else %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-car-front fs-1 d-block mb-2"></i>
    <p>No parking notices found.</p>
  </div>
<% end %>
