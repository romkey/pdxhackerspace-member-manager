<%= form_with model: parking_notice, local: true do |f| %>
  <% if parking_notice.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(parking_notice.errors.count, 'error') %> prevented this parking notice from being saved:</h6>
      <ul class="mb-0">
        <% parking_notice.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :notice_type %>

  <div class="row">
    <div class="col-md-6">
      <%# Member selection %>
      <div class="mb-3">
        <%= f.label :user_id, 'Member', class: 'form-label' %>
        <% if parking_notice.permit? %>
          <span class="text-danger">*</span>
        <% end %>
        <%= f.select :user_id,
            options_from_collection_for_select(@users, :id, :display_name, parking_notice.user_id),
            { include_blank: parking_notice.permit? ? 'Select a member...' : '(Optional) Select a member...' },
            class: 'form-select',
            required: parking_notice.permit? %>
      </div>

      <%# Description %>
      <div class="mb-3">
        <%= f.label :description, class: 'form-label' %>
        <%= f.text_area :description, class: 'form-control', rows: 3,
            placeholder: 'Describe the project that is being left out...' %>
      </div>

      <%# Notes %>
      <div class="mb-3">
        <%= f.label :notes, 'Admin Notes', class: 'form-label' %>
        <%= f.text_area :notes, class: 'form-control', rows: 2,
            placeholder: 'Internal notes (not shown to members)...' %>
      </div>
    </div>

    <div class="col-md-6">
      <%# Expiration with quick-select buttons %>
      <div class="mb-3">
        <%= f.label :expires_at, 'Expiration', class: 'form-label' %>
        <span class="text-danger">*</span>
        <div class="d-flex flex-wrap gap-2 mb-2">
          <button type="button" class="btn btn-sm btn-outline-secondary quick-expire" data-days="1">1 Day</button>
          <button type="button" class="btn btn-sm btn-outline-secondary quick-expire" data-days="3">3 Days</button>
          <button type="button" class="btn btn-sm btn-outline-secondary quick-expire" data-days="7">1 Week</button>
          <button type="button" class="btn btn-sm btn-outline-secondary quick-expire" data-days="10">10 Days</button>
        </div>
        <%= f.datetime_local_field :expires_at, class: 'form-control', required: true,
            value: parking_notice.expires_at&.strftime('%Y-%m-%dT%H:%M') %>
      </div>

      <%# Location with room quick-select %>
      <div class="mb-3">
        <%= f.label :location, 'Room / Location', class: 'form-label' %>
        <% if @rooms.any? %>
          <div class="d-flex flex-wrap gap-2 mb-2">
            <% @rooms.each do |room| %>
              <button type="button" class="btn btn-sm btn-outline-secondary quick-room"
                      data-room="<%= room.name %>"><%= room.name %></button>
            <% end %>
          </div>
        <% end %>
        <%= f.text_field :location, class: 'form-control', placeholder: 'Room name...' %>
      </div>

      <%# Location detail %>
      <div class="mb-3">
        <%= f.label :location_detail, 'Location Detail', class: 'form-label' %>
        <%= f.text_field :location_detail, class: 'form-control',
            placeholder: 'Additional location info (e.g. near the south wall)...' %>
      </div>

      <%# Photos %>
      <div class="mb-3">
        <%= f.label :photos, 'Photos', class: 'form-label' %>
        <div class="d-flex gap-2 mb-2">
          <label class="btn btn-outline-secondary mb-0" id="photo-upload-btn">
            <i class="bi bi-image me-1"></i> Choose Files
            <%= f.file_field :photos, multiple: true, accept: 'image/*', class: 'd-none', id: 'photo-file-input' %>
          </label>
          <label class="btn btn-outline-secondary mb-0 d-none" id="photo-camera-btn">
            <i class="bi bi-camera me-1"></i> Take Photo
            <input type="file" name="parking_notice[photos][]" accept="image/*" capture="environment" class="d-none" id="photo-camera-input">
          </label>
        </div>
        <div id="photo-preview" class="d-flex flex-wrap gap-2 mb-2"></div>
        <div class="form-text">You can select multiple photos or take them with your camera.</div>
      </div>

      <% if parking_notice.persisted? && parking_notice.photos.attached? %>
        <div class="mb-3">
          <label class="form-label">Existing Photos</label>
          <div class="d-flex flex-wrap gap-2">
            <% parking_notice.photos.each do |photo| %>
              <div class="position-relative">
                <%= link_to download_photo_parking_notice_path(parking_notice, photo_id: photo.id, disposition: 'inline'), target: '_blank' do %>
                  <%= image_tag url_for(photo), class: 'rounded', style: 'width: 80px; height: 80px; object-fit: cover;' %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <% label = parking_notice.persisted? ? "Update" : "Create" %>
    <%= f.submit "#{label} Parking #{parking_notice.notice_type_display}",
        class: "btn btn-#{parking_notice.permit? ? 'success' : 'danger'}" %>
    <%= link_to "Cancel", parking_notice.persisted? ? parking_notice_path(parking_notice) : parking_notices_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<script>
  (function() {
    function initParkingNoticeForm() {
      var expiresField = document.querySelector('input[name="parking_notice[expires_at]"]');
      var locationField = document.querySelector('input[name="parking_notice[location]"]');

      if (!expiresField) return;

      document.querySelectorAll('.quick-expire').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var days = parseInt(this.dataset.days);
          var date = new Date();
          date.setDate(date.getDate() + days);
          date.setHours(17, 0, 0, 0);
          var pad = function(n) { return n < 10 ? '0' + n : n; };
          expiresField.value = date.getFullYear() + '-' + pad(date.getMonth() + 1) + '-' +
                               pad(date.getDate()) + 'T' + pad(date.getHours()) + ':' + pad(date.getMinutes());
        });
      });

      document.querySelectorAll('.quick-room').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (locationField) locationField.value = this.dataset.room;
        });
      });

      var cameraBtn = document.getElementById('photo-camera-btn');
      if (cameraBtn && 'mediaDevices' in navigator && 'getUserMedia' in navigator.mediaDevices) {
        cameraBtn.classList.remove('d-none');
      }

      var preview = document.getElementById('photo-preview');

      function addPreviews(files) {
        Array.from(files).forEach(function(file) {
          if (!file.type.startsWith('image/')) return;
          var reader = new FileReader();
          reader.onload = function(e) {
            var img = document.createElement('img');
            img.src = e.target.result;
            img.className = 'rounded border';
            img.style.cssText = 'width: 80px; height: 80px; object-fit: cover;';
            preview.appendChild(img);
          };
          reader.readAsDataURL(file);
        });
      }

      var fileInput = document.getElementById('photo-file-input');
      if (fileInput) {
        fileInput.addEventListener('change', function() { addPreviews(this.files); });
      }

      var cameraInput = document.getElementById('photo-camera-input');
      if (cameraInput) {
        cameraInput.addEventListener('change', function() { addPreviews(this.files); });
      }
    }

    document.addEventListener('DOMContentLoaded', initParkingNoticeForm);
    document.addEventListener('turbo:load', initParkingNoticeForm);
  })();
</script>
