<div class="py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="d-flex align-items-center mb-4">
        <span class="badge bg-success rounded-pill me-2"><i class="bi bi-check"></i></span>
        <span class="text-muted">Member Info</span>
        <i class="bi bi-chevron-right mx-2 text-muted"></i>
        <span class="badge bg-primary rounded-pill me-2">2</span>
        <span class="fw-semibold text-primary">Payment</span>
        <i class="bi bi-chevron-right mx-2 text-muted"></i>
        <span class="badge bg-secondary rounded-pill me-2">3</span>
        <span class="text-muted">Building Access</span>
        <i class="bi bi-chevron-right mx-2 text-muted"></i>
        <span class="badge bg-secondary rounded-pill me-2">4</span>
        <span class="text-muted">Mail</span>
      </div>

      <!-- Member Summary -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body py-2">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-check-circle-fill text-success fs-4"></i>
            <div>
              <%= link_to @user.display_name, user_path(@user), class: "fw-semibold text-decoration-none" %>
              <span class="text-muted ms-2"><%= @user.email %></span>
              <% if @user.username.present? %>
                <span class="text-muted ms-2">@<%= @user.username %></span>
              <% end %>
            </div>
            <span class="badge text-bg-success ms-auto">Created</span>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-header bg-body-tertiary">
          <h4 class="card-title mb-0"><i class="bi bi-credit-card me-2"></i>Membership & Payment</h4>
        </div>
        <div class="card-body">

          <%= form_with url: onboard_save_payment_path(@user), method: :post, id: "payment-form", data: { turbo: false } do |f| %>

            <div class="mb-4">
              <label class="form-label fw-semibold">Membership Type</label>

              <div class="form-check mb-2">
                <input type="radio" name="membership_type" value="paying" class="form-check-input" id="type_paying" checked>
                <label class="form-check-label" for="type_paying">
                  <strong>Paying Member</strong> &mdash; full access, pays dues
                </label>
              </div>

              <div class="form-check mb-2">
                <input type="radio" name="membership_type" value="sponsored" class="form-check-input" id="type_sponsored">
                <label class="form-check-label" for="type_sponsored">
                  <strong>Sponsored</strong> &mdash; full access, no dues
                </label>
              </div>

              <div class="form-check mb-2">
                <input type="radio" name="membership_type" value="guest" class="form-check-input" id="type_guest">
                <label class="form-check-label" for="type_guest">
                  <strong>Guest</strong> &mdash; no physical access, no dues
                </label>
              </div>

              <div id="sponsored-guest-duration-wrap" class="mt-2 ps-4 border-start border-3 border-secondary" style="display: none;">
                <label class="form-label small mb-1">Optional: limit access (months from now)</label>
                <input type="number" name="sponsored_guest_duration_months" id="sponsored_guest_duration_months"
                       class="form-control form-control-sm" min="0" step="1" placeholder="Leave blank for unlimited">
              </div>
            </div>

            <!-- Cash plan option (shown when "paying" is selected) -->
            <div id="paying-options">
              <hr>
              <div class="form-check mb-3">
                <input type="checkbox" name="cash_plan" value="1" class="form-check-input" id="cash_plan_check">
                <label class="form-check-label" for="cash_plan_check">
                  <strong>Cash payment plan</strong> &mdash; dues tracked manually
                </label>
              </div>

              <div id="cash-plan-fields" class="border rounded p-3 bg-body-tertiary" style="display: none;">
                <div class="row g-3">
                  <div class="col-md-4">
                    <label class="form-label">Amount ($)</label>
                    <input type="number" name="plan_cost" step="0.01" min="0" class="form-control" placeholder="0.00">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Billing Frequency</label>
                    <select name="plan_billing_frequency" class="form-select">
                      <option value="monthly">Monthly</option>
                      <option value="yearly">Yearly</option>
                      <option value="one-time">One-time</option>
                    </select>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Notes</label>
                    <input type="text" name="plan_notes" class="form-control" placeholder="Optional notes...">
                  </div>
                </div>
              </div>
            </div>

            <div class="d-flex gap-2 mt-4">
              <%= submit_tag "Save & Continue", class: "btn btn-primary btn-lg" %>
              <%= link_to "Back", onboard_path, class: "btn btn-outline-secondary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const typeRadios = document.querySelectorAll('input[name="membership_type"]');
  const payingOptions = document.getElementById('paying-options');
  const cashCheck = document.getElementById('cash_plan_check');
  const cashFields = document.getElementById('cash-plan-fields');
  if (!payingOptions || !cashFields) return;

  const durationWrap = document.getElementById('sponsored-guest-duration-wrap');

  function updatePayingVisibility() {
    const selected = document.querySelector('input[name="membership_type"]:checked');
    payingOptions.style.display = (selected && selected.value === 'paying') ? 'block' : 'none';
  }

  function updateDurationVisibility() {
    const selected = document.querySelector('input[name="membership_type"]:checked');
    if (!durationWrap) return;
    const show = selected && (selected.value === 'sponsored' || selected.value === 'guest');
    durationWrap.style.display = show ? 'block' : 'none';
  }

  function updateCashVisibility() {
    cashFields.style.display = cashCheck.checked ? 'block' : 'none';
  }

  typeRadios.forEach(function(radio) {
    radio.addEventListener('change', function() {
      updatePayingVisibility();
      updateDurationVisibility();
    });
  });

  cashCheck.addEventListener('change', updateCashVisibility);

  updatePayingVisibility();
  updateDurationVisibility();
  updateCashVisibility();
})();
</script>
