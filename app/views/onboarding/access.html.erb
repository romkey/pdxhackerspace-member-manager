<div class="py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="d-flex align-items-center mb-4">
        <span class="badge bg-success rounded-pill me-2"><i class="bi bi-check"></i></span>
        <span class="text-muted">Member Info</span>
        <i class="bi bi-chevron-right mx-2 text-muted"></i>
        <span class="badge bg-success rounded-pill me-2"><i class="bi bi-check"></i></span>
        <span class="text-muted">Payment</span>
        <i class="bi bi-chevron-right mx-2 text-muted"></i>
        <span class="badge bg-primary rounded-pill me-2">3</span>
        <span class="fw-semibold text-primary">Building Access</span>
      </div>

      <!-- Member Summary -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body py-2">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-person-circle fs-3 text-muted"></i>
            <div>
              <strong><%= @user.display_name %></strong>
              <span class="text-muted ms-2"><%= @user.email %></span>
              <% if @user.username.present? %>
                <span class="text-muted ms-2">@<%= @user.username %></span>
              <% end %>
            </div>
            <div class="ms-auto">
              <span class="badge text-bg-<%= @user.active? ? 'success' : 'secondary' %>"><%= @user.membership_status&.titleize %></span>
              <% if @user.membership_plan %>
                <span class="badge text-bg-info"><%= @user.membership_plan.name %></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- RFID Key Fob -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-body-tertiary">
          <h5 class="card-title mb-0"><i class="bi bi-key me-2"></i>RFID Key Fob</h5>
        </div>
        <div class="card-body">
          <% if @rfids.any? %>
            <div class="mb-3">
              <% @rfids.each do |rfid| %>
                <div class="d-flex align-items-center gap-2 mb-2">
                  <i class="bi bi-check-circle-fill text-success"></i>
                  <code><%= rfid.rfid %></code>
                  <% if rfid.notes.present? %>
                    <span class="text-muted small">(<%= rfid.notes %>)</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>

          <%= form_with url: onboard_save_rfid_path(@user), method: :post, class: "d-flex gap-2", data: { turbo: false } do %>
            <input type="text" name="rfid_code" class="form-control" placeholder="Scan or enter RFID code..."
                   autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
            <button type="submit" class="btn btn-success flex-shrink-0">
              <i class="bi bi-plus-lg me-1"></i>Add
            </button>
          <% end %>
        </div>
      </div>

      <!-- Building Access Training -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-body-tertiary">
          <h5 class="card-title mb-0"><i class="bi bi-mortarboard me-2"></i>Building Access Training</h5>
        </div>
        <div class="card-body">
          <% if @building_access_topic.nil? %>
            <div class="alert alert-warning mb-0">
              <i class="bi bi-exclamation-triangle me-2"></i>
              No "Building Access" training topic found.
              <%= link_to "Create one under Settings > Training Topics", training_topics_path %> first.
            </div>
          <% elsif @has_building_access_training %>
            <div class="d-flex align-items-center gap-2">
              <i class="bi bi-check-circle-fill text-success fs-4"></i>
              <span class="fw-semibold">Building Access training completed</span>
            </div>
          <% else %>
            <p class="text-muted mb-3">Mark this member as trained for building access.</p>
            <%= button_to "Mark Building Access Trained", onboard_save_training_path(@user),
                method: :post, class: "btn btn-info" do %>
              <i class="bi bi-mortarboard me-1"></i>Mark Building Access Trained
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Completion -->
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-4">
          <% if @rfids.any? && @has_building_access_training %>
            <i class="bi bi-check-circle-fill text-success fs-1 mb-2"></i>
            <h5 class="text-success">Onboarding Complete!</h5>
            <p class="text-muted">
              <%= @user.display_name %> is set up with RFID access and building training.
            </p>
          <% else %>
            <p class="text-muted mb-2">
              <% missing = [] %>
              <% missing << "RFID key fob" unless @rfids.any? %>
              <% missing << "Building Access training" unless @has_building_access_training %>
              <% if missing.any? %>
                Still needed: <strong><%= missing.join(", ") %></strong>
              <% end %>
            </p>
          <% end %>

          <div class="d-flex justify-content-center gap-2 mt-3">
            <%= link_to user_path(@user), class: "btn btn-primary btn-lg" do %>
              <i class="bi bi-check-lg me-1"></i>Completed
            <% end %>
            <%= link_to "Back to Dashboard", root_path, class: "btn btn-outline-secondary btn-lg" %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
