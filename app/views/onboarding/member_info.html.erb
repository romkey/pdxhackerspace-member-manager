<div class="py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="d-flex align-items-center mb-4">
        <span class="badge bg-primary rounded-pill me-2">1</span>
        <span class="fw-semibold text-primary">Member Info</span>
        <i class="bi bi-chevron-right mx-2 text-muted"></i>
        <span class="badge bg-secondary rounded-pill me-2">2</span>
        <span class="text-muted">Payment</span>
        <i class="bi bi-chevron-right mx-2 text-muted"></i>
        <span class="badge bg-secondary rounded-pill me-2">3</span>
        <span class="text-muted">Building Access</span>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-header bg-body-tertiary">
          <h4 class="card-title mb-0"><i class="bi bi-person-plus me-2"></i>Onboard New Member</h4>
        </div>
        <div class="card-body">

          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% @user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with url: onboard_create_path, scope: :user, method: :post, class: "vstack gap-3", data: { turbo: false } do |f| %>
            <div>
              <%= f.label :full_name, "Full Name", class: "form-label" %>
              <%= f.text_field :full_name, value: @user.full_name, class: "form-control form-control-lg", id: "onboard_full_name",
                  autocorrect: "off", autocapitalize: "off", spellcheck: "false", autofocus: true %>
            </div>

            <div>
              <%= f.label :email, "Email Address", class: "form-label" %>
              <%= f.email_field :email, value: @user.email, class: "form-control form-control-lg",
                  autocorrect: "off", autocapitalize: "off", spellcheck: "false" %>
            </div>

            <div>
              <%= f.label :username, class: "form-label" %>
              <%= f.text_field :username, value: @user.username, class: "form-control form-control-lg", id: "onboard_username",
                  autocorrect: "off", autocapitalize: "off", spellcheck: "false" %>
              <div class="form-text">Auto-generated from the name. Edit if needed.</div>
            </div>

            <div class="d-flex gap-2 mt-2">
              <%= f.submit "Save & Continue", class: "btn btn-primary btn-lg" %>
              <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const nameField = document.getElementById('onboard_full_name');
  const usernameField = document.getElementById('onboard_username');
  if (!nameField || !usernameField) return;

  let userEditedUsername = false;

  usernameField.addEventListener('input', function() {
    userEditedUsername = true;
  });

  nameField.addEventListener('input', function() {
    if (!userEditedUsername || usernameField.value === '') {
      usernameField.value = nameField.value
        .toLowerCase()
        .replace(/[^a-z0-9\s]/g, '')
        .replace(/\s+/g, '');
      userEditedUsername = false;
    }
  });
})();
</script>
