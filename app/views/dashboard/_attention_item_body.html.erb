<% case item_id
when :ac_issues %>
  <% if @ac_issue_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All access controllers operating normally
    </div>
  <% else %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to access_controllers_path, class: "text-decoration-none fw-semibold" do %>
        <strong><%= @ac_issue_count %></strong> access controller <%= 'issue'.pluralize(@ac_issue_count) %>
      <% end %>
      <div class="text-muted small mt-1">
        <% parts = [] %>
        <% parts << "#{@ac_offline_count} offline" if @ac_offline_count > 0 %>
        <% parts << "#{@ac_sync_failed_count} sync failed" if @ac_sync_failed_count > 0 %>
        <% parts << "#{@ac_backup_failed_count} backup failed" if @ac_backup_failed_count > 0 %>
        <%= parts.join(', ') %>
      </div>
    </div>
  <% end %>
<% when :payment_processors %>
  <% if @payment_processors_sync_unhealthy.empty? %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      Payment processor API syncs are healthy
    </div>
  <% else %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to payment_processors_path, class: "text-decoration-none fw-semibold" do %>
        <strong><%= @payment_processors_sync_unhealthy.size %></strong>
        payment processor <%= 'integration'.pluralize(@payment_processors_sync_unhealthy.size) %> with sync problems
      <% end %>
      <div class="text-muted small mt-1">
        <%= @payment_processors_sync_unhealthy.map { |p| "#{p.name} (#{p.status_label})" }.join(', ') %>
      </div>
    </div>
  <% end %>
<% when :authentik %>
  <% if @authentik_api_urgent %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to authentik_webhooks_path, class: "text-decoration-none fw-semibold" do %>
        Authentik API integration is not configured
      <% end %>
      <div class="text-muted small mt-1">
        Set <code>AUTHENTIK_TOKEN</code> (and a valid API base URL) so group sync, provisioning, and webhooks can call Authentik.
      </div>
    </div>
  <% elsif @authentik_member_source.nil? || !@authentik_member_source.enabled? %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      Authentik member source disabled — no sync alerts
    </div>
  <% elsif @authentik_sync_issue %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to member_source_path(@authentik_sync_issue), class: "text-decoration-none fw-semibold" do %>
        Authentik sync is <%= @authentik_sync_issue.sync_status_label.downcase %>
      <% end %>
      <% if @authentik_sync_issue.last_error_message.present? %>
        <div class="text-muted small mt-1 text-break">
          <%= truncate(@authentik_sync_issue.last_error_message, length: 200) %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      Authentik sync is healthy
    </div>
  <% end %>
<% when :membership_applications %>
  <% if @pending_applications_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No pending membership applications
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to membership_applications_path(status: 'submitted'), class: 'text-decoration-none fw-semibold' do %>
        <strong><%= @pending_applications_count %></strong> pending membership <%= 'application'.pluralize(@pending_applications_count) %>
      <% end %>
      <div class="text-muted small mt-1">
        <%= "#{@submitted_applications_count} open" if @submitted_applications_count > 0 %>
      </div>
    </div>
  <% end %>
<% when :unlinked_recharge %>
  <% if @unlinked_recharge_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No unlinked Recharge payments
    </div>
  <% else %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to recharge_payments_path(linked: 'no'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @unlinked_recharge_count %></strong> unlinked Recharge <%= 'payment'.pluralize(@unlinked_recharge_count) %>
      <% end %>
    </div>
  <% end %>
<% when :mail_queue %>
  <% if @queued_mail_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      Mail queue is empty
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to queued_mails_path, class: "text-decoration-none fw-semibold" do %>
        <strong><%= @queued_mail_count %></strong> <%= 'message'.pluralize(@queued_mail_count) %> in mail queue
      <% end %>
    </div>
  <% end %>
<% when :incidents %>
  <% if @active_incident_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No open or draft incident reports
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to incident_reports_path, class: "text-decoration-none fw-semibold" do %>
        <strong><%= @active_incident_count %></strong> incident <%= 'report'.pluralize(@active_incident_count) %>
      <% end %>
      <div class="text-muted small mt-1">
        <% parts = [] %>
        <% parts << "#{@open_incident_count} open" if @open_incident_count > 0 %>
        <% parts << "#{@draft_incident_count} draft" if @draft_incident_count > 0 %>
        <%= parts.join(', ') %>
      </div>
    </div>
  <% end %>
<% when :email_templates %>
  <% if @templates_needing_review_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All email templates have been reviewed
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to email_templates_path(filter: 'needs_review'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @templates_needing_review_count %></strong> email <%= 'template'.pluralize(@templates_needing_review_count) %> need review
      <% end %>
    </div>
  <% end %>
<% when :interests %>
  <% if @interests_needing_review_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All member-suggested interests reviewed
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to interests_path(filter: 'needs_review'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @interests_needing_review_count %></strong> member-suggested <%= 'interest'.pluralize(@interests_needing_review_count) %> need review
      <% end %>
    </div>
  <% end %>
<% when :emergency_active_overrides %>
  <% if @emergency_active_override_count.zero? %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No members with active override
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to users_path(emergency_active_override: '1'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @emergency_active_override_count %></strong> <%= 'member'.pluralize(@emergency_active_override_count) %> with active override
      <% end %>
    </div>
  <% end %>
<% when :parking_active %>
  <% if @active_parking_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No active parking notices
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to parking_notices_path(status: 'active'), class: 'text-decoration-none fw-semibold' do %>
        <strong><%= @active_parking_count %></strong> active parking <%= 'notice'.pluralize(@active_parking_count) %>
      <% end %>
      <div class="text-muted small mt-1">
        <% parts = [] %>
        <% parts << "#{@active_parking_permit_count} #{'permit'.pluralize(@active_parking_permit_count)}" if @active_parking_permit_count > 0 %>
        <% parts << "#{@active_parking_ticket_count} #{'ticket'.pluralize(@active_parking_ticket_count)}" if @active_parking_ticket_count > 0 %>
        <%= parts.join(', ') %>
      </div>
    </div>
  <% end %>
<% when :parking_expired %>
  <% if @expired_parking_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All parking notices current
    </div>
  <% else %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to parking_notices_path(status: 'expired'), class: 'text-decoration-none fw-semibold' do %>
        <strong><%= @expired_parking_count %></strong> expired parking <%= 'notice'.pluralize(@expired_parking_count) %>
      <% end %>
      <div class="text-muted small mt-1">
        <% parts = [] %>
        <% parts << "#{@expired_parking_permit_count} #{'permit'.pluralize(@expired_parking_permit_count)}" if @expired_parking_permit_count > 0 %>
        <% parts << "#{@expired_parking_ticket_count} #{'ticket'.pluralize(@expired_parking_ticket_count)}" if @expired_parking_ticket_count > 0 %>
        <%= parts.join(', ') %>
      </div>
    </div>
  <% end %>
<% when :manual_payments_due %>
  <% if @manual_payments_due_count.zero? %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All manual payments current
    </div>
  <% else %>
    <% soon_days = MembershipSetting.manual_payment_due_soon_days %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to manual_payments_membership_plans_path, class: "text-decoration-none fw-semibold" do %>
        <strong><%= @manual_payments_due_count %></strong> <%= 'member'.pluralize(@manual_payments_due_count) %> with manual payments overdue or due soon
      <% end %>
      <div class="text-muted small mt-1">
        <% if soon_days.positive? %>
          “Due soon” = within <%= pluralize(soon_days, 'day') %> ·
        <% else %>
          Due today or overdue only ·
        <% end %>
        <%= link_to 'Membership Settings', membership_settings_path, class: 'link-secondary' %>
      </div>
    </div>
  <% end %>
<% when :lapsed_with_access %>
  <% if @lapsed_with_access_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No lapsed members using access control
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
      <%= link_to reports_view_all_path('lapsed-with-access'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @lapsed_with_access_count %></strong> lapsed <%= 'member'.pluralize(@lapsed_with_access_count) %> using access control
      <% end %>
    </div>
  <% end %>
<% when :legacy_recent_access %>
  <% if @legacy_recent_access_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No legacy members using access control recently
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
      <%= link_to reports_view_all_path('legacy-recent-access'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @legacy_recent_access_count %></strong> legacy <%= 'member'.pluralize(@legacy_recent_access_count) %> using access control in the last year
      <% end %>
    </div>
  <% end %>
<% when :lapsed_with_slack %>
  <% if @lapsed_with_slack_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No lapsed members with Slack accounts
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
      <%= link_to reports_path(tab: 'lapsed-with-slack'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @lapsed_with_slack_count %></strong> lapsed <%= 'member'.pluralize(@lapsed_with_slack_count) %> with Slack accounts
      <% end %>
    </div>
  <% end %>
<% when :legacy_with_slack %>
  <% if @legacy_with_slack_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No legacy members with Slack accounts
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
      <%= link_to reports_path(tab: 'legacy-with-slack'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @legacy_with_slack_count %></strong> legacy <%= 'member'.pluralize(@legacy_with_slack_count) %> with Slack accounts
      <% end %>
    </div>
  <% end %>
<% when :lapsed_active_slack %>
  <% if @lapsed_active_slack_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No lapsed members still active on Slack
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
      <%= link_to reports_path(tab: 'lapsed-active-slack'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @lapsed_active_slack_count %></strong> lapsed <%= 'member'.pluralize(@lapsed_active_slack_count) %> still active on Slack
      <% end %>
    </div>
  <% end %>
<% when :legacy_active_slack %>
  <% if @legacy_active_slack_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No legacy members still active on Slack
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
      <%= link_to reports_path(tab: 'legacy-active-slack'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @legacy_active_slack_count %></strong> legacy <%= 'member'.pluralize(@legacy_active_slack_count) %> still active on Slack
      <% end %>
    </div>
  <% end %>
<% when :slack_inactive %>
  <% if @slack_inactive_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All Slack users have been active in the last year
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
      <%= link_to reports_path(tab: 'slack-inactive'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @slack_inactive_count %></strong> Slack <%= 'user'.pluralize(@slack_inactive_count) %> inactive for over a year
      <% end %>
    </div>
  <% end %>
<% when :active_no_email %>
  <% if @active_no_email_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All active members have an email address
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
      <%= link_to reports_path(tab: 'active-no-email'), class: "text-decoration-none fw-semibold" do %>
        <strong><%= @active_no_email_count %></strong> active <%= 'member'.pluralize(@active_no_email_count) %> with no email address
      <% end %>
    </div>
  <% end %>
<% when :ai_ollama %>
  <% if @ai_ollama_urgent %>
    <% bad = @ai_ollama_profiles.select(&:urgent_health_issue?) %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to ai_ollama_profiles_path, class: "text-decoration-none fw-semibold" do %>
        AI / Ollama: <strong><%= bad.size %></strong> unhealthy <%= 'endpoint'.pluralize(bad.size) %>
      <% end %>
      <div class="text-muted small mt-1">
        <% bad.each do |p| %>
          <div class="text-break"><span class="fw-semibold"><%= p.name %>:</span> <%= truncate(p.last_health_error.to_s, length: 160) %></div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      AI endpoints healthy
      <div class="mt-1">
        <%= link_to "Manage AI", ai_ollama_profiles_path, class: "link-secondary small" %>
      </div>
    </div>
  <% end %>
<% when :ai_ollama_unconfigured %>
  <% if @ai_ollama_unconfigured %>
    <% missing = @ai_ollama_profiles.select { |p| p.enabled? && p.effective_base_url.blank? } %>
    <div>
      <h6 class="mb-2">AI unconfigured</h6>
      <div class="small text-muted">
        <% missing.each do |p| %>
          <div class="text-warning mb-1">
            <i class="bi bi-exclamation-circle me-1"></i>
            <span class="fw-semibold"><%= p.name %></span> — no Ollama endpoint
          </div>
        <% end %>
      </div>
      <div class="mt-2">
        <%= link_to "Manage AI", ai_ollama_profiles_path, class: "link-secondary small" %>
      </div>
    </div>
  <% else %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All enabled AI profiles have an Ollama endpoint
      <div class="mt-1">
        <%= link_to "Manage AI", ai_ollama_profiles_path, class: "link-secondary small" %>
      </div>
    </div>
  <% end %>
<% end %>
