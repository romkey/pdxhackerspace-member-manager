        <% parts << "#{@open_incident_count} open" if @open_incident_count > 0 %>
        <% parts << "#{@draft_incident_count} draft" if @draft_incident_count > 0 %>
        <%= parts.join(', ') %>
      </div>
    </div>
  <% end %>
