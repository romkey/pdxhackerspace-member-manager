<% case item_id
when :ac_issues %>
  <% if @ac_issue_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      All access controllers operating normally
    </div>
  <% else %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to access_controllers_path, class: "text-decoration-none fw-semibold" do %>
        <strong><%= @ac_issue_count %></strong> access controller <%= 'issue'.pluralize(@ac_issue_count) %>
      <% end %>
      <div class="text-muted small mt-1">
        <% parts = [] %>
        <% parts << "#{@ac_offline_count} offline" if @ac_offline_count > 0 %>
        <% parts << "#{@ac_sync_failed_count} sync failed" if @ac_sync_failed_count > 0 %>
        <% parts << "#{@ac_backup_failed_count} backup failed" if @ac_backup_failed_count > 0 %>
        <%= parts.join(', ') %>
      </div>
    </div>
  <% end %>
<% when :payment_processors %>
  <% if @payment_processors_sync_unhealthy.empty? %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      Payment processor API syncs are healthy
    </div>
  <% else %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to payment_processors_path, class: "text-decoration-none fw-semibold" do %>
        <strong><%= @payment_processors_sync_unhealthy.size %></strong>
        payment processor <%= 'integration'.pluralize(@payment_processors_sync_unhealthy.size) %> with sync problems
      <% end %>
      <div class="text-muted small mt-1">
        <%= @payment_processors_sync_unhealthy.map { |p| "#{p.name} (#{p.status_label})" }.join(', ') %>
      </div>
    </div>
  <% end %>
<% when :authentik %>
  <% if @authentik_api_urgent %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to authentik_webhooks_path, class: "text-decoration-none fw-semibold" do %>
        Authentik API integration is not configured
      <% end %>
      <div class="text-muted small mt-1">
        Set <code>AUTHENTIK_TOKEN</code> (and a valid API base URL) so group sync, provisioning, and webhooks can call Authentik.
      </div>
    </div>
  <% elsif @authentik_member_source.nil? || !@authentik_member_source.enabled? %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      Authentik member source disabled — no sync alerts
    </div>
  <% elsif @authentik_sync_issue %>
    <div>
      <i class="bi bi-x-circle-fill text-danger me-1"></i>
      <%= link_to member_source_path(@authentik_sync_issue), class: "text-decoration-none fw-semibold" do %>
        Authentik sync is <%= @authentik_sync_issue.sync_status_label.downcase %>
      <% end %>
      <% if @authentik_sync_issue.last_error_message.present? %>
        <div class="text-muted small mt-1 text-break">
          <%= truncate(@authentik_sync_issue.last_error_message, length: 200) %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      Authentik sync is healthy
    </div>
  <% end %>
<% when :membership_applications %>
  <% if @pending_applications_count == 0 %>
    <div>
      <i class="bi bi-check-circle-fill text-success me-1"></i>
      No pending membership applications
    </div>
  <% else %>
    <div>
      <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
      <%= link_to membership_applications_path(status: 'submitted'), class: 'text-decoration-none fw-semibold' do %>
        <strong><%= @pending_applications_count %></strong> pending membership <%= 'application'.pluralize(@pending_applications_count) %>
      <% end %>
      <div class="text-muted small mt-1">
        <% parts = [] %>
        <% parts << "#{@submitted_applications_count} submitted" if @submitted_applications_count > 0 %>
        <% parts << "#{@under_review_applications_count} under review" if @under_review_applications_count > 0 %>
        <%= parts.join(', ') %>
      </div>
    </div>
  <% end %>
