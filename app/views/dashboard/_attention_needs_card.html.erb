<%# locals: attention_need %>
<div class="card dashboard-panel mb-4">
  <div class="card-header rounded-0">
    <h2 class="h-section-label mb-0">Needs attention</h2>
  </div>
  <div class="card-body p-0">
    <% if attention_need.empty? %>
      <ul class="list-group list-group-flush">
        <li class="list-group-item py-3 text-muted">
          <span class="status-dot status-success me-2" title="OK"></span>
          Nothing needs attention right now.
        </li>
      </ul>
    <% else %>
      <ul class="list-group list-group-flush">
        <%= render 'dashboard/attention_tiered_list', items: attention_need %>
      </ul>
    <% end %>
  </div>
</div>
