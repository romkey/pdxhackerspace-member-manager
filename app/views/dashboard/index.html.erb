<div class="py-4">
  <ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item" role="presentation">
      <%= link_to root_path(tab: :admin_dashboard), class: "nav-link #{'active' if @active_tab == :admin_dashboard}", role: "tab" do %>
        <i class="bi bi-speedometer2 me-1"></i> Admin Dashboard
      <% end %>
    </li>
    <li class="nav-item" role="presentation">
      <%= link_to root_path(tab: :member_dashboard), class: "nav-link #{'active' if @active_tab == :member_dashboard}", role: "tab" do %>
        <i class="bi bi-person-badge me-1"></i> Member Dashboard
      <% end %>
    </li>
    <li class="nav-item" role="presentation">
      <%= link_to root_path(tab: :profile), class: "nav-link #{'active' if @active_tab == :profile}", role: "tab" do %>
        <i class="bi bi-person me-1"></i> Profile
      <% end %>
    </li>
    <li class="nav-item" role="presentation">
      <%= link_to root_path(tab: :payments), class: "nav-link #{'active' if @active_tab == :payments}", role: "tab" do %>
        <i class="bi bi-credit-card me-1"></i> Payment History
        <% if @home_payments_count.to_i > 0 %>
          <span class="badge bg-secondary ms-1"><%= @home_payments_count %></span>
        <% end %>
      <% end %>
    </li>
    <% if @home_parking_notices_count.to_i > 0 %>
      <li class="nav-item" role="presentation">
        <%= link_to root_path(tab: :parking), class: "nav-link #{'active' if @active_tab == :parking}", role: "tab" do %>
          <i class="bi bi-car-front me-1"></i> Parking
          <span class="badge bg-secondary ms-1"><%= @home_parking_notices_count %></span>
        <% end %>
      </li>
    <% end %>
    <li class="nav-item" role="presentation">
      <%= link_to messages_path(folder: :unread), class: 'nav-link', role: 'tab' do %>
        <i class="bi bi-chat-dots me-1"></i> Messages
        <% if @home_unread_messages_count.to_i > 0 %>
          <span class="badge bg-danger ms-1"><%= @home_unread_messages_count %></span>
        <% elsif @home_messages_count.to_i > 0 %>
          <span class="badge bg-secondary ms-1"><%= @home_messages_count %></span>
        <% end %>
      <% end %>
    </li>
  </ul>

  <% if @active_tab.in?(%i[member_dashboard profile]) %>
    <% member_since = @home_user.membership_start_date || @home_user.created_at %>
    <div class="d-flex align-items-center justify-content-between mb-3">
      <div class="d-flex align-items-center gap-3">
        <%= render 'users/member_avatar_44', user: @home_user, editable: @active_tab == :profile %>
        <div>
          <% if @active_tab == :profile %>
            <div class="h-page-title mb-0">Your profile</div>
            <div class="text-12 text-secondary">How others see you and how we reach you</div>
          <% else %>
            <div class="h-page-title mb-0">Hi, <%= @home_user.display_name %></div>
            <div class="text-12 text-secondary">Member since <%= member_since.strftime('%b %Y') %></div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @active_tab == :admin_dashboard %>
  <% attention_need = @dashboard_attention_items.reject { |i| i[:ok] } %>
  <% attention_ok = @dashboard_attention_items.select { |i| i[:ok] } %>

  <div class="d-flex align-items-end justify-content-between mb-3">
    <div>
      <h1 class="h-page-title mb-0">Admin dashboard</h1>
      <div class="text-13 text-secondary mt-1">
        <span class="text-body"><%= @active_user_count %></span> active members ·
        <span class="text-body"><%= @user_count %></span> total ·
        <span class="<%= attention_need.any? ? 'text-warning' : 'text-secondary' %>"><%= attention_need.size %></span> need attention
      </div>
    </div>
  </div>

  <!-- Member Search (full width) -->
  <div class="card dashboard-panel dashboard-panel-search mb-3">
    <div class="card-body py-2">
      <div class="position-relative">
        <input type="text" id="dashboard_member_search" class="form-control form-control-sm"
               placeholder="Find a member by name, email or username" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
               data-search-url="<%= api_users_search_path %>">
        <div id="dashboard_search_results" class="position-absolute w-100 bg-body border rounded shadow-sm mt-1"
             style="max-height: 300px; overflow-y: auto; z-index: 1000; display: none;">
        </div>
        <div id="dashboard_no_results" class="position-absolute w-100 bg-body border rounded shadow-sm mt-1 p-3 text-center text-muted"
             style="z-index: 1000; display: none;">
          No members found matching your search.
        </div>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-2 mb-3">
    <div class="col-sm-6 col-lg-4">
      <div class="kpi-tile h-100 <%= 'warning' if attention_need.any? %>">
        <div class="kpi-label">Needs attention</div>
        <div class="kpi-value"><%= attention_need.size %></div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-4">
      <%= link_to users_path(filter: 'active'), class: "kpi-tile clickable d-block text-decoration-none h-100" do %>
        <div class="kpi-label">Active members</div>
        <div class="kpi-value"><%= @active_user_count %> <span class="text-secondary fs-6 fw-normal">/ <%= @user_count %></span></div>
      <% end %>
    </div>
    <div class="col-sm-6 col-lg-4">
      <%= link_to slack_users_path, class: "kpi-tile clickable d-block text-decoration-none h-100" do %>
        <div class="kpi-label">Slack users</div>
        <div class="kpi-value"><%= @slack_user_count %></div>
      <% end %>
    </div>
  </div>

  <div class="row align-items-start g-4">
    <!-- Main column: actions + attention items -->
    <div class="col-lg-8">
      <div class="card dashboard-panel mb-4">
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-4">
              <div class="h-section-label mb-2">Members</div>
              <div class="d-flex flex-wrap gap-2">
                <%= link_to onboard_path, class: "btn btn-primary btn-sm" do %>
                  <i class="bi bi-person-badge me-1"></i>New member
                <% end %>
                <%= link_to new_invitation_path, class: "btn btn-outline-secondary btn-sm" do %>
                  <i class="bi bi-envelope-plus me-1"></i>Invitation
                <% end %>
                <%= link_to new_rfid_path, class: "btn btn-outline-secondary btn-sm" do %>
                  <i class="bi bi-key me-1"></i>Key
                <% end %>
                <% if current_user_admin? || current_user&.trainer_capabilities&.any? %>
                  <%= link_to train_member_path, class: "btn btn-outline-secondary btn-sm" do %>
                    <i class="bi bi-mortarboard me-1"></i>Train
                  <% end %>
                <% end %>
              </div>
            </div>
            <div class="col-md-4">
              <div class="h-section-label mb-2">Building</div>
              <div class="d-flex flex-wrap gap-2">
                <%= link_to new_parking_notice_path(type: 'permit'), class: "btn btn-outline-secondary btn-sm" do %>
                  <i class="bi bi-p-circle me-1"></i>Parking permit
                <% end %>
                <%= link_to new_parking_notice_path(type: 'ticket'), class: "btn btn-outline-secondary btn-sm" do %>
                  <i class="bi bi-ticket-perforated me-1"></i>Parking ticket
                <% end %>
                <% if current_user_admin? %>
                  <%= link_to access_controllers_path, class: "btn btn-outline-secondary btn-sm" do %>
                    <i class="bi bi-router me-1"></i>Access controllers
                  <% end %>
                <% end %>
              </div>
            </div>
            <div class="col-md-4">
              <div class="h-section-label mb-2">Operations</div>
              <div class="d-flex flex-wrap gap-2">
                <%= link_to new_incident_report_path, class: "btn btn-outline-secondary btn-sm" do %>
                  <i class="bi bi-exclamation-triangle me-1"></i>Incident report
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%= render 'dashboard/attention_needs_card', attention_need: attention_need %>
      <%= render 'dashboard/attention_all_good_card', attention_ok: attention_ok if attention_ok.any? %>
    </div>

    <!-- Highlights Column -->
    <div class="col-lg-4">
      <div class="card dashboard-panel">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h2 class="h-section-label mb-0">Recent highlights</h2>
          <%= link_to "View all", journals_path(filter: 'highlights'), class: "btn btn-sm btn-outline-secondary" %>
        </div>
        <div class="card-body p-0" style="max-height: 1200px; overflow-y: auto;">
          <% if @recent_highlights.any? %>
            <div class="list-group list-group-flush">
              <% @recent_highlights.each do |j| %>
                <div class="list-group-item list-group-item-action px-3 py-2 text-13">
                  <div class="d-flex justify-content-between align-items-start mb-1">
                    <% dot_class = case j.action
                                  when 'created', 'application_approved' then 'status-success'
                                  when 'incident_report_involvement', 'banned', 'application_rejected' then 'status-danger'
                                  when 'membership_status_changed', 'activated', 'deactivated' then 'status-warning'
                                  else 'status-muted'
                                  end %>
                    <span class="text-secondary text-12"><span class="status-dot <%= dot_class %> me-1" title="<%= j.action.humanize %>"></span><%= j.action.humanize %></span>
                    <small class="text-secondary"><%= time_ago_in_words(j.changed_at) %> ago</small>
                  </div>
                  <div class="fw-medium">
                    <% if j.user.present? %>
                      <%= link_to j.user.display_name, user_path(j.user), class: "text-decoration-none" %>
                    <% elsif j.changes_json.dig('application', 'email').present? %>
                      <%= j.changes_json.dig('application', 'email') %>
                    <% else %>
                      <span class="text-muted">N/A</span>
                    <% end %>
                  </div>
                  <% if j.action.start_with?('application_') && j.changes_json['application'].present? %>
                    <% app = j.changes_json['application'] %>
                    <small class="text-muted d-block">
                      Status: <%= app['status']&.titleize %>
                      <% if app['id'].present? %>
                        &middot; <%= link_to "View", membership_application_path(app['id']), class: "link-primary" %>
                      <% end %>
                    </small>
                  <% elsif j.action == 'incident_report_involvement' && j.changes_json['incident_report'].present? %>
                    <% ir = j.changes_json['incident_report'] %>
                    <small class="text-muted d-block">
                      <%= ir['type'] %>: <%= truncate(ir['subject'], length: 40) %>
                    </small>
                  <% elsif j.changes_json['training'].is_a?(Hash) %>
                    <small class="text-muted d-block">
                      <span class="badge text-bg-primary-subtle"><%= j.changes_json['training']['topic'] %></span>
                    </small>
                  <% elsif j.changes_json['trainer_capability'].is_a?(Hash) %>
                    <small class="text-muted d-block">
                      <span class="badge text-bg-info-subtle"><%= j.changes_json['trainer_capability']['topic'] %></span>
                      <span>can train others</span>
                    </small>
                  <% elsif j.changes_json.present? %>
                    <% key_changes = j.changes_json.keys & %w[membership_status active banned deceased] %>
                    <% if key_changes.any? %>
                      <small class="text-muted d-block">
                        <% key_changes.first(2).each do |field| %>
                          <% change = j.changes_json[field] %>
                          <%= field.humanize %>: <%= change['from'] || '(none)' %> → <%= change['to'] || '(none)' %><br>
                        <% end %>
                      </small>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="p-4 text-center text-muted">
              <i class="bi bi-star display-4 mb-2 d-block opacity-25"></i>
              No highlights in the last 2 weeks.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <% elsif @active_tab == :member_dashboard %>
    <%= render 'users/tab_dashboard_self', user: @home_user %>
  <% elsif @active_tab == :profile %>
    <%= render 'users/tab_profile_self', user: @home_user %>
  <% elsif @active_tab == :payments %>
    <%= render 'users/tab_payments', payments: @home_payments, pagy: @pagy_payments, user: @home_user, show_payment_links: false, dashboard_mode: true %>
  <% elsif @active_tab == :parking %>
    <%= render 'users/tab_parking', parking_notices: @home_parking_notices_list, show_actions: false %>
  <% else %>
    <%= render 'users/tab_dashboard_self', user: @home_user %>
  <% end %>

<% if @active_tab == :admin_dashboard %>
<script>
  (function() {
    var _debounceTimer = null;
    var _abortController = null;

    function initDashboardSearch() {
      var searchInput = document.getElementById('dashboard_member_search');
      var searchResults = document.getElementById('dashboard_search_results');
      var noResults = document.getElementById('dashboard_no_results');
      if (!searchInput || !searchResults) return;

      var searchUrl = searchInput.getAttribute('data-search-url');

      function hideDropdowns() {
        searchResults.style.display = 'none';
        noResults.style.display = 'none';
      }

      function renderResults(users) {
        searchResults.innerHTML = '';
        users.forEach(function(user) {
          var a = document.createElement('a');
          a.href = '/users/' + user.id;
          a.className = 'd-block p-3 text-decoration-none border-bottom search-result-item';
          var nameDiv = document.createElement('div');
          nameDiv.className = 'fw-semibold';
          nameDiv.textContent = user.name;
          a.appendChild(nameDiv);
          if (user.email) {
            var emailDiv = document.createElement('div');
            emailDiv.className = 'text-muted small';
            emailDiv.textContent = user.email;
            a.appendChild(emailDiv);
          }
          a.addEventListener('mouseenter', function() { a.classList.add('bg-body-secondary'); });
          a.addEventListener('mouseleave', function() { a.classList.remove('bg-body-secondary'); });
          searchResults.appendChild(a);
        });
      }

      function doSearch() {
        var q = searchInput.value.trim();
        if (q.length < 2) { hideDropdowns(); return; }

        if (_abortController) _abortController.abort();
        _abortController = new AbortController();

        fetch(searchUrl + '?q=' + encodeURIComponent(q), {
          signal: _abortController.signal,
          headers: { 'Accept': 'application/json' }
        })
        .then(function(r) { return r.json(); })
        .then(function(users) {
          if (users.length === 0) {
            searchResults.style.display = 'none';
            noResults.style.display = 'block';
          } else {
            renderResults(users);
            searchResults.style.display = 'block';
            noResults.style.display = 'none';
          }
        })
        .catch(function(err) {
          if (err.name !== 'AbortError') console.error('Search failed:', err);
        });
      }

      searchInput.addEventListener('input', function() {
        clearTimeout(_debounceTimer);
        _debounceTimer = setTimeout(doSearch, 200);
      });

      searchInput.addEventListener('focus', function() {
        if (searchInput.value.trim().length >= 2) doSearch();
      });

      document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
          hideDropdowns();
        }
      });

      searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          hideDropdowns();
          searchInput.blur();
        } else if (e.key === 'Enter') {
          var firstVisible = searchResults.querySelector('.search-result-item');
          if (firstVisible && searchResults.style.display !== 'none') {
            window.location.href = firstVisible.href;
          }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', initDashboardSearch);
    document.addEventListener('turbo:load', initDashboardSearch);
  })();
</script>
<% end %>
</div>
