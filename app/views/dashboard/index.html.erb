<div class="py-4">
  <!-- Member Search (full width) -->
  <div class="card dashboard-panel mb-4">
    <div class="card-body py-3">
      <div class="position-relative">
        <input type="text" id="dashboard_member_search" class="form-control form-control-lg"
               placeholder="Find a member by name, email or username" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
               data-search-url="<%= api_users_search_path %>">
        <div id="dashboard_search_results" class="position-absolute w-100 bg-body border rounded shadow-sm mt-1"
             style="max-height: 300px; overflow-y: auto; z-index: 1000; display: none;">
        </div>
        <div id="dashboard_no_results" class="position-absolute w-100 bg-body border rounded shadow-sm mt-1 p-3 text-center text-muted"
             style="z-index: 1000; display: none;">
          No members found matching your search.
        </div>
      </div>
    </div>
  </div>

  <!-- Stats (full width, unboxed) -->
  <div class="mb-4">
    <div class="d-flex flex-wrap justify-content-center gap-4 text-center py-2">
      <div>
        <span class="text-muted">Members:</span>
        <%= link_to "#{@active_user_count} active", users_path(filter: 'active'), class: "fw-bold text-decoration-none" %>
        /
        <%= link_to "#{@user_count} total", users_path, class: "fw-bold text-decoration-none" %>
      </div>
      <div class="border-start ps-4">
        <span class="text-muted">Slack:</span>
        <%= link_to @slack_user_count, slack_users_path, class: "fw-bold text-decoration-none" %>
      </div>
      <div class="border-start ps-4">
        <span class="text-muted">Sheet:</span>
        <%= link_to @sheet_entry_count, sheet_entries_path, class: "fw-bold text-decoration-none" %>
      </div>
    </div>
  </div>

  <div class="row align-items-start g-4">
    <!-- Main column: actions + attention items -->
    <div class="col-lg-8">
      <!-- Quick Actions -->
      <div class="card dashboard-panel mb-4">
        <div class="card-body">
          <div class="d-flex flex-wrap justify-content-center gap-3 mb-3">
            <%= link_to onboard_path, class: "btn btn-primary btn-lg" do %>
              <i class="bi bi-person-badge me-2"></i>Onboard New Member
            <% end %>
            <%= link_to new_invitation_path, class: "btn btn-info btn-lg" do %>
              <i class="bi bi-envelope-plus me-2"></i>Send Invitation
            <% end %>
            <%= link_to new_rfid_path, class: "btn btn-success btn-lg" do %>
              <i class="bi bi-key me-2"></i>Add Key Fob
            <% end %>
          </div>
          <div class="d-flex flex-wrap justify-content-center gap-3 mb-3">
            <% if current_user_admin? || current_user&.trainer_capabilities&.any? %>
              <%= link_to train_member_path, class: "btn btn-info btn-lg" do %>
                <i class="bi bi-mortarboard me-2"></i>Train a Member
              <% end %>
            <% end %>
            <%= link_to new_parking_notice_path(type: 'permit'), class: "btn btn-success btn-lg" do %>
              <i class="bi bi-p-circle me-2"></i>New Parking Permit
            <% end %>
            <%= link_to new_parking_notice_path(type: 'ticket'), class: "btn btn-danger btn-lg" do %>
              <i class="bi bi-ticket-perforated me-2"></i>New Parking Ticket
            <% end %>
          </div>
          <div class="d-flex flex-wrap justify-content-center gap-3">
            <%= link_to new_incident_report_path, class: "btn btn-warning btn-lg" do %>
              <i class="bi bi-exclamation-triangle me-2"></i>New Incident Report
            <% end %>
            <% if current_user_admin? %>
              <%= link_to access_controllers_path, class: "btn btn-secondary btn-lg" do %>
                <i class="bi bi-router me-2"></i>Access Controllers
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Needs Attention -->
      <% item_number = 0 %>

      <div class="card dashboard-panel mb-4">
        <div class="card-body p-0">
          <section class="dashboard-attention-section">
            <div class="card-header bg-danger bg-opacity-10 rounded-0">
              <h5 class="mb-0"><i class="bi bi-exclamation-octagon-fill text-danger me-2"></i>Urgent</h5>
            </div>
            <ul class="list-group list-group-flush">

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @ac_issue_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  All access controllers operating normally
                </div>
              <% else %>
                <div>
                  <i class="bi bi-x-circle-fill text-danger me-1"></i>
                  <%= link_to access_controllers_path, class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @ac_issue_count %></strong> access controller <%= 'issue'.pluralize(@ac_issue_count) %>
                  <% end %>
                  <div class="text-muted small mt-1">
                    <% parts = [] %>
                    <% parts << "#{@ac_offline_count} offline" if @ac_offline_count > 0 %>
                    <% parts << "#{@ac_sync_failed_count} sync failed" if @ac_sync_failed_count > 0 %>
                    <% parts << "#{@ac_backup_failed_count} backup failed" if @ac_backup_failed_count > 0 %>
                    <%= parts.join(', ') %>
                  </div>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @payment_processors_sync_unhealthy.empty? %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  Payment processor API syncs are healthy
                </div>
              <% else %>
                <div>
                  <i class="bi bi-x-circle-fill text-danger me-1"></i>
                  <%= link_to payment_processors_path, class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @payment_processors_sync_unhealthy.size %></strong>
                    payment processor <%= 'integration'.pluralize(@payment_processors_sync_unhealthy.size) %> with sync problems
                  <% end %>
                  <div class="text-muted small mt-1">
                    <%= @payment_processors_sync_unhealthy.map { |p| "#{p.name} (#{p.status_label})" }.join(', ') %>
                  </div>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @authentik_api_urgent %>
                <div>
                  <i class="bi bi-x-circle-fill text-danger me-1"></i>
                  <%= link_to authentik_webhooks_path, class: "text-decoration-none fw-semibold" do %>
                    Authentik API integration is not configured
                  <% end %>
                  <div class="text-muted small mt-1">
                    Set <code>AUTHENTIK_TOKEN</code> (and a valid API base URL) so group sync, provisioning, and webhooks can call Authentik.
                  </div>
                </div>
              <% elsif @authentik_member_source.nil? || !@authentik_member_source.enabled? %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  Authentik member source disabled — no sync alerts
                </div>
              <% elsif @authentik_sync_issue %>
                <div>
                  <i class="bi bi-x-circle-fill text-danger me-1"></i>
                  <%= link_to member_source_path(@authentik_sync_issue), class: "text-decoration-none fw-semibold" do %>
                    Authentik sync is <%= @authentik_sync_issue.sync_status_label.downcase %>
                  <% end %>
                  <% if @authentik_sync_issue.last_error_message.present? %>
                    <div class="text-muted small mt-1 text-break">
                      <%= truncate(@authentik_sync_issue.last_error_message, length: 200) %>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  Authentik sync is healthy
                </div>
              <% end %>
            </li>

          </ul>
          </section>

          <section class="dashboard-attention-section">
            <div class="card-header bg-info bg-opacity-10 rounded-0">
              <h5 class="mb-0"><i class="bi bi-info-circle-fill text-info me-2"></i>Important</h5>
            </div>
            <ul class="list-group list-group-flush">

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @pending_applications_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No pending membership applications
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
                  <%= link_to membership_applications_path(status: 'submitted'), class: 'text-decoration-none fw-semibold' do %>
                    <strong><%= @pending_applications_count %></strong> pending membership <%= 'application'.pluralize(@pending_applications_count) %>
                  <% end %>
                  <div class="text-muted small mt-1">
                    <% parts = [] %>
                    <% parts << "#{@submitted_applications_count} submitted" if @submitted_applications_count > 0 %>
                    <% parts << "#{@under_review_applications_count} under review" if @under_review_applications_count > 0 %>
                    <%= parts.join(', ') %>
                  </div>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @unlinked_recharge_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No unlinked Recharge payments
                </div>
              <% else %>
                <div>
                  <i class="bi bi-x-circle-fill text-danger me-1"></i>
                  <%= link_to recharge_payments_path(linked: 'no'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @unlinked_recharge_count %></strong> unlinked Recharge <%= 'payment'.pluralize(@unlinked_recharge_count) %>
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @queued_mail_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  Mail queue is empty
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
                  <%= link_to queued_mails_path, class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @queued_mail_count %></strong> <%= 'message'.pluralize(@queued_mail_count) %> in mail queue
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @active_incident_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No open or draft incident reports
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
                  <%= link_to incident_reports_path, class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @active_incident_count %></strong> incident <%= 'report'.pluralize(@active_incident_count) %>
                  <% end %>
                  <div class="text-muted small mt-1">
                    <% parts = [] %>
                    <% parts << "#{@open_incident_count} open" if @open_incident_count > 0 %>
                    <% parts << "#{@draft_incident_count} draft" if @draft_incident_count > 0 %>
                    <%= parts.join(', ') %>
                  </div>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @templates_needing_review_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  All email templates have been reviewed
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
                  <%= link_to email_templates_path(filter: 'needs_review'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @templates_needing_review_count %></strong> email <%= 'template'.pluralize(@templates_needing_review_count) %> need review
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @interests_needing_review_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No member-suggested interests waiting for review
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
                  <%= link_to interests_path(filter: 'needs_review'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @interests_needing_review_count %></strong> member-suggested <%= 'interest'.pluralize(@interests_needing_review_count) %> need review
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @active_parking_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No active parking notices
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-circle-fill text-info me-1"></i>
                  <%= link_to parking_notices_path(status: 'active'), class: 'text-decoration-none fw-semibold' do %>
                    <strong><%= @active_parking_count %></strong> active parking <%= 'notice'.pluralize(@active_parking_count) %>
                  <% end %>
                  <div class="text-muted small mt-1">
                    <% parts = [] %>
                    <% parts << "#{@active_parking_permit_count} #{'permit'.pluralize(@active_parking_permit_count)}" if @active_parking_permit_count > 0 %>
                    <% parts << "#{@active_parking_ticket_count} #{'ticket'.pluralize(@active_parking_ticket_count)}" if @active_parking_ticket_count > 0 %>
                    <%= parts.join(', ') %>
                  </div>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @expired_parking_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No expired parking notices
                </div>
              <% else %>
                <div>
                  <i class="bi bi-x-circle-fill text-danger me-1"></i>
                  <%= link_to parking_notices_path(status: 'expired'), class: 'text-decoration-none fw-semibold' do %>
                    <strong><%= @expired_parking_count %></strong> expired parking <%= 'notice'.pluralize(@expired_parking_count) %>
                  <% end %>
                  <div class="text-muted small mt-1">
                    <% parts = [] %>
                    <% parts << "#{@expired_parking_permit_count} #{'permit'.pluralize(@expired_parking_permit_count)}" if @expired_parking_permit_count > 0 %>
                    <% parts << "#{@expired_parking_ticket_count} #{'ticket'.pluralize(@expired_parking_ticket_count)}" if @expired_parking_ticket_count > 0 %>
                    <%= parts.join(', ') %>
                  </div>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <div>
                <i class="bi bi-check-circle-fill text-success me-1"></i>
                <span class="text-muted">Manual payments due</span>
                <span class="text-muted fst-italic small ms-1">(coming soon)</span>
              </div>
            </li>

          </ul>
          </section>

          <section class="dashboard-attention-section">
            <div class="card-header bg-warning bg-opacity-10 rounded-0">
              <h5 class="mb-0"><i class="bi bi-clipboard-check text-warning me-2"></i>Housekeeping</h5>
            </div>
            <ul class="list-group list-group-flush">

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @lapsed_with_access_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No lapsed members using access control
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                  <%= link_to reports_view_all_path('lapsed-with-access'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @lapsed_with_access_count %></strong> lapsed <%= 'member'.pluralize(@lapsed_with_access_count) %> using access control
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @legacy_recent_access_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No legacy members using access control recently
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                  <%= link_to reports_view_all_path('legacy-recent-access'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @legacy_recent_access_count %></strong> legacy <%= 'member'.pluralize(@legacy_recent_access_count) %> using access control in the last year
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @lapsed_with_slack_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No lapsed members with Slack accounts
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                  <%= link_to reports_path(tab: 'lapsed-with-slack'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @lapsed_with_slack_count %></strong> lapsed <%= 'member'.pluralize(@lapsed_with_slack_count) %> with Slack accounts
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @legacy_with_slack_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No legacy members with Slack accounts
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                  <%= link_to reports_path(tab: 'legacy-with-slack'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @legacy_with_slack_count %></strong> legacy <%= 'member'.pluralize(@legacy_with_slack_count) %> with Slack accounts
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @lapsed_active_slack_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No lapsed members still active on Slack
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                  <%= link_to reports_path(tab: 'lapsed-active-slack'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @lapsed_active_slack_count %></strong> lapsed <%= 'member'.pluralize(@lapsed_active_slack_count) %> still active on Slack
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @legacy_active_slack_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  No legacy members still active on Slack
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                  <%= link_to reports_path(tab: 'legacy-active-slack'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @legacy_active_slack_count %></strong> legacy <%= 'member'.pluralize(@legacy_active_slack_count) %> still active on Slack
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @slack_inactive_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  All Slack users have been active in the last year
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                  <%= link_to reports_path(tab: 'slack-inactive'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @slack_inactive_count %></strong> Slack <%= 'user'.pluralize(@slack_inactive_count) %> inactive for over a year
                  <% end %>
                </div>
              <% end %>
            </li>

            <% item_number += 1 %>
            <li class="list-group-item d-flex align-items-start gap-2 py-3">
              <span class="badge rounded-pill text-bg-secondary"><%= item_number %></span>
              <% if @active_no_email_count == 0 %>
                <div>
                  <i class="bi bi-check-circle-fill text-success me-1"></i>
                  All active members have an email address
                </div>
              <% else %>
                <div>
                  <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                  <%= link_to reports_path(tab: 'active-no-email'), class: "text-decoration-none fw-semibold" do %>
                    <strong><%= @active_no_email_count %></strong> active <%= 'member'.pluralize(@active_no_email_count) %> with no email address
                  <% end %>
                </div>
              <% end %>
            </li>

          </ul>
          </section>
        </div>
      </div>
    </div>

    <!-- Highlights Column -->
    <div class="col-lg-4">
      <div class="card dashboard-panel">
        <div class="card-header bg-warning bg-opacity-25 d-flex justify-content-between align-items-center">
          <h5 class="mb-0">
            <i class="bi bi-star-fill text-warning me-2"></i>Recent Highlights
          </h5>
          <%= link_to "View All", journals_path(filter: 'highlights'), class: "btn btn-sm btn-outline-warning" %>
        </div>
        <div class="card-body p-0" style="max-height: 600px; overflow-y: auto;">
          <% if @recent_highlights.any? %>
            <div class="list-group list-group-flush">
              <% @recent_highlights.each do |j| %>
                <div class="list-group-item list-group-item-action px-3 py-2">
                  <div class="d-flex justify-content-between align-items-start mb-1">
                    <% badge_class = case j.action
                                     when 'created' then 'text-bg-success'
                                     when 'incident_report_involvement' then 'text-bg-danger'
                                     when 'membership_status_changed', 'activated', 'deactivated' then 'text-bg-warning'
                                     when 'banned' then 'text-bg-dark'
                                     when 'training_added', 'training_removed' then 'text-bg-primary'
                                     when 'trainer_capability_added', 'trainer_capability_removed' then 'text-bg-info'
                                     when 'application_submitted' then 'text-bg-info'
                                     when 'application_approved' then 'text-bg-success'
                                     when 'application_rejected' then 'text-bg-danger'
                                     else 'text-bg-secondary'
                                     end %>
                    <span class="badge <%= badge_class %> small"><%= j.action.humanize %></span>
                    <small class="text-muted"><%= time_ago_in_words(j.changed_at) %> ago</small>
                  </div>
                  <div class="fw-semibold">
                    <% if j.user.present? %>
                      <%= link_to j.user.display_name, user_path(j.user), class: "text-decoration-none" %>
                    <% elsif j.changes_json.dig('application', 'email').present? %>
                      <%= j.changes_json.dig('application', 'email') %>
                    <% else %>
                      <span class="text-muted">N/A</span>
                    <% end %>
                  </div>
                  <% if j.action.start_with?('application_') && j.changes_json['application'].present? %>
                    <% app = j.changes_json['application'] %>
                    <small class="text-muted d-block">
                      Status: <%= app['status']&.titleize %>
                      <% if app['id'].present? %>
                        &middot; <%= link_to "View", membership_application_path(app['id']), class: "link-primary" %>
                      <% end %>
                    </small>
                  <% elsif j.action == 'incident_report_involvement' && j.changes_json['incident_report'].present? %>
                    <% ir = j.changes_json['incident_report'] %>
                    <small class="text-muted d-block">
                      <%= ir['type'] %>: <%= truncate(ir['subject'], length: 40) %>
                    </small>
                  <% elsif j.changes_json['training'].is_a?(Hash) %>
                    <small class="text-muted d-block">
                      <span class="badge text-bg-primary"><%= j.changes_json['training']['topic'] %></span>
                    </small>
                  <% elsif j.changes_json['trainer_capability'].is_a?(Hash) %>
                    <small class="text-muted d-block">
                      <span class="badge text-bg-info"><%= j.changes_json['trainer_capability']['topic'] %></span>
                      <span>can train others</span>
                    </small>
                  <% elsif j.changes_json.present? %>
                    <% key_changes = j.changes_json.keys & %w[membership_status active banned deceased] %>
                    <% if key_changes.any? %>
                      <small class="text-muted d-block">
                        <% key_changes.first(2).each do |field| %>
                          <% change = j.changes_json[field] %>
                          <%= field.humanize %>: <%= change['from'] || '(none)' %> → <%= change['to'] || '(none)' %><br>
                        <% end %>
                      </small>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="p-4 text-center text-muted">
              <i class="bi bi-star display-4 mb-2 d-block opacity-25"></i>
              No highlights in the last 2 weeks.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var _debounceTimer = null;
    var _abortController = null;

    function initDashboardSearch() {
      var searchInput = document.getElementById('dashboard_member_search');
      var searchResults = document.getElementById('dashboard_search_results');
      var noResults = document.getElementById('dashboard_no_results');
      if (!searchInput || !searchResults) return;

      var searchUrl = searchInput.getAttribute('data-search-url');

      function hideDropdowns() {
        searchResults.style.display = 'none';
        noResults.style.display = 'none';
      }

      function renderResults(users) {
        searchResults.innerHTML = '';
        users.forEach(function(user) {
          var a = document.createElement('a');
          a.href = '/users/' + user.id;
          a.className = 'd-block p-3 text-decoration-none border-bottom search-result-item';
          var nameDiv = document.createElement('div');
          nameDiv.className = 'fw-semibold';
          nameDiv.textContent = user.name;
          a.appendChild(nameDiv);
          if (user.email) {
            var emailDiv = document.createElement('div');
            emailDiv.className = 'text-muted small';
            emailDiv.textContent = user.email;
            a.appendChild(emailDiv);
          }
          a.addEventListener('mouseenter', function() { a.classList.add('bg-body-secondary'); });
          a.addEventListener('mouseleave', function() { a.classList.remove('bg-body-secondary'); });
          searchResults.appendChild(a);
        });
      }

      function doSearch() {
        var q = searchInput.value.trim();
        if (q.length < 2) { hideDropdowns(); return; }

        if (_abortController) _abortController.abort();
        _abortController = new AbortController();

        fetch(searchUrl + '?q=' + encodeURIComponent(q), {
          signal: _abortController.signal,
          headers: { 'Accept': 'application/json' }
        })
        .then(function(r) { return r.json(); })
        .then(function(users) {
          if (users.length === 0) {
            searchResults.style.display = 'none';
            noResults.style.display = 'block';
          } else {
            renderResults(users);
            searchResults.style.display = 'block';
            noResults.style.display = 'none';
          }
        })
        .catch(function(err) {
          if (err.name !== 'AbortError') console.error('Search failed:', err);
        });
      }

      searchInput.addEventListener('input', function() {
        clearTimeout(_debounceTimer);
        _debounceTimer = setTimeout(doSearch, 200);
      });

      searchInput.addEventListener('focus', function() {
        if (searchInput.value.trim().length >= 2) doSearch();
      });

      document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
          hideDropdowns();
        }
      });

      searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          hideDropdowns();
          searchInput.blur();
        } else if (e.key === 'Enter') {
          var firstVisible = searchResults.querySelector('.search-result-item');
          if (firstVisible && searchResults.style.display !== 'none') {
            window.location.href = firstVisible.href;
          }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', initDashboardSearch);
    document.addEventListener('turbo:load', initDashboardSearch);
  })();
</script>
